# Dependencies
node_modules/

# Astro build output
dist/
.astro/

# Environment & secrets (the security design keeps .env outside the repo,
# but ignore the whole family in case one lands here)
.env
.env.*
!.env.example

# Staging basic-auth credential file (architecture §14.2/§14.6, Task 63) —
# generated on the Droplet by deploy/runbook.md step 5, never committed.
deploy/nginx/staging.htpasswd

# Logs
logs/
*.log
npm-debug.log*

# Test artifacts
coverage/
playwright-report/
test-results/

# Generated by `npm run seed:e2e` (scripts/seed-e2e.ts) — a snapshot of
# whichever DB it was just run against; never hand-authored, never committed.
tests/e2e/.fixtures.json

# Database dumps / backups (never commit — contain personal data)
*.dump
*.sql.gz

# Generated at runtime by jobs/regen-sitemaps.ts (src/lib/seo/sitemaps.ts) —
# never hand-authored, never committed.
public/sitemap*.xml

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
