# Build context exclusions for the app+jobs image (Task 59).
#
# IMPORTANT: this file governs the docker build CONTEXT only. Everything the
# runtime actually reads at request/job time — src/, data/, content/,
# drizzle/, jobs/, scripts/, deploy/crontab, package.json — must stay
# reachable and is deliberately NOT excluded below. See Dockerfile for what
# gets copied into the final image.

# Design/legacy prototype tree — not part of the shipped app.
prototype/

# Reinstalled fresh in every build stage; never trust the host's copy.
node_modules/

# Documentation/spec repo content — not needed at build or run time.
# NOTE: scoped to the repo root only (leading slash) — content/pages/**/*.md
# is genuine runtime data (src/i18n/content.ts reads it) and must NOT match
# here; a bare unanchored "*.md" would wrongly exclude it recursively.
docs/
/CLAUDE.md

# VCS / CI / planning metadata.
.git/
.github/
.superpowers/

# Slide decks and other stray binary artifacts that sometimes land at repo root.
*.pptx

# Test sources and output — the image ships no test runner.
tests/
coverage/
playwright-report/
test-results/
vitest.config.ts

# Secrets / local env files — never bake these into an image.
.env
.env.*
!.env.example

# Astro's local dev cache — regenerated by `astro build`/`astro sync`.
.astro/

# Editors / OS cruft.
.vscode/
.idea/
.DS_Store
Thumbs.db
*.swp

# Previous local build output — each stage runs its own `astro build`.
dist/
