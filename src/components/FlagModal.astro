---
/**
 * Flag misinformation modal shell (Task 32, IA §7.2, PRD §6.1/§6.3,
 * design-system.md §7.9) — rendered ONCE per page (from Base.astro, same
 * convention as `src/components/RegisterLoginModal.astro`), as a native
 * `<dialog>`. Purely markup/i18n — all behavior (auth gating + resume,
 * the field/claim picker, the fetch call, success/error states) lives in
 * the client island `src/islands/FlagModal.ts`, which finds this exact
 * markup via `[data-flag-modal]` and its `data-flag-*`/`data-msg-*` hooks.
 *
 * The field/claim PICKER is entirely built client-side (the island injects
 * radio inputs — or a single pre-selected hidden input, when there's only
 * one target — into `[data-flag-target-options]`) because the set of
 * flaggable targets differs per page/ward and isn't known until the
 * "Flag an error" button that opened this modal is clicked (its
 * `data-flag-targets` JSON attribute).
 *
 * Modal shell (Close button, scrim-tap, Escape, focus trap/return, URL
 * never changes) comes from `ModalController` (src/islands/ModalShell.ts).
 */
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<dialog class="flag-modal" data-flag-modal aria-labelledby="flag-modal-title">
  <div class="flag-modal-inner">
    <button type="button" class="flag-modal-close" data-modal-close aria-label={t(lang, 'flag.modal.close')}>
      &times;
    </button>
    <h2 id="flag-modal-title">{t(lang, 'flag.modal.title')}</h2>

    <form data-flag-form novalidate>
      <div class="form-field">
        <p class="form-label" id="flag-target-label">{t(lang, 'flag.modal.targetLabel')}</p>
        <div data-flag-target-options role="radiogroup" aria-labelledby="flag-target-label"></div>
      </div>

      <div class="form-field">
        <label class="form-label" for="flag-detail">{t(lang, 'flag.modal.detailLabel')}</label>
        <textarea id="flag-detail" class="form-input" name="detail" rows="3" required></textarea>
      </div>

      <div class="form-field">
        <label class="form-label" for="flag-source">{t(lang, 'flag.modal.sourceLabel')}</label>
        <input id="flag-source" class="form-input" name="sourceUrl" type="url" />
        <p class="form-error" data-flag-source-error hidden></p>
      </div>

      <div class="form-field">
        <label class="form-label" for="flag-suggested">{t(lang, 'flag.modal.suggestedLabel')}</label>
        <input id="flag-suggested" class="form-input" name="suggestedValue" type="text" />
      </div>

      <p class="form-error" data-flag-rate-limit-error hidden></p>
      <p class="form-error" data-flag-generic-error hidden></p>

      <button type="submit" class="btn btn--primary" data-flag-submit>
        {t(lang, 'flag.modal.submit')}
      </button>
    </form>
  </div>

  <span hidden data-msg-rate-limit>{t(lang, 'flag.modal.rateLimited')}</span>
  <span hidden data-msg-source-invalid>{t(lang, 'flag.modal.sourceInvalid')}</span>
  <span hidden data-msg-generic-error>{t(lang, 'flag.modal.genericError')}</span>
  <span hidden data-msg-success>{t(lang, 'flag.modal.success')}</span>
</dialog>

<style>
  .flag-modal {
    padding: 0;
    border: none;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-modal);
    max-width: 28rem;
    width: calc(100% - var(--space-8));
  }

  .flag-modal::backdrop {
    background: rgba(26, 26, 26, 0.5);
  }

  .flag-modal-inner {
    position: relative;
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .flag-modal h2 {
    font-size: var(--text-2xl);
    line-height: var(--leading-2xl);
    margin: 0;
    padding-right: var(--space-8);
  }

  .flag-modal-close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    min-width: 44px;
    min-height: 44px;
    background: transparent;
    border: none;
    font-size: var(--text-2xl);
    line-height: 1;
    cursor: pointer;
    color: var(--color-text);
  }

  .flag-modal form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .form-label {
    margin: 0;
    font-size: var(--text-sm);
    font-weight: 700;
  }

  .form-input {
    min-height: 44px;
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-base);
    font-family: var(--font-body);
    color: var(--color-text);
    background: var(--color-bg);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  .form-input:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-color: var(--color-primary);
  }

  .form-error {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-danger);
  }

  :global([data-flag-target-options]) {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  :global(.flag-target-option) {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-base);
  }

  :global(.flag-target-single) {
    margin: 0;
    font-size: var(--text-base);
  }

  /* Success toast (design-system.md §7.12) — created dynamically by
     src/islands/FlagModal.ts's showSuccessToast, outside this component's
     own scoped DOM (it must outlive the modal closing), so its styling
     lives here as a :global rule rather than inline styles (tests/unit/
     tokens.test.ts forbids hex literals outside tokens.css; this way the
     toast, like every other component, only ever references the semantic
     tokens). Mirrors src/components/Toast.astro's `.toast--success`. */
  :global(.flag-success-toast) {
    position: fixed;
    left: 50%;
    bottom: var(--space-6);
    transform: translateX(-50%);
    max-width: calc(100vw - var(--space-8));
    padding: var(--space-3) var(--space-4);
    background: var(--color-bg);
    color: var(--color-text);
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-modal);
    border-left: 4px solid var(--color-primary);
  }

  @media (max-width: 767px) {
    .flag-modal {
      position: fixed;
      top: auto;
      bottom: 0;
      left: 0;
      right: 0;
      max-width: 100%;
      width: 100%;
      margin: 0;
      border-radius: var(--radius-md) var(--radius-md) 0 0;
    }
  }
</style>

<script>
  import { initFlagModal } from '../islands/FlagModal';
  initFlagModal();
</script>
