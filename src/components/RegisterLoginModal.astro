---
/**
 * Register/Login modal shell (Task 27, IA §7.1, design-system.md §7.9) —
 * rendered ONCE per page (from Base.astro, so it's present everywhere the
 * "Sign in" control or a "Register for updates" slot can appear) as a
 * native `<dialog>`. Purely markup/i18n — all behavior (opening, step
 * transitions, the fetch calls, resume-in-place) lives in the client
 * island `src/islands/RegisterLoginModal.ts`, which finds this exact markup
 * via `[data-register-login-modal]` and its `data-rl-*` hooks.
 *
 * Modal shell (Close button, scrim-tap, Escape, focus trap/return, URL
 * never changes) comes from `ModalController` (src/islands/ModalShell.ts) —
 * this component only supplies the dialog element and its content.
 *
 * Three steps, each its own `<form>` (never submitted natively — the
 * island always calls `preventDefault` and does the fetch itself; there is
 * no no-JS path through THIS markup, that's what `/login` is for):
 *   1. contact (email or WhatsApp number — channel inferred from the
 *      value, not a separate toggle: design-system.md §7.9 "single input
 *      per step").
 *   2. the ONE 6-digit OTP input (inputmode=numeric,
 *      autocomplete=one-time-code, maxlength=6 — never six boxes).
 *   3. confirm/register: ward (read-only pre-filled OR an editable numeric
 *      input, toggled by the island depending on whether it was opened
 *      from a ward page's register-for-updates slot), language, the
 *      consent sentence (links to /terms and /privacy, includes the 18+
 *      assertion in the wording itself — registering IS the consent act,
 *      PRD §10, so there is no separate consent checkbox), and the ONE
 *      optional "future civic tools" checkbox.
 *
 * `data-msg-*` attributes carry the handful of dynamic strings the island
 * needs to paint banners/errors, already localized server-side — same
 * convention as src/islands/WardLookup.ts, so the client bundle never
 * needs to import the full i18n table.
 */
import Button from './Button.astro';
import { t, localePath, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<dialog class="rl-modal" data-register-login-modal aria-labelledby="rl-modal-title">
  <div class="rl-modal-inner">
    <button type="button" class="rl-modal-close" data-modal-close aria-label={t(lang, 'auth.modal.close')}>
      &times;
    </button>
    <h2 id="rl-modal-title">{t(lang, 'auth.modal.title')}</h2>

    <p class="rl-banner" data-rl-banner hidden></p>

    <form data-rl-form="1" novalidate>
      <div class="form-field">
        <label class="form-label" for="rl-destination">{t(lang, 'auth.step1.contactLabel')}</label>
        <input id="rl-destination" class="form-input" name="destination" type="text" required />
      </div>
      <p class="rl-helper">{t(lang, 'auth.step1.helper')}</p>
      <Button type="submit" variant="primary" lang={lang} data-rl-submit>
        {t(lang, 'auth.step1.submit')}
      </Button>
    </form>

    <form data-rl-form="2" hidden novalidate>
      <p>{t(lang, 'auth.step1.sent')}</p>
      <div class="form-field">
        <label class="form-label" for="rl-code">{t(lang, 'auth.step2.codeLabel')}</label>
        <input
          id="rl-code"
          class="form-input"
          name="code"
          type="text"
          inputmode="numeric"
          autocomplete="one-time-code"
          maxlength="6"
          required
        />
      </div>
      <p class="form-error" data-rl-otp-error hidden></p>
      <Button type="submit" variant="primary" lang={lang} data-rl-submit>
        {t(lang, 'auth.step2.submit')}
      </Button>
      <Button type="button" variant="tertiary" lang={lang} data-rl-back-to-1>
        {t(lang, 'auth.step2.backLabel')}
      </Button>
    </form>

    <form data-rl-form="3" hidden novalidate>
      <div class="form-field" data-rl-ward-editable>
        <label class="form-label" for="rl-ward">{t(lang, 'auth.step3.wardLabel')}</label>
        <input id="rl-ward" class="form-input" name="wardId" type="number" />
      </div>
      <p class="form-field" data-rl-ward-readonly hidden>
        <span class="form-label">{t(lang, 'auth.step3.wardLabel')}</span>{' '}
        <span data-rl-ward-readonly-value></span>
      </p>
      <div class="form-field">
        <label class="form-label" for="rl-language">{t(lang, 'auth.step3.languageLabel')}</label>
        <select id="rl-language" class="form-input" name="language">
          <option value="en">{t(lang, 'auth.step3.languageOption.en')}</option>
          <option value="kn">{t(lang, 'auth.step3.languageOption.kn')}</option>
        </select>
      </div>
      <p class="rl-consent">
        {t(lang, 'auth.step3.consentSentence')}{' '}
        <a href={localePath(lang, '/terms')} target="_blank" rel="noopener noreferrer">
          {t(lang, 'auth.step3.termsLink')}
        </a>
        {' · '}
        <a href={localePath(lang, '/privacy')} target="_blank" rel="noopener noreferrer">
          {t(lang, 'auth.step3.privacyLink')}
        </a>
      </p>
      <label class="rl-checkbox">
        <input type="checkbox" name="futureTools" />
        {t(lang, 'auth.step3.futureTools')}
      </label>
      <Button type="submit" variant="primary" lang={lang} data-rl-submit>
        {t(lang, 'auth.step3.submit')}
      </Button>
    </form>
  </div>

  <span hidden data-msg-whatsapp-nudge>{t(lang, 'auth.step1.whatsappNudge')}</span>
  <span hidden data-msg-send-failed>{t(lang, 'auth.step1.sendFailed')}</span>
  <span hidden data-msg-error-invalid>{t(lang, 'auth.step2.error.invalid')}</span>
  <span hidden data-msg-error-expired>{t(lang, 'auth.step2.error.expired')}</span>
  <span hidden data-msg-error-locked>{t(lang, 'auth.step2.error.locked')}</span>
  <span hidden data-msg-code-expired-resend>{t(lang, 'auth.step3.codeExpired')}</span>
</dialog>

<style>
  .rl-modal {
    padding: 0;
    border: none;
    border-radius: var(--radius-md);
    box-shadow: var(--shadow-modal);
    max-width: 28rem;
    width: calc(100% - var(--space-8));
  }

  .rl-modal::backdrop {
    background: rgba(26, 26, 26, 0.5);
  }

  .rl-modal-inner {
    position: relative;
    padding: var(--space-6);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .rl-modal h2 {
    font-size: var(--text-2xl);
    line-height: var(--leading-2xl);
    margin: 0;
    padding-right: var(--space-8);
  }

  .rl-modal-close {
    position: absolute;
    top: var(--space-4);
    right: var(--space-4);
    min-width: 44px;
    min-height: 44px;
    background: transparent;
    border: none;
    font-size: var(--text-2xl);
    line-height: 1;
    cursor: pointer;
    color: var(--color-text);
  }

  .rl-modal form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .form-label {
    font-size: var(--text-sm);
    font-weight: 700;
  }

  .form-input {
    min-height: 44px;
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-base);
    font-family: var(--font-body);
    color: var(--color-text);
    background: var(--color-bg);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  .form-input:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-color: var(--color-primary);
  }

  .form-error {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-danger);
  }

  .rl-helper {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .rl-banner {
    margin: 0;
    padding: var(--space-2) var(--space-3);
    border-radius: var(--radius-md);
    background: var(--color-accent-surface);
    font-size: var(--text-sm);
  }

  .rl-consent {
    margin: 0;
    font-size: var(--text-sm);
  }

  .rl-checkbox {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
  }

  @media (max-width: 767px) {
    .rl-modal {
      position: fixed;
      top: auto;
      bottom: 0;
      left: 0;
      right: 0;
      max-width: 100%;
      width: 100%;
      margin: 0;
      border-radius: var(--radius-md) var(--radius-md) 0 0;
    }
  }
</style>

<script>
  import { initRegisterLoginModal } from '../islands/RegisterLoginModal';
  initRegisterLoginModal();
</script>
