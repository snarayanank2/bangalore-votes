---
/**
 * Badge — design-system.md §7.7, the RESERVED chip set (excluding
 * provenance, which SourceLine.astro owns). Radius-full, 13px, 4px/10px
 * padding. Exactly five variants exist; do not invent a sixth without a
 * design decision in design-system.md §7.7 first:
 *
 *   - flag-pending  : gray-600 on --gray-100     (a flagged correction awaits curator review)
 *   - flag-accepted : forest on --forest-tint    (curator accepted + published the correction)
 *   - flag-rejected : brick on --brick-tint      (curator reviewed and rejected it)
 *   - ward-ready    : white on solid --oc-forest (curator/admin: ward meets the publish bar)
 *   - ward-held     : ink on solid --oc-sun      (curator/admin: ward held — a work state, not an error)
 *
 * Default content is the variant's spec'd label (t()-resolved); the
 * default slot can override it for a caller that needs different wording
 * on the same visual treatment (the label vocabulary, not the color, is
 * what's free to vary).
 */
import { t, type Lang } from '../i18n';

export type BadgeVariant = 'flag-pending' | 'flag-accepted' | 'flag-rejected' | 'ward-ready' | 'ward-held';

interface Props {
  variant: BadgeVariant;
  lang: Lang;
}

const { variant, lang } = Astro.props;

const labelKeys: Record<BadgeVariant, string> = {
  'flag-pending': 'common.badge.flagPending',
  'flag-accepted': 'common.badge.flagAccepted',
  'flag-rejected': 'common.badge.flagRejected',
  'ward-ready': 'common.badge.wardReady',
  'ward-held': 'common.badge.wardHeld',
};

const defaultLabel = t(lang, labelKeys[variant]);
---

<span class={`badge-chip badge-chip--${variant}`}>
  <slot>{defaultLabel}</slot>
</span>

<style>
  .badge-chip {
    display: inline-block;
    padding: 4px 10px;
    border-radius: var(--radius-full);
    font-size: var(--text-xs);
    font-weight: 700;
  }

  .badge-chip--flag-pending {
    color: var(--color-text-muted);
    background: var(--color-surface);
  }

  .badge-chip--flag-accepted {
    color: var(--color-primary);
    background: var(--color-primary-surface);
  }

  .badge-chip--flag-rejected {
    color: var(--color-danger);
    background: var(--color-danger-surface);
  }

  .badge-chip--ward-ready {
    color: var(--color-on-primary);
    background: var(--color-primary);
  }

  .badge-chip--ward-held {
    color: var(--color-on-accent);
    background: var(--color-accent);
  }
</style>
