---
/**
 * SkipLink — design-system.md §10 (a11y floor): a "Skip to main content"
 * anchor to #main-content, visually hidden until it receives focus so
 * keyboard/screen-reader users can bypass the app bar without disrupting
 * mouse users.
 */
import { t, type Lang } from '../i18n';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;
---

<a class="skip-link" href="#main-content">{t(lang, 'a11y.skipToContent')}</a>

<style>
  .skip-link {
    position: absolute;
    top: 0;
    left: 0;
    z-index: 100;
    padding: var(--space-2) var(--space-4);
    background: var(--color-bg);
    color: var(--color-primary);
    border-radius: 0 0 var(--radius-sm) 0;
    transform: translateY(-100%);
    transition: transform 0.15s ease;
  }

  .skip-link:focus-visible {
    transform: translateY(0);
  }

  @media (prefers-reduced-motion: reduce) {
    .skip-link {
      transition: none;
    }
  }
</style>
