---
/**
 * Card — design-system.md §6.3/§7.5. White, 1px border, radius-md, 16px
 * padding. Elevation is border-first — no shadow.
 */
---

<div class="card">
  <slot />
</div>

<style>
  .card {
    background: var(--color-bg);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }
</style>
