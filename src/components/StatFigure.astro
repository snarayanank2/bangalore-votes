---
/**
 * StatFigure — a single labeled figure for `/data` and `/press`'s "current
 * key stats" (Task 51; PRD §5.14/§5.15). Renders as a `<dt>`/`<dd>` pair —
 * callers wrap one or more of these in a `<dl>` (a `<div>` wrapping a
 * `<dt>`+`<dd>` pair, as this component does, is valid HTML5 `<dl>`
 * content). The value renders in tabular figures so digits don't jitter,
 * same convention as IssueBars' rank/share numbers.
 */
interface Props {
  label: string;
  value: string | number;
}

const { label, value } = Astro.props;
---

<div class="stat-figure">
  <dt class="stat-label">{label}</dt>
  <dd class="stat-value">{value}</dd>
</div>

<style>
  .stat-figure {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    margin: 0;
  }

  .stat-label {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .stat-value {
    margin: 0;
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
  }
</style>
