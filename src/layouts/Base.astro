---
/**
 * Base layout — every public page renders through this. Emits the full
 * document shell: doctype/html/head (title, description, canonical,
 * hreflang alternates, OG tags, font preloads, global stylesheet) and a
 * body with the skip link, app bar, a `<main>` landmark for the page's own
 * content, and the footer.
 *
 * CACHE-SAFETY (architecture.md §5, binding on every page that uses this
 * layout): every server-generated absolute URL below (canonical, hreflang,
 * og:url, og:image) is derived from the fixed configured origin
 * (`Astro.site`, sourced from `SITE_ORIGIN` in astro.config.mjs) — NEVER
 * from the request's Host header. This layout also never reads
 * cookies/session, so the HTML it produces is identical for every
 * visitor and safe for nginx's anonymous-page micro-cache. The Sign-in
 * control (in AppBar) always renders the anonymous state; Task 28's
 * MeSlot island swaps it client-side for signed-in visitors.
 *
 * The Register/Login modal (Task 27, IA §7.1) is rendered ONCE here, on
 * every page, so it's always reachable from the AppBar's "Sign in" control
 * and from any ward page's "Register for updates" slot without each of
 * those pages needing to know about it. Its own markup/behavior are
 * self-contained (src/components/RegisterLoginModal.astro,
 * src/islands/RegisterLoginModal.ts); it never changes the server-rendered
 * HTML per visitor (the dialog always starts closed), so it doesn't affect
 * this layout's cache-safety.
 *
 * MeSlot (Task 28, src/islands/MeSlot.ts) is mounted ONCE here too, for the
 * same reason: every page has the app-bar Sign-in/Account slot, so every
 * page needs the island that personalizes it. It makes exactly ONE
 * `/api/me` call per page load and swaps that (and, where present, a ward
 * page's register-for-updates slot / vote-action hint) client-side — never
 * server-side, which is what keeps this layout's HTML cache-safe.
 *
 * The Flag misinformation modal (Task 32, IA §7.2) is rendered ONCE here
 * too, same rationale as Register/Login: any page that shows curator-
 * maintained data (Ward.astro, WardIssues.astro today; Candidate.astro in
 * Task 41) renders a "Flag an error" button carrying its own
 * `data-flag-action`/`data-ward-id`/`data-flag-targets`, and
 * src/islands/FlagModal.ts's `initFlagModal()` (this component's own
 * script) wires every such button on the page to this one dialog — no
 * per-page wiring script needed. Same cache-safety note as Register/Login:
 * self-contained markup/behavior, dialog always starts closed, never reads
 * cookies/session.
 *
 * The Cast issue vote modal (Task 33, IA §3.6/§7, PRD §5.5) is rendered
 * ONCE here too, same rationale again — WardIssues.astro's "Vote your top
 * 3" button carries its own `data-vote-action`/`data-ward-id`/
 * `data-vote-issues`, and src/islands/VoteModal.ts's `initVoteModal()`
 * (this component's own script) wires it to this one dialog. Same
 * cache-safety note: self-contained, dialog always starts closed, never
 * reads cookies/session.
 *
 * The `?src` attribution cookie writer (Task 49, architecture §5/§13, PRD
 * §5.12) is rendered ONCE here too, in `<head>`, on every page —
 * `src/lib/attribution.ts#ATTRIBUTION_SCRIPT_SOURCE`, one of exactly two
 * CSP-allowed nonce'd inline scripts (the other is GA, Task 62). The
 * server never reads `?src` or branches the page on it (the cache key
 * ignores the query string entirely); the script reads `location.search`
 * client-side and writes the `bv_src` cookie the registration endpoint
 * later reads. This is the one place this layout's markup embeds a
 * per-request value (`Astro.locals.cspNonce`, from `src/middleware.ts`) —
 * still cache-safe: nginx's microcache stores the whole response
 * (headers + body) as one unit, so a cached page's baked-in nonce always
 * matches that same cached response's CSP header.
 *
 * JSON-LD structured data (Task 56, architecture §8/§13) is rendered ONCE
 * here too, in `<head>`, from the optional `jsonLd` prop below. Each block
 * is a plain schema.org object a page already built from its own loaded
 * data (via `src/lib/seo.ts`'s builders) — this layout only serializes
 * (`jsonLd()` from `src/lib/seo`, which HTML-escapes `<`/`>`/`&` so a
 * curator/citizen-authored value can never break out of the `<script>`
 * tag) and nonces it, the same nonce as the `?src` writer above. Like that
 * script, this is page-specific but NOT session-specific data — never
 * built from a cookie/session read — so it stays cache-safe under nginx's
 * anonymous-page microcache the same way.
 *
 * The Google Analytics (gtag.js) snippet (Task 58, src/lib/analytics.ts) is
 * mounted ONCE here too, in `<head>`, gated to `!noindex && GA_MEASUREMENT_ID`
 * (env) — i.e. ONLY on public, indexable pages, and ONLY when a measurement
 * id is actually configured (unset in dev/test/CI, so this never perturbs
 * existing tests or the cache-safety byte-identical guard). That gate alone
 * excludes every authenticated screen: every `/account`, `/login`,
 * `/partner/*` page renders with `noindex={true}` (src/middleware.ts's
 * `NOINDEX_PREFIXES`), and `/curator`/`/admin` never render through Base at
 * all. Same cache-safety note as the `?src` writer: identical markup for
 * every visitor (only the nonce varies), never a session/cookie read here —
 * GA's own cookies are written client-side by gtag.js, never a server
 * `Set-Cookie`. See src/lib/analytics.ts's own docstring for the CSP note
 * (nginx, Task 62 — not yet built).
 */
import '../styles/global.css';
import SkipLink from '../components/SkipLink.astro';
import AppBar from '../components/AppBar.astro';
import Footer from '../components/Footer.astro';
import RegisterLoginModal from '../components/RegisterLoginModal.astro';
import FlagModal from '../components/FlagModal.astro';
import VoteModal from '../components/VoteModal.astro';
import { localePath, type Lang } from '../i18n';
import { ATTRIBUTION_SCRIPT_SOURCE } from '../lib/attribution';
import { gaLoaderSrc, gaConfigScriptSource } from '../lib/analytics';
import { jsonLd } from '../lib/seo';

interface Props {
  lang: Lang;
  title: string;
  description: string;
  /**
   * The page's root-relative, UNPREFIXED (English-canonical) route, e.g.
   * `/ward/57` — the same value for both the `/ward/57` and `/kn/ward/57`
   * variants of a page. Every language-specific URL below (canonical, the
   * two hreflang alternates, AppBar's toggle/logo/sign-in links, Footer's
   * links) is derived by passing this same `path` through
   * `localePath(lang, path)` — never pass an already-`/kn`-prefixed path.
   */
  path: string;
  ogImage?: string;
  noindex?: boolean;
  /**
   * Plain schema.org objects (from `src/lib/seo.ts`'s builders) this page
   * wants emitted as `<script type="application/ld+json">` tags in
   * `<head>` — e.g. `[personLd(candidate), breadcrumbLd(trail)]`. Each is
   * serialized via `jsonLd()` (never raw `JSON.stringify`) and rendered
   * with the same per-request CSP nonce as every other inline script on
   * this layout. Defaults to none.
   */
  jsonLd?: Record<string, unknown>[];
}

const { lang, title, description, path, ogImage, noindex = false, jsonLd: jsonLdBlocks = [] } = Astro.props;

// Astro.site is always configured (astro.config.mjs falls back to the
// production origin when SITE_ORIGIN is unset) — the local fallback here
// only satisfies strict typing (Astro.site: URL | undefined) and is never
// reached against the request's Host.
const siteOrigin = Astro.site ?? new URL('https://bangalore-votes.opencity.in');

const canonicalHref = new URL(localePath(lang, path), siteOrigin).href;
const enHref = new URL(localePath('en', path), siteOrigin).href;
const knHref = new URL(localePath('kn', path), siteOrigin).href;
const ogImageHref = ogImage ? new URL(ogImage, siteOrigin).href : undefined;
const ogLocale = lang === 'en' ? 'en_IN' : 'kn_IN';

// Per-request CSP nonce (architecture §13, src/middleware.ts) for the two
// allowed nonce'd inline scripts rendered below (the `?src` writer and, when
// shown, GA — Task 58; the CSP header itself that actually enforces this is
// nginx's, Task 62, not yet built). This does NOT break this layout's
// cache-safety: nginx's microcache
// stores the full response (headers + body) as one unit per the TTL window
// (architecture §5), so every visitor served from a given cache entry gets
// the SAME nonce in both the cached CSP header and this cached markup —
// they never need to match a freshly-generated value on a cache HIT.
const cspNonce = Astro.locals.cspNonce;

// GA (Task 58/62): public, indexable pages only, and only when a
// measurement id is actually configured — see the docstring above and
// src/lib/analytics.ts. Unset in dev/test/CI, so GA renders nothing there.
const gaMeasurementId = process.env.GA_MEASUREMENT_ID;
const showGa = !noindex && !!gaMeasurementId;
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <!--
      ?src attribution cookie writer (architecture §5/§13, PRD §5.12) —
      src/lib/attribution.ts. Runs first, in <head>, before any interaction.
      Reads location.search client-side ONLY; the server never branches on
      ?src, so this markup (aside from the nonce attribute itself, see
      cspNonce above) is identical for every visitor — the query-blind
      nginx cache is safe. One of exactly two CSP-allowed nonce'd inline
      scripts (the other is GA below, Task 58); no unsafe-inline.
    -->
    <script nonce={cspNonce} is:inline set:html={ATTRIBUTION_SCRIPT_SOURCE} />
    <title>{title}</title>
    <meta name="description" content={description} />
    {noindex && <meta name="robots" content="noindex" />}

    <link rel="canonical" href={canonicalHref} />
    <link rel="alternate" hreflang="en" href={enHref} />
    <link rel="alternate" hreflang="kn" href={knHref} />
    <link rel="alternate" hreflang="x-default" href={enHref} />

    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalHref} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content={ogLocale} />
    {ogImageHref && <meta property="og:image" content={ogImageHref} />}

    {
      lang === 'en' ? (
        <>
          <link
            rel="preload"
            as="font"
            type="font/woff2"
            href="/fonts/manrope-latin-wght-normal.woff2"
            crossorigin
          />
          <link
            rel="preload"
            as="font"
            type="font/woff2"
            href="/fonts/pt-sans-latin-400-normal.woff2"
            crossorigin
          />
        </>
      ) : (
        <link
          rel="preload"
          as="font"
          type="font/woff2"
          href="/fonts/noto-sans-kannada-kannada-wght-normal.woff2"
          crossorigin
        />
      )
    }

    {
      jsonLdBlocks.map((block) => (
        <script type="application/ld+json" nonce={cspNonce} is:inline set:html={jsonLd(block)} />
      ))
    }

    {
      showGa && (
        <>
          <script async is:inline nonce={cspNonce} src={gaLoaderSrc(gaMeasurementId!)} />
          <script nonce={cspNonce} is:inline set:html={gaConfigScriptSource(gaMeasurementId!)} />
        </>
      )
    }
  </head>
  <body>
    <SkipLink lang={lang} />
    <AppBar lang={lang} path={path} />
    <main id="main-content">
      <slot />
    </main>
    <Footer lang={lang} />
    <RegisterLoginModal lang={lang} />
    <FlagModal lang={lang} />
    <VoteModal lang={lang} />
    <script>
      import { initMeSlot } from '../islands/MeSlot';
      initMeSlot();
    </script>
  </body>
</html>
