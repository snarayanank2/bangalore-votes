---
/**
 * Home (`/`, `/kn/`) — information-architecture.md §3.1, PRD §5.1/§5.7.
 *
 * Renders through Base with the ward-search form as the centerpiece. The
 * form is a REAL `<form method="post">` — with JS disabled it POSTs back to
 * this same page and this file's `Astro.request.method === 'POST'` branch
 * below server-renders the result using the SAME resolution functions the
 * `/api/ward-lookup` endpoint uses (`lookupWardByAddress` / `wardsForPincode`
 * — imported directly, never fetched). With JS enabled, `src/islands/
 * WardLookup.ts` intercepts the submit and calls the API instead, painting
 * the result inline without a page reload.
 *
 * CACHE-SAFETY: the GET render below never reads cookies/session and reads
 * app_settings only (src/lib/settings.ts — safe under the anonymous-page
 * micro-cache, see that file's header). The POST branch is a per-request
 * geocode lookup and is explicitly marked `cache-control: no-store`; it
 * never touches the GET response.
 */
import { asc, eq, inArray } from 'drizzle-orm';
import Base from '../../layouts/Base.astro';
import Banner from '../../components/Banner.astro';
import DeadlineBanner from '../../components/DeadlineBanner.astro';
import Card from '../../components/Card.astro';
import FormField from '../../components/FormField.astro';
import Button from '../../components/Button.astro';
import { t, localePath, type Lang } from '../../i18n';
import { getSettings } from '../../lib/settings';
import { lookupWardByAddress } from '../../lib/geocode';
import { wardsForPincode } from '../../lib/pincode';
import { db } from '../../db/client';
import { wards } from '../../db/schema';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

type WardRow = { id: number; nameEn: string; nameKn: string; corporation: string };

type LookupResult =
  | { result: 'ward'; ward: WardRow }
  | { result: 'shortlist'; wards: WardRow[] }
  | { result: 'out_of_coverage' }
  | { result: 'use_pincode'; reason: 'ambiguous' | 'budget' | 'failed' };

const PINCODE_RE = /^\d{6}$/;

let postResult: LookupResult | null = null;

// No-JS fallback path (see file header). Only ever runs for a POST; the GET
// render below is unaffected and stays cacheable.
if (Astro.request.method === 'POST') {
  Astro.response.headers.set('cache-control', 'no-store');

  const form = await Astro.request.formData();
  const query = String(form.get('query') ?? '').trim();

  if (PINCODE_RE.test(query)) {
    const wardIds = wardsForPincode(query);
    if (wardIds.length === 0) {
      postResult = { result: 'out_of_coverage' };
    } else {
      const rows = await db.select().from(wards).where(inArray(wards.id, wardIds)).orderBy(asc(wards.id));
      postResult = { result: 'shortlist', wards: rows };
    }
  } else if (query.length > 0) {
    const lookup = await lookupWardByAddress(query);
    switch (lookup.kind) {
      case 'ward': {
        const [row] = await db.select().from(wards).where(eq(wards.id, lookup.wardId));
        postResult = row ? { result: 'ward', ward: row } : { result: 'use_pincode', reason: 'failed' };
        break;
      }
      case 'out_of_coverage':
        postResult = { result: 'out_of_coverage' };
        break;
      case 'ambiguous':
        postResult = { result: 'use_pincode', reason: 'ambiguous' };
        break;
      case 'budget_exhausted':
        postResult = { result: 'use_pincode', reason: 'budget' };
        break;
      case 'failed':
        postResult = { result: 'use_pincode', reason: 'failed' };
        break;
    }
  } else {
    // Defensive only — the input carries `required`, so an empty query
    // should never reach here from a real browser submit.
    postResult = { result: 'use_pincode', reason: 'failed' };
  }
}

const settings = await getSettings(['notification_date', 'election_date', 'roll_deadline']);
const notificationDate = settings.notification_date;
const electionDate = settings.election_date;
const rollDeadline = settings.roll_deadline;

const rollDeadlineActive = rollDeadline
  ? new Date(`${rollDeadline}T23:59:59Z`).getTime() >= Date.now()
  : false;

function wardHref(id: number): string {
  return localePath(lang, `/ward/${id}`);
}

function wardName(ward: WardRow): string {
  return lang === 'kn' ? ward.nameKn : ward.nameEn;
}
---

<Base
  lang={lang}
  title={t(lang, 'home.meta.title')}
  description={t(lang, 'home.meta.description')}
  path="/"
>
  <div class="home">
    <section class="hero">
      <h1>{t(lang, 'home.hero.heading')}</h1>
      <p class="subheading">{t(lang, 'home.hero.subheading')}</p>

      <form
        method="post"
        action={localePath(lang, '/')}
        class="ward-form"
        data-ward-lookup
        data-lang={lang}
        data-msg-shortlist-heading={t(lang, 'home.result.shortlistHeading')}
        data-msg-out-of-coverage={t(lang, 'home.result.outOfCoverage')}
        data-msg-use-pincode={t(lang, 'home.result.usePincode')}
      >
        <FormField
          label={t(lang, 'home.form.label')}
          name="query"
          type="text"
          helper={t(lang, 'home.form.helper')}
          required
          lang={lang}
        />
        <Button type="submit" variant="primary" lang={lang}>
          {t(lang, 'home.form.submit')}
        </Button>

        <div class="ward-result" data-ward-result aria-live="polite">
          {postResult?.result === 'ward' && (
            <p>
              <a href={wardHref(postResult.ward.id)}>{wardName(postResult.ward)}</a>
            </p>
          )}
          {postResult?.result === 'shortlist' && (
            <>
              <p>{t(lang, 'home.result.shortlistHeading')}</p>
              <ul>
                {postResult.wards.map((ward) => (
                  <li>
                    <a href={wardHref(ward.id)}>{wardName(ward)}</a>
                  </li>
                ))}
              </ul>
            </>
          )}
          {postResult?.result === 'out_of_coverage' && <p>{t(lang, 'home.result.outOfCoverage')}</p>}
          {postResult?.result === 'use_pincode' && <p>{t(lang, 'home.result.usePincode')}</p>}
        </div>
      </form>
    </section>

    <section class="election-status">
      {!notificationDate ? (
        <Banner kind="notice" lang={lang}>
          {t(lang, 'home.election.awaited')}
        </Banner>
      ) : (
        notificationDate &&
        electionDate && (
          <Banner kind="notice" lang={lang}>
            {t(lang, 'home.election.status', { notificationDate, electionDate })}
          </Banner>
        )
      )}

      {rollDeadlineActive && rollDeadline && <DeadlineBanner deadlineISO={rollDeadline} lang={lang} />}
    </section>

    <section class="shortcuts">
      <Card>
        <h2>{t(lang, 'home.shortcuts.checkRegistration.title')}</h2>
        <p>{t(lang, 'home.shortcuts.checkRegistration.description')}</p>
        <Button href={localePath(lang, '/check-registration')} variant="secondary" lang={lang}>
          {t(lang, 'home.shortcuts.checkRegistration.title')}
        </Button>
      </Card>
      <Card>
        <h2>{t(lang, 'home.shortcuts.votingGuide.title')}</h2>
        <p>{t(lang, 'home.shortcuts.votingGuide.description')}</p>
        <Button href={localePath(lang, '/voting-guide')} variant="secondary" lang={lang}>
          {t(lang, 'home.shortcuts.votingGuide.title')}
        </Button>
      </Card>
    </section>
  </div>

  <script>
    import { initWardLookup } from '../../islands/WardLookup';
    initWardLookup();
  </script>
</Base>

<style>
  .home {
    max-width: var(--container-app);
    margin-inline: auto;
    padding: var(--space-8) var(--container-pad-x);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .hero h1 {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    line-height: var(--leading-3xl);
    margin: 0 0 var(--space-2);
  }

  .subheading {
    color: var(--color-text-muted);
    margin: 0 0 var(--space-4);
  }

  .ward-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 32rem;
  }

  /* Only paint the surface once there's an actual result. The container is
     a permanent aria-live region, and Astro leaves an indentation-whitespace
     text node inside it when the SSR result slots render nothing — so it is
     never truly `:empty`. Key off an element child instead (renderResult in
     WardLookup.ts always `replaceChildren`s in a <p>/<ul>/<a>), which the
     stray whitespace node doesn't satisfy. */
  .ward-result:has(> *) {
    padding: var(--space-3) var(--space-4);
    background: var(--color-surface);
    border-radius: var(--radius-md);
  }

  .election-status {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .shortcuts {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(16rem, 1fr));
    gap: var(--space-4);
  }

  /* Shortcut-card contents (slotted into Card, so still in this component's
     scope). The card title sits a step below the hero h1 (text-xl vs
     text-3xl), and the heading/description/button get explicit vertical
     rhythm — Card itself is a bare container with no internal spacing. */
  .shortcuts h2 {
    font-size: var(--text-xl);
    line-height: var(--leading-xl);
    margin: 0 0 var(--space-2);
  }

  .shortcuts p {
    margin: 0 0 var(--space-4);
  }
</style>
