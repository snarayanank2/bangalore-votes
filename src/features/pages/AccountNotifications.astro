---
/**
 * `/account/notifications` (`/kn/account/notifications`) —
 * information-architecture.md §4.2, PRD §9.3: channel toggles ONLY (email
 * on/off, WhatsApp on/off) — there is deliberately no per-topic
 * subscription list here. See src/features/pages/Account.astro's header
 * comment for the split between this component (presentational) and
 * src/lib/account-flow.ts (state/mutation), called by the route twins
 * (src/pages/account/notifications.astro, src/pages/kn/account/notifications.astro).
 */
import Base from '../../layouts/Base.astro';
import Button from '../../components/Button.astro';
import Banner from '../../components/Banner.astro';
import { t, localePath, type Lang } from '../../i18n';
import { CSRF_FIELD_NAME } from '../../lib/csrf';
import type { AccountMessage } from '../../lib/account-flow';

interface Props {
  lang: Lang;
  csrfToken: string;
  emailEnabled: boolean;
  whatsappEnabled: boolean;
  message?: AccountMessage;
}

const { lang, csrfToken, emailEnabled, whatsappEnabled, message } = Astro.props;
const messageText = message ? t(lang, message.key) : undefined;
---

<Base
  lang={lang}
  title={t(lang, 'account.notifications.meta.title')}
  description={t(lang, 'account.notifications.meta.description')}
  path="/account/notifications"
  noindex={true}
>
  <div class="account-page">
    <h1>{t(lang, 'account.notifications.heading')}</h1>
    <p><a href={localePath(lang, '/account')}>{t(lang, 'account.nav.back')}</a></p>

    {
      messageText && (
        <Banner kind={message!.kind === 'error' ? 'error' : 'notice'} lang={lang}>
          {messageText}
        </Banner>
      )
    }

    <form method="post">
      <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
      <label class="checkbox">
        <input type="checkbox" name="emailEnabled" checked={emailEnabled} />
        {t(lang, 'account.notifications.emailLabel')}
      </label>
      <label class="checkbox">
        <input type="checkbox" name="whatsappEnabled" checked={whatsappEnabled} />
        {t(lang, 'account.notifications.whatsappLabel')}
      </label>
      <Button type="submit" variant="primary" lang={lang}>
        {t(lang, 'account.notifications.submit')}
      </Button>
    </form>
  </div>
</Base>

<style>
  .account-page {
    max-width: var(--container-prose);
    margin-inline: auto;
    padding-block: var(--space-8);
    padding-inline: var(--container-pad-x);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .account-page h1 {
    font-size: var(--text-2xl);
    line-height: var(--leading-2xl);
    margin: 0;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 24rem;
  }

  .checkbox {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-base);
  }
</style>
