---
/**
 * `/account/submissions` (`/kn/account/submissions`) —
 * information-architecture.md §4.3, PRD §6.2/§6.3: a read-only list of the
 * signed-in citizen's own flag submissions with each one's current
 * pending/accepted/rejected status and (once resolved) the resolution
 * reason. GET only — see src/lib/account-flow.ts's `loadSubmissions` for
 * the query.
 *
 * SHARED OUTCOME (PRD §6.3): a flag is deduped server-side into one
 * `flag_items` row per `(targetRef, status)` — two of THIS user's own
 * submissions against the same item (or, in principle, submissions from
 * different users collapsed into the same item) all read the SAME
 * status/resolutionReason, because they all join to the one shared parent
 * row. Nothing here needs to special-case that; it falls out of the join.
 */
import Base from '../../layouts/Base.astro';
import Badge from '../../components/Badge.astro';
import type { BadgeVariant } from '../../components/Badge.astro';
import { t, localePath, type Lang } from '../../i18n';
import type { SubmissionRow } from '../../lib/account-flow';

interface Props {
  lang: Lang;
  submissions: SubmissionRow[];
}

const { lang, submissions } = Astro.props;

const BADGE_VARIANT: Record<SubmissionRow['status'], BadgeVariant> = {
  pending: 'flag-pending',
  accepted: 'flag-accepted',
  rejected: 'flag-rejected',
};
---

<Base
  lang={lang}
  title={t(lang, 'account.submissions.meta.title')}
  description={t(lang, 'account.submissions.meta.description')}
  path="/account/submissions"
  noindex={true}
>
  <div class="account-page">
    <h1>{t(lang, 'account.submissions.heading')}</h1>
    <p><a href={localePath(lang, '/account')}>{t(lang, 'account.nav.back')}</a></p>

    {submissions.length === 0 && <p>{t(lang, 'account.submissions.empty')}</p>}

    {
      submissions.length > 0 && (
        <ul class="submissions-list">
          {submissions.map((submission) => (
            <li class="submission-card">
              <Badge variant={BADGE_VARIANT[submission.status]} lang={lang} />
              <p class="detail">{submission.detail}</p>
              {submission.status !== 'pending' && submission.resolutionReason && (
                <p class="reason">
                  {t(lang, 'account.submissions.reasonLabel')}: {submission.resolutionReason}
                </p>
              )}
            </li>
          ))}
        </ul>
      )
    }
  </div>
</Base>

<style>
  .account-page {
    max-width: var(--container-prose);
    margin-inline: auto;
    padding-block: var(--space-8);
    padding-inline: var(--container-pad-x);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .account-page h1 {
    font-size: var(--text-2xl);
    line-height: var(--leading-2xl);
    margin: 0;
  }

  .submissions-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .submission-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .detail {
    margin: 0;
  }

  .reason {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
</style>
