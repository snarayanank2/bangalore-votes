---
/**
 * `/curator/candidate/{id}` and `/curator/candidate/new?ward={id}` (Task 36,
 * information-architecture.md §5.4; PRD §5.2/§9.1/§11; architecture §6) — the
 * curator candidate editor. Every route twin
 * (src/pages/curator/candidate/[id].astro, .../new.astro) is responsible for
 * the 404/403 scope check BEFORE rendering this component — see those
 * files' docstrings and src/lib/curator.ts's module docstring for the same
 * convention used by the queue-item editor (Task 34).
 *
 * THREE INDEPENDENT FORMS, each its own `<form>` posting back to the same
 * URL with a distinct hidden `formAction` value (mirrors QueueItem.astro's
 * accept/reject split):
 *   - `formAction=core` — name/party/photo/status (or, on the `new` route,
 *     name/party/photo only — status is always the schema default there).
 *     A STATUS change clears the ward's sign-off (src/lib/publish.ts's
 *     `publishCandidateCore`) — a static warning sits next to the status
 *     select rather than a JS-conditional one, consistent with every other
 *     form on `/curator/*` being a plain no-JS server round trip.
 *   - `formAction=field:{fieldKey}`, one per report-card field
 *     (track_record/cases/assets/education/approachability) — SOURCE IS
 *     REQUIRED on every one of these (PRD §11): the source url field is
 *     marked `required` and the server re-validates regardless (see
 *     `handleCandidateFieldPublish`).
 *
 * AFFIDAVIT (Task 37, architecture §7/§13, PRD §5.2): TWO independent forms
 * (`formAction=affidavit`, disambiguated server-side by which of
 * `affidavitFile` / `ecUrl` is present) — an upload (curator picks a PDF
 * off disk) and an EC-link fetch (curator pastes the official EC affidavit
 * URL; src/lib/affidavit-fetch.ts does the SSRF-hardened fetch). Either
 * path lands the same way: `storeMedia(kind:'affidavit')`, a new
 * `candidate_affidavits` row, then AI extraction populates the three
 * extracted fields immediately (marked AI-extracted, cleared the moment a
 * curator re-confirms one — Task 5's rule, unchanged here). The stored
 * affidavit list shows each PDF's link, its source (uploaded vs. the EC URL
 * it came from), and its extraction status.
 *
 * NEWS LINKS (Task 38; PRD §5.2; architecture §7): a curator-add form
 * (`formAction=news_link_add`) plus, per link, either an "approved" badge
 * or — for a `suggested` link (auto-suggested, origin `'auto'`) — a
 * "suggested, not yet public" badge with its own approve form
 * (`formAction=news_link_approve`). SUGGESTED links render ONLY here, on
 * this curator-only editor — never on any public page (the data-level
 * guard lives in src/lib/news.ts's `listNewsLinks({ approvedOnly: true })`,
 * which the public report card — Task 42 — calls instead of the default,
 * ALL-links view this page uses).
 */
import CuratorLayout from '../../../layouts/CuratorLayout.astro';
import Card from '../../../components/Card.astro';
import Banner from '../../../components/Banner.astro';
import Button from '../../../components/Button.astro';
import FormField from '../../../components/FormField.astro';
import SourceLine from '../../../components/SourceLine.astro';
import { t, type Lang } from '../../../i18n';
import { CSRF_FIELD_NAME } from '../../../lib/csrf';
import { REPORT_CARD_FIELD_KEYS, type CandidateEditData, type ReportCardFieldKey } from '../../../lib/curator';
import type { NewsLink } from '../../../lib/news';

interface Props {
  lang: Lang;
  csrfToken: string;
  wardId: number;
  wardNameEn: string;
  wardNameKn: string;
  /** Present in EDIT mode (an existing candidate); absent on the `new` route. */
  candidate?: CandidateEditData;
  /** Present in EDIT mode — ALL of the candidate's links, suggested + approved (src/lib/news.ts's `listNewsLinks` default view). Absent on the `new` route (no candidate to hang links off of yet). */
  newsLinks?: NewsLink[];
  message?: { kind: 'notice' | 'error'; key: string };
}

const { lang, csrfToken, wardId, wardNameEn, wardNameKn, candidate, newsLinks, message } = Astro.props;
const isNew = candidate === undefined;
const wardName = lang === 'kn' ? wardNameKn : wardNameEn;
const messageText = message ? t(lang, message.key) : undefined;

const FIELD_LABEL_KEYS: Record<ReportCardFieldKey, string> = {
  track_record: 'curator.candidateEdit.field.trackRecord',
  cases: 'curator.candidateEdit.field.cases',
  assets: 'curator.candidateEdit.field.assets',
  education: 'curator.candidateEdit.field.education',
  approachability: 'curator.candidateEdit.field.approachability',
};

const pageHeading = isNew
  ? t(lang, 'curator.candidateEdit.new.heading', { ward: wardName })
  : t(lang, 'curator.candidateEdit.heading', { name: candidate!.nameEn });
const pageTitle = isNew ? t(lang, 'curator.candidateEdit.new.meta.title') : t(lang, 'curator.candidateEdit.meta.title');
const pageDescription = isNew
  ? t(lang, 'curator.candidateEdit.new.meta.description')
  : t(lang, 'curator.candidateEdit.meta.description');
const formTarget = isNew ? `/curator/candidate/new?ward=${wardId}` : `/curator/candidate/${candidate!.id}`;
---

<CuratorLayout lang={lang} title={pageTitle} description={pageDescription}>
  <div class="curator-page">
    <p><a href="/curator">{t(lang, 'curator.candidateEdit.backToDashboard')}</a></p>
    <h1>{pageHeading}</h1>
    <p class="ward-line">{t(lang, 'curator.candidateEdit.wardLine', { ward: wardName })}</p>

    {
      messageText && (
        <Banner kind={message!.kind === 'error' ? 'error' : 'notice'} lang={lang}>
          {messageText}
        </Banner>
      )
    }

    <Card>
      <h2>{t(lang, 'curator.candidateEdit.core.heading')}</h2>
      <form method="post" action={formTarget} enctype="multipart/form-data">
        <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
        <input type="hidden" name="formAction" value="core" />

        <FormField
          label={t(lang, 'curator.candidateEdit.core.nameEnLabel')}
          name="nameEn"
          required
          value={candidate?.nameEn}
          lang={lang}
        />
        <FormField
          label={t(lang, 'curator.candidateEdit.core.nameKnLabel')}
          name="nameKn"
          value={candidate?.nameKn ?? undefined}
          lang={lang}
        />
        <FormField
          label={t(lang, 'curator.candidateEdit.core.partyEnLabel')}
          name="partyEn"
          required
          value={candidate?.partyEn}
          lang={lang}
        />
        <FormField
          label={t(lang, 'curator.candidateEdit.core.partyKnLabel')}
          name="partyKn"
          value={candidate?.partyKn ?? undefined}
          lang={lang}
        />

        <div class="form-field">
          <label class="form-label" for="core-photo">
            {t(lang, 'curator.candidateEdit.core.photoLabel')}
          </label>
          {candidate?.photoUrl && (
            <p class="meta">
              {t(lang, 'curator.candidateEdit.core.photoCurrent')}{' '}
              <a href={candidate.photoUrl} target="_blank" rel="noopener noreferrer">
                {candidate.photoUrl}
              </a>
            </p>
          )}
          <input id="core-photo" class="form-input" type="file" name="photo" accept="image/png,image/jpeg,image/webp" />
        </div>

        {
          !isNew && (
            <div class="form-field">
              <label class="form-label" for="core-status">
                {t(lang, 'curator.candidateEdit.core.statusLabel')}
              </label>
              <select id="core-status" class="form-input" name="status">
                {(['filed', 'contesting', 'rejected', 'withdrawn'] as const).map((s) => (
                  <option value={s} selected={candidate!.status === s}>
                    {t(lang, `curator.candidateEdit.core.status.${s}`)}
                  </option>
                ))}
              </select>
              <p class="form-helper">{t(lang, 'curator.candidateEdit.core.statusWarning')}</p>
            </div>
          )
        }

        <Button type="submit" variant="primary" lang={lang}>
          {isNew ? t(lang, 'curator.candidateEdit.core.createSubmit') : t(lang, 'curator.candidateEdit.core.submit')}
        </Button>
      </form>
    </Card>

    {
      !isNew && (
        <Card>
          <h2>{t(lang, 'curator.candidateEdit.fields.heading')}</h2>
          <div class="field-cards">
            {REPORT_CARD_FIELD_KEYS.map((key) => {
              const field = candidate!.fields[key];
              return (
                <div class="field-card">
                  <h3>{t(lang, FIELD_LABEL_KEYS[key])}</h3>
                  <SourceLine sourceType={field.sourceType} sourceUrl={field.sourceUrl} lang={lang} />
                  <form method="post" action={formTarget}>
                    <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
                    <input type="hidden" name="formAction" value={`field:${key}`} />
                    <div class="form-field">
                      <label class="form-label" for={`field-${key}-valueEn`}>
                        {t(lang, 'curator.candidateEdit.field.valueEnLabel')}
                      </label>
                      <textarea id={`field-${key}-valueEn`} class="form-input" name="valueEn" rows={2}>
                        {field.valueEn ?? ''}
                      </textarea>
                    </div>
                    <div class="form-field">
                      <label class="form-label" for={`field-${key}-valueKn`}>
                        {t(lang, 'curator.candidateEdit.field.valueKnLabel')}
                      </label>
                      <textarea id={`field-${key}-valueKn`} class="form-input" name="valueKn" rows={2}>
                        {field.valueKn ?? ''}
                      </textarea>
                    </div>
                    <label class="checkbox">
                      <input type="checkbox" name="notDeclared" checked={field.notDeclared} />
                      {t(lang, 'curator.queueItem.accept.notDeclaredLabel')}
                    </label>
                    <FormField
                      label={t(lang, 'curator.queueItem.accept.sourceUrlLabel')}
                      name="sourceUrl"
                      type="text"
                      required
                      value={field.sourceUrl ?? undefined}
                      lang={lang}
                    />
                    <div class="form-field">
                      <label class="form-label" for={`field-${key}-sourceType`}>
                        {t(lang, 'curator.queueItem.accept.sourceTypeLabel')}
                      </label>
                      <select id={`field-${key}-sourceType`} class="form-input" name="sourceType">
                        <option value="curator" selected={field.sourceType === 'curator'}>
                          {t(lang, 'curator.queueItem.accept.sourceType.curator')}
                        </option>
                        <option value="official" selected={field.sourceType === 'official'}>
                          {t(lang, 'curator.queueItem.accept.sourceType.official')}
                        </option>
                      </select>
                    </div>
                    <div class="form-field">
                      <label class="form-label" for={`field-${key}-authoredLang`}>
                        {t(lang, 'curator.queueItem.accept.authoredLangLabel')}
                      </label>
                      <select id={`field-${key}-authoredLang`} class="form-input" name="authoredLang">
                        <option value="en" selected={field.authoredLang === 'en'}>
                          {t(lang, 'curator.queueItem.accept.authoredLang.en')}
                        </option>
                        <option value="kn" selected={field.authoredLang === 'kn'}>
                          {t(lang, 'curator.queueItem.accept.authoredLang.kn')}
                        </option>
                      </select>
                    </div>
                    <Button type="submit" variant="secondary" lang={lang}>
                      {t(lang, 'curator.candidateEdit.field.submit')}
                    </Button>
                  </form>
                </div>
              );
            })}
          </div>
        </Card>
      )
    }

    {
      !isNew && (
        <Card>
          <h2>{t(lang, 'curator.candidateEdit.affidavit.heading')}</h2>

          <h3>{t(lang, 'curator.candidateEdit.affidavit.existingHeading')}</h3>
          {candidate!.affidavits.length === 0 ? (
            <p class="placeholder-note">{t(lang, 'curator.candidateEdit.affidavit.noneYet')}</p>
          ) : (
            <ul class="affidavit-list">
              {candidate!.affidavits.map((a) => (
                <li class="affidavit-item">
                  <a href={a.mediaUrl} target="_blank" rel="noopener noreferrer">
                    {t(lang, 'curator.candidateEdit.affidavit.viewPdf')}
                  </a>
                  <span class="meta">
                    {a.originUrl
                      ? `${t(lang, 'curator.candidateEdit.affidavit.sourceEcLink')} ${a.originUrl}`
                      : t(lang, 'curator.candidateEdit.affidavit.sourceUpload')}
                  </span>
                  <span class={`status-badge status-${a.extractionStatus}`}>
                    {t(lang, `curator.candidateEdit.affidavit.status.${a.extractionStatus}`)}
                  </span>
                </li>
              ))}
            </ul>
          )}

          <h3>{t(lang, 'curator.candidateEdit.affidavit.uploadHeading')}</h3>
          <form method="post" action={formTarget} enctype="multipart/form-data">
            <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
            <input type="hidden" name="formAction" value="affidavit" />
            <div class="form-field">
              <label class="form-label" for="affidavit-file">
                {t(lang, 'curator.candidateEdit.affidavit.uploadLabel')}
              </label>
              <input id="affidavit-file" class="form-input" type="file" name="affidavitFile" accept="application/pdf" />
            </div>
            <Button type="submit" variant="secondary" lang={lang}>
              {t(lang, 'curator.candidateEdit.affidavit.uploadSubmit')}
            </Button>
          </form>

          <h3>{t(lang, 'curator.candidateEdit.affidavit.ecUrlHeading')}</h3>
          <form method="post" action={formTarget}>
            <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
            <input type="hidden" name="formAction" value="affidavit" />
            <FormField
              label={t(lang, 'curator.candidateEdit.affidavit.ecUrlLabel')}
              name="ecUrl"
              type="text"
              helper={t(lang, 'curator.candidateEdit.affidavit.ecUrlHelper')}
              lang={lang}
            />
            <Button type="submit" variant="secondary" lang={lang}>
              {t(lang, 'curator.candidateEdit.affidavit.ecUrlSubmit')}
            </Button>
          </form>
        </Card>
      )
    }

    {
      !isNew && (
        <Card>
          <h2>{t(lang, 'curator.candidateEdit.newsLinks.heading')}</h2>

          <h3>{t(lang, 'curator.candidateEdit.newsLinks.existingHeading')}</h3>
          {newsLinks && newsLinks.length > 0 ? (
            <ul class="news-link-list">
              {newsLinks.map((link) => (
                <li class="news-link-item">
                  <div class="news-link-main">
                    <a href={link.url} target="_blank" rel="noopener noreferrer">
                      {link.title}
                    </a>
                    <span class="meta">{link.domain}</span>
                    <span class={`status-badge ${link.status === 'approved' ? 'status-approved' : 'status-suggested'}`}>
                      {t(
                        lang,
                        link.status === 'approved'
                          ? 'curator.candidateEdit.newsLinks.approvedBadge'
                          : 'curator.candidateEdit.newsLinks.suggestedBadge',
                      )}
                    </span>
                  </div>
                  {link.status === 'suggested' && (
                    <form method="post" action={formTarget}>
                      <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
                      <input type="hidden" name="formAction" value="news_link_approve" />
                      <input type="hidden" name="linkId" value={link.id} />
                      <Button type="submit" variant="secondary" lang={lang}>
                        {t(lang, 'curator.candidateEdit.newsLinks.approveSubmit')}
                      </Button>
                    </form>
                  )}
                </li>
              ))}
            </ul>
          ) : (
            <p class="placeholder-note">{t(lang, 'curator.candidateEdit.newsLinks.noneYet')}</p>
          )}

          <h3>{t(lang, 'curator.candidateEdit.newsLinks.addHeading')}</h3>
          <form method="post" action={formTarget}>
            <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
            <input type="hidden" name="formAction" value="news_link_add" />
            <FormField label={t(lang, 'curator.candidateEdit.newsLinks.urlLabel')} name="url" type="text" required lang={lang} />
            <FormField label={t(lang, 'curator.candidateEdit.newsLinks.titleLabel')} name="title" type="text" required lang={lang} />
            <Button type="submit" variant="secondary" lang={lang}>
              {t(lang, 'curator.candidateEdit.newsLinks.addSubmit')}
            </Button>
          </form>
        </Card>
      )
    }
  </div>
</CuratorLayout>

<style>
  .curator-page {
    max-width: var(--container-prose);
    margin-inline: auto;
    padding-block: var(--space-8);
    padding-inline: var(--container-pad-x);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .curator-page h1 {
    font-size: var(--text-2xl);
    line-height: var(--leading-2xl);
    margin: 0;
  }

  .curator-page h2 {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-3);
  }

  .curator-page h3 {
    font-size: var(--text-base);
    margin: 0 0 var(--space-1);
  }

  .ward-line {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .meta {
    margin: 0 0 var(--space-1);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 32rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .form-label {
    font-size: var(--text-sm);
    font-weight: 700;
  }

  .form-helper {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .form-input {
    min-height: 44px;
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-base);
    font-family: var(--font-body);
    color: var(--color-text);
    background: var(--color-bg);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  textarea.form-input {
    min-height: 5.5rem;
    resize: vertical;
  }

  .checkbox {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-base);
  }

  .field-cards {
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .field-card {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
  }

  .placeholder-note {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-style: italic;
  }

  .affidavit-list {
    list-style: none;
    margin: 0 0 var(--space-4);
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .affidavit-item {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-border);
    font-size: var(--text-sm);
  }

  .status-badge {
    padding: 0 var(--space-2);
    border-radius: var(--radius-sm);
    font-size: var(--text-sm);
    background: var(--color-surface);
    color: var(--color-text-muted);
  }

  .status-badge.status-failed {
    background: var(--color-danger-surface);
    color: var(--color-danger);
  }

  .status-badge.status-approved {
    background: var(--color-primary-surface);
    color: var(--color-primary);
  }

  .status-badge.status-suggested {
    background: var(--color-accent-surface);
    color: var(--color-on-accent);
  }

  .news-link-list {
    list-style: none;
    margin: 0 0 var(--space-4);
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .news-link-item {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: var(--space-2);
    padding: var(--space-2) 0;
    border-bottom: 1px solid var(--color-border);
    font-size: var(--text-sm);
  }

  .news-link-main {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: var(--space-2);
  }
</style>
