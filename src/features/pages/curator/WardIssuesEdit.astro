---
/**
 * `/curator/ward/{id}/issues` (Task 39; PRD §5.4/§5.5) — the ward-issues
 * editor: the ward's current issue list (position order), an add form, and
 * per-issue rename/remove forms. See src/lib/ward-issues.ts for the
 * add/rename/remove semantics (rename keeps the id — and every citizen
 * vote referencing it — intact; remove cascades its OWN vote selections
 * away while every other selection in the same vote set stands).
 *
 * THREE INDEPENDENT FORMS per the same convention as CandidateEdit.astro
 * (hidden `formAction`, one `<form>` per action): `add`, `rename:{issueId}`,
 * `remove:{issueId}`. The remove form carries a REQUIRED confirmation
 * checkbox (design-system.md §7.13: destructive actions get a confirmation
 * stating scope) — removing an issue drops it from every citizen's vote
 * set; their OTHER selections are unaffected, and the confirmation copy
 * says so.
 */
import CuratorLayout from '../../../layouts/CuratorLayout.astro';
import Card from '../../../components/Card.astro';
import Banner from '../../../components/Banner.astro';
import Button from '../../../components/Button.astro';
import FormField from '../../../components/FormField.astro';
import { t, type Lang } from '../../../i18n';
import { CSRF_FIELD_NAME } from '../../../lib/csrf';
import type { WardIssueRow } from '../../../lib/ward-issues';

interface Props {
  lang: Lang;
  csrfToken: string;
  wardId: number;
  wardNameEn: string;
  wardNameKn: string;
  issues: WardIssueRow[];
  message?: { kind: 'notice' | 'error'; key: string };
}

const { lang, csrfToken, wardId, wardNameEn, wardNameKn, issues, message } = Astro.props;
const wardName = lang === 'kn' ? wardNameKn : wardNameEn;
const messageText = message ? t(lang, message.key) : undefined;
const formTarget = `/curator/ward/${wardId}/issues`;
---

<CuratorLayout lang={lang} title={t(lang, 'curator.wardIssuesEdit.meta.title')} description={t(lang, 'curator.wardIssuesEdit.meta.description')}>
  <div class="curator-page">
    <p><a href={`/curator/ward/${wardId}`}>{t(lang, 'curator.wardIssuesEdit.backToWard')}</a></p>
    <h1>{t(lang, 'curator.wardIssuesEdit.heading', { ward: wardName })}</h1>

    {
      messageText && (
        <Banner kind={message!.kind === 'error' ? 'error' : 'notice'} lang={lang}>
          {messageText}
        </Banner>
      )
    }

    <Card>
      <h2>{t(lang, 'curator.wardIssuesEdit.list.heading')}</h2>
      {
        issues.length === 0 ? (
          <p class="placeholder-note">{t(lang, 'curator.wardIssuesEdit.list.empty')}</p>
        ) : (
          <ul class="issue-list">
            {issues.map((issue) => (
              <li class="issue-row">
                <p class="issue-title">{issue.titleEn}</p>

                <form method="post" action={formTarget} class="rename-form">
                  <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
                  <input type="hidden" name="formAction" value={`rename:${issue.id}`} />
                  <FormField
                    label={t(lang, 'curator.wardIssuesEdit.rename.titleLabel')}
                    name="titleEn"
                    required
                    value={issue.titleEn ?? undefined}
                    lang={lang}
                  />
                  <Button type="submit" variant="secondary" lang={lang}>
                    {t(lang, 'curator.wardIssuesEdit.rename.submit')}
                  </Button>
                </form>

                <form method="post" action={formTarget} class="remove-form">
                  <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
                  <input type="hidden" name="formAction" value={`remove:${issue.id}`} />
                  <label class="checkbox">
                    <input type="checkbox" name="confirmRemove" required />
                    {t(lang, 'curator.wardIssuesEdit.remove.confirmLabel')}
                  </label>
                  <Button type="submit" variant="destructive" lang={lang}>
                    {t(lang, 'curator.wardIssuesEdit.remove.submit')}
                  </Button>
                </form>
              </li>
            ))}
          </ul>
        )
      }
    </Card>

    <Card>
      <h2>{t(lang, 'curator.wardIssuesEdit.add.heading')}</h2>
      <form method="post" action={formTarget}>
        <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
        <input type="hidden" name="formAction" value="add" />
        <FormField label={t(lang, 'curator.wardIssuesEdit.add.titleLabel')} name="titleEn" required lang={lang} />
        <Button type="submit" variant="primary" lang={lang}>
          {t(lang, 'curator.wardIssuesEdit.add.submit')}
        </Button>
      </form>
    </Card>
  </div>
</CuratorLayout>

<style>
  .curator-page {
    max-width: var(--container-prose);
    margin-inline: auto;
    padding-block: var(--space-8);
    padding-inline: var(--container-pad-x);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .curator-page h1 {
    font-size: var(--text-2xl);
    line-height: var(--leading-2xl);
    margin: 0;
  }

  .curator-page h2 {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-3);
  }

  .placeholder-note {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-style: italic;
  }

  .issue-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .issue-row {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .issue-title {
    margin: 0;
    font-weight: 700;
  }

  form {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    max-width: 28rem;
  }

  .checkbox {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
  }
</style>
