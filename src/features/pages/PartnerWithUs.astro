---
/**
 * Partner with us (`/partner-with-us`, `/kn/partner-with-us`) — Task 50, IA
 * §3.15, PRD §5.13. Renders the Task 8 editorial content (the two paths —
 * spread awareness / curate data — their time commitment and the
 * neutrality/vetting expectation) followed by the ONE anonymous
 * expression-of-interest form covering BOTH paths (a path selector, not two
 * separate forms).
 *
 * ANONYMOUS — NO ACCOUNT REQUIRED (core concept #2's usual "gated at
 * submit" rule does NOT apply here: this is deliberately open to
 * institutions like RWAs that don't map onto an individual citizen login,
 * IA §3.15/PRD §5.13). The form posts straight to `POST /api/eoi`
 * (src/pages/api/eoi.ts) with no session at all — the ONE anonymous write
 * this platform has (architecture.md §7). "Applications ≠ access" (PRD
 * §5.13): submitting never grants a partner slug or curator scope by
 * itself — an admin triages every submission at `/admin/partners`
 * (src/lib/partners.ts's `listEois`/`acceptEoiAwareness`/`acceptEoiCuration`
 * /`declineEoi`, Task 46).
 *
 * RECAPTCHA V3 LOADS ONLY ON THIS PAGE (architecture.md §7/§13): the
 * external `<script src="https://www.google.com/recaptcha/api.js?render=…">`
 * below is emitted ONLY when `RECAPTCHA_SITE_KEY` is configured, and ONLY
 * from this component — no other page in this codebase emits a
 * google.com/recaptcha script tag. The corresponding CSP relaxation
 * (allowing www.google.com/www.gstatic.com as script/frame hosts) is an
 * nginx per-location header, Task 63's concern, not this component's.
 * `RECAPTCHA_SITE_KEY` is ABSENT in this repo's dev/CI env (Task 50
 * brief) — the form still renders and still submits without it (see
 * src/islands/EoiForm.ts's module docstring for the empty-token path);
 * production MUST configure both `RECAPTCHA_SITE_KEY` (here) and
 * `RECAPTCHA_SECRET_KEY` (src/lib/recaptcha.ts) for real bot protection.
 *
 * NO-JS: this form requires JS (reCAPTCHA v3 has no non-JS mode) — see
 * src/islands/EoiForm.ts's module docstring for why that's an acceptable
 * tradeoff for this specific, low-frequency, deliberate action (unlike the
 * ward finder, which must keep working with JS disabled). The `<form>`
 * below deliberately has no `action`/`method`, so a no-JS submit is a
 * harmless same-page GET re-render rather than a raw POST straight at the
 * JSON API.
 *
 * CACHE-SAFETY (architecture.md §5): this component reads only repo content
 * + `process.env.RECAPTCHA_SITE_KEY` (a fixed deployment-wide value, same
 * for every visitor) — no cookie/session access, safe under the
 * anonymous-page micro-cache. `RECAPTCHA_SITE_KEY` is a PUBLIC key, meant to
 * be embedded in client-side markup (unlike `RECAPTCHA_SECRET_KEY`, which
 * never leaves the server).
 */
import Prose from '../../layouts/Prose.astro';
import Card from '../../components/Card.astro';
import FormField from '../../components/FormField.astro';
import Button from '../../components/Button.astro';
import { t, type Lang } from '../../i18n';
import { getPageContent } from '../../i18n/content';
import { renderContentHtml } from '../../lib/render-content';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const content = getPageContent(lang, 'partner-with-us');
if (!content) {
  throw new Error('PartnerWithUs: missing content/pages/en/partner-with-us.md');
}

const recaptchaSiteKey = process.env.RECAPTCHA_SITE_KEY ?? '';
---

<Prose lang={lang} title={content.title} description={content.description} path="/partner-with-us">
  <div set:html={renderContentHtml(content.body, lang)} />

  <Card>
    <form data-eoi-form novalidate data-recaptcha-site-key={recaptchaSiteKey}>
      <h2>{t(lang, 'partnerWithUs.form.heading')}</h2>

      <div class="form-field">
        <label class="form-label" for="eoi-path">
          {t(lang, 'partnerWithUs.form.pathLabel')}
        </label>
        <select id="eoi-path" class="form-input" name="path" required>
          <option value="awareness">{t(lang, 'partnerWithUs.form.path.awareness')}</option>
          <option value="curation">{t(lang, 'partnerWithUs.form.path.curation')}</option>
        </select>
      </div>

      <FormField label={t(lang, 'partnerWithUs.form.nameLabel')} name="name" type="text" required lang={lang} />

      <FormField
        label={t(lang, 'partnerWithUs.form.organisationLabel')}
        name="organisation"
        type="text"
        lang={lang}
      />

      <FormField
        label={t(lang, 'partnerWithUs.form.contactLabel')}
        name="contact"
        type="text"
        required
        helper={t(lang, 'partnerWithUs.form.contactHelper')}
        lang={lang}
      />

      <div class="form-field">
        <label class="form-label" for="eoi-wardsText">
          {t(lang, 'partnerWithUs.form.wardsTextLabel')}
        </label>
        <textarea id="eoi-wardsText" class="form-input" name="wardsText" rows="2"></textarea>
        <p class="form-helper">{t(lang, 'partnerWithUs.form.wardsTextHelper')}</p>
      </div>

      <div class="form-field">
        <label class="form-label" for="eoi-message">
          {t(lang, 'partnerWithUs.form.messageLabel')}
        </label>
        <textarea id="eoi-message" class="form-input" name="message" rows="3"></textarea>
      </div>

      <Button type="submit" variant="primary" lang={lang} data-eoi-submit>
        {t(lang, 'partnerWithUs.form.submit')}
      </Button>

      <p class="eoi-success" role="status" aria-live="polite" data-eoi-success hidden></p>
      <p class="eoi-error" role="alert" data-eoi-error hidden></p>

      <span hidden data-msg-generic-error>{t(lang, 'partnerWithUs.form.error.generic')}</span>
      <span hidden data-msg-recaptcha-failed>{t(lang, 'partnerWithUs.form.error.recaptcha')}</span>
      <span hidden data-msg-invalid>{t(lang, 'partnerWithUs.form.error.invalid')}</span>
      <span hidden data-msg-success>{t(lang, 'partnerWithUs.form.success')}</span>
    </form>
  </Card>

  {
    recaptchaSiteKey && (
      <script
        src={`https://www.google.com/recaptcha/api.js?render=${encodeURIComponent(recaptchaSiteKey)}`}
        is:inline
      />
    )
  }

  <script>
    import { initEoiForm } from '../../islands/EoiForm';
    initEoiForm();
  </script>
</Prose>

<style>
  .form-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    margin-block-end: var(--space-4);
  }

  .form-label {
    font-size: var(--text-sm);
    color: var(--color-text);
    font-weight: 700;
  }

  .form-input {
    min-height: 44px;
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-base);
    font-family: var(--font-body);
    color: var(--color-text);
    background: var(--color-bg);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  textarea.form-input {
    resize: vertical;
  }

  .form-helper {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .eoi-success {
    margin: var(--space-4) 0 0;
    color: var(--color-primary);
    font-weight: 700;
  }

  .eoi-error {
    margin: var(--space-4) 0 0;
    color: var(--color-danger);
    font-weight: 700;
  }
</style>
