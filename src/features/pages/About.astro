---
/**
 * About this platform (`/about`, `/kn/about`) — information-architecture.md
 * §3.13, PRD §5.11.
 *
 * Renders the Task 8 `about` content entry inside Prose — operator
 * (Oorvani Foundation), funding-disclosure structure, data-sourcing/
 * neutrality commitments (all in the content itself; INPUT NEEDED markers
 * are stripped by renderContentHtml, never reaching the visitor).
 *
 * ADDITIONALLY emits the platform `Organization` JSON-LD (architecture.md
 * §8) via `src/lib/seo.ts#orgLd` — the shared builder every page type's
 * JSON-LD now goes through (Task 56), passed to Base.astro's `jsonLd` prop
 * (via Prose.astro, which forwards it). This replaces the small ad-hoc
 * inline builder this page used to carry itself before Task 56 centralized
 * JSON-LD construction/serialization.
 *
 * CACHE-SAFETY: only reads repo content + `orgLd()` (a static builder with
 * no per-request input) — no cookie/session access, safe under the
 * anonymous-page micro-cache.
 */
import Prose from '../../layouts/Prose.astro';
import { type Lang } from '../../i18n';
import { getPageContent } from '../../i18n/content';
import { renderContentHtml } from '../../lib/render-content';
import { orgLd } from '../../lib/seo';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const content = getPageContent(lang, 'about');
if (!content) {
  throw new Error('About: missing content/pages/en/about.md');
}
---

<Prose lang={lang} title={content.title} description={content.description} path="/about" jsonLd={[orgLd()]}>
  <div set:html={renderContentHtml(content.body, lang)} />
</Prose>
