---
/**
 * About this platform (`/about`, `/kn/about`) — information-architecture.md
 * §3.13, PRD §5.11.
 *
 * Renders the Task 8 `about` content entry inside Prose — operator
 * (Oorvani Foundation), funding-disclosure structure, data-sourcing/
 * neutrality commitments (all in the content itself; INPUT NEEDED markers
 * are stripped by renderContentHtml, never reaching the visitor).
 *
 * ADDITIONALLY emits `Organization` JSON-LD (architecture.md §8) for the
 * Oorvani Foundation, the operator this page names. Task 56 will centralize
 * JSON-LD construction/serialization across every page type (Person, Place,
 * Event, FAQPage, Organization, BreadcrumbList) into a shared `seo.ts`
 * helper — this inlines a small, correct one now rather than block on that
 * task; swap this block for the shared helper when Task 56 lands.
 *
 * SECURITY (architecture.md §13): JSON-LD is serialized with `<` escaped to
 * `<` so no embedded substring can prematurely close the `<script>`
 * tag. Every value below is a static, repo-known string (organization
 * name/description), not curator or user input, so the actual risk here is
 * low — but the escape is applied unconditionally anyway, so this snippet
 * stays correct as a template even if a future edit feeds it dynamic data.
 *
 * CACHE-SAFETY: only reads repo content + Astro.site (the fixed configured
 * origin, never the request Host) — no cookie/session access, safe under
 * the anonymous-page micro-cache.
 */
import Prose from '../../layouts/Prose.astro';
import { type Lang } from '../../i18n';
import { getPageContent } from '../../i18n/content';
import { renderContentHtml } from '../../lib/render-content';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const content = getPageContent(lang, 'about');
if (!content) {
  throw new Error('About: missing content/pages/en/about.md');
}

const siteOrigin = Astro.site ?? new URL('https://bangalore-votes.opencity.in');

const organizationJsonLd = JSON.stringify({
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: 'Oorvani Foundation',
  url: siteOrigin.href,
  description:
    'The Oorvani Foundation operates Bangalore Votes, a neutral, non-partisan citizen information platform for the GBA ward corporator elections in Bengaluru.',
}).replace(/</g, '\\u003c');
---

<Prose lang={lang} title={content.title} description={content.description} path="/about">
  <script type="application/ld+json" set:html={organizationJsonLd} is:inline />
  <div set:html={renderContentHtml(content.body, lang)} />
</Prose>
