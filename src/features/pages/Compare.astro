---
/**
 * Candidate comparison (`/ward/{id}/compare`, `/kn/ward/{id}/compare`) —
 * information-architecture.md §3.5, PRD §5.3, design-system §5.5/§4. Every
 * FILED/CONTESTING candidate in the ward, side by side in a COLUMN layout
 * (not a scrolling feed) — same field rows as the report card so values
 * line up across candidates.
 *
 * Existence check lives in the route twins (src/pages/ward/[id]/compare.astro,
 * src/pages/kn/ward/[id]/compare.astro), not here — same pattern as
 * Ward.astro/WardCandidates.astro; see Ward.astro's header comment for the
 * full rationale. The `ward` lookup below is guarded defensively anyway.
 *
 * FILED/CONTESTING ONLY (PRD §5.3, load-bearing): withdrawn and
 * scrutiny-rejected candidates are EXCLUDED from this view entirely (unlike
 * the candidates-in-ward list, Task 42, which shows every status) — their
 * report-card URL still resolves elsewhere, but they never occupy a column
 * here. This mirrors src/lib/readiness.ts's `ACTIVE_CANDIDATE_STATUSES`
 * ('filed'/'contesting') and PRD §9.1's completeness check, kept as its own
 * small local copy here (same convention src/lib/news.ts's `isHttpUrl`
 * duplicate documents) rather than exporting a shared constant this task
 * wasn't asked to create.
 *
 * ORDERING (design-system §4.3, LOAD-BEARING): ALPHABETICAL by `nameEn` —
 * the same stable, language-independent sort key WardCandidates.astro uses
 * — NEVER ranked by any editorial measure. `id` is only a tiebreak for two
 * candidates that happen to share an identical nameEn.
 *
 * LAYOUT (design-system §5.5, PRD §5.3): a real `<table>` inside a
 * `.compare-scroll` (`overflow-x: auto`) container. The field-label column
 * is the table's own header column (`scope="row"`, class `sticky-col` ->
 * `position: sticky; left: 0`) so it stays visible while the candidate
 * columns scroll horizontally. Candidate columns default to a ~45vw width
 * (2-up on mobile, horizontal scroll for the rest — NO hard cap on
 * candidate count, PRD §5.3) and widen at `--bp-lg` (1024px, design-system
 * §2 "Desktop; compare grid widens") so more columns fit without scrolling.
 * PURE CSS — no island/JS drives the scroll or the sticky column.
 *
 * FIELD SET (PRD §5.3 "same fields as the report card so rows line up"):
 * the five REPORT_CARD_FIELD_KEYS (track_record, cases, assets, education,
 * approachability) plus a sixth `news` row — Candidate.astro's News &
 * coverage section, included here as a row so it lines up too. Each of the
 * five FieldRow-anatomy cells (value + SourceLine) is built the same way
 * Candidate.astro resolves them (`pickValue`, kept as its own local copy
 * here per the same small-duplication convention noted above) — the brief
 * explicitly allows rendering FieldRow's anatomy directly in a grid/table
 * cell rather than reusing the FieldRow component itself (whose own
 * internal label paragraph would duplicate this table's own row header).
 *
 * NEUTRALITY (design-system §4, non-negotiable): every candidate column
 * gets the exact same width/photo-size/field-order/markup regardless of
 * party or position — ordering is alphabetical only. Candidate headers
 * reuse CandidateRow verbatim (same component as ward lists — party is
 * TEXT only, no color). Cases/assets render in plain ink, same FieldRow-style
 * markup as every other field — no alarm/danger styling.
 *
 * EMPTY STATE (PRD §5.3 read alongside design-system §7.12): a ward with
 * ZERO filed/contesting candidates (e.g. only withdrawn/rejected on file,
 * or none yet) renders EmptyState at HTTP 200 — "No candidates to compare
 * yet" plus a link back to the ward and the register-for-updates slot —
 * never a broken/empty table.
 *
 * REGISTER-FOR-UPDATES SLOT (IA §3.5 "same as §3.2"): exactly ONE
 * `[data-register-slot]` element ever renders per response (empty-state
 * branch XOR table-bottom branch, mutually exclusive) — same convention as
 * WardCandidates.astro, for the same MeSlot `querySelector` reason.
 *
 * CACHE-SAFETY (architecture §5): this component never reads cookies or
 * session — the page is identical for every visitor.
 */
import Base from '../../layouts/Base.astro';
import Button from '../../components/Button.astro';
import EmptyState from '../../components/EmptyState.astro';
import CandidateRow from '../../components/CandidateRow.astro';
import type { CandidateRowCandidate } from '../../components/CandidateRow.astro';
import SourceLine from '../../components/SourceLine.astro';
import { t, localePath, type Lang } from '../../i18n';
import { db } from '../../db/client';
import { wards, candidates, candidateFields, candidateNewsLinks, media } from '../../db/schema';
import { and, eq, inArray } from 'drizzle-orm';
import { REPORT_CARD_FIELD_KEYS, type ReportCardFieldKey } from '../../lib/curator';
import { getKnownSetting } from '../../lib/settings';

interface Props {
  lang: Lang;
  wardId: number;
}

const { lang, wardId } = Astro.props;

// See module docstring: local copy of readiness.ts's ACTIVE_CANDIDATE_STATUSES.
const COMPARABLE_STATUSES = ['filed', 'contesting'] as const;

const [ward] = await db.select().from(wards).where(eq(wards.id, wardId));

const FIELD_LABEL_KEYS: Record<ReportCardFieldKey, string> = {
  track_record: 'candidate.field.trackRecord',
  cases: 'candidate.field.cases',
  assets: 'candidate.field.assets',
  education: 'candidate.field.education',
  approachability: 'candidate.field.approachability',
};

interface ResolvedField {
  value: string | null;
  notDeclared: boolean;
  sourceType: 'official' | 'curator';
  sourceUrl: string | null;
  aiExtracted: boolean;
  authoredLang: Lang;
  translationStatus: 'pending' | 'done' | 'manual';
}

interface NewsLinkLite {
  url: string;
  title: string;
}

interface CompareCandidate {
  id: number;
  slug: string;
  nameEn: string;
  nameKn: string | null;
  partyEn: string;
  partyKn: string | null;
  photoUrl: string | null;
  fields: Record<ReportCardFieldKey, ResolvedField>;
  newsLinks: NewsLinkLite[];
}

/** Same caller-resolved value pick Candidate.astro uses (Task 40 convention): prefer this page's own language, falling back to the other one when it hasn't been authored/translated yet. */
function pickValue(preferred: Lang, en: string | null | undefined, kn: string | null | undefined): string | null {
  const value = preferred === 'kn' ? (kn ?? en) : (en ?? kn);
  return value ?? null;
}

const candidateRows = ward
  ? await db
      .select({
        id: candidates.id,
        slug: candidates.slug,
        nameEn: candidates.nameEn,
        nameKn: candidates.nameKn,
        partyEn: candidates.partyEn,
        partyKn: candidates.partyKn,
        photoMediaId: candidates.photoMediaId,
        photoHash: media.sha256,
      })
      .from(candidates)
      .leftJoin(media, eq(media.id, candidates.photoMediaId))
      .where(and(eq(candidates.wardId, wardId), inArray(candidates.status, COMPARABLE_STATUSES)))
  : [];

// Alphabetical by nameEn, id tiebreak — see module docstring; never ranked.
const orderedCandidates = [...candidateRows].sort((a, b) => a.nameEn.localeCompare(b.nameEn) || a.id - b.id);
const candidateIds = orderedCandidates.map((c) => c.id);

const fieldRows = candidateIds.length > 0 ? await db.select().from(candidateFields).where(inArray(candidateFields.candidateId, candidateIds)) : [];
const fieldsByCandidate = new Map<number, Map<string, (typeof fieldRows)[number]>>();
for (const row of fieldRows) {
  if (!fieldsByCandidate.has(row.candidateId)) fieldsByCandidate.set(row.candidateId, new Map());
  fieldsByCandidate.get(row.candidateId)!.set(row.fieldKey, row);
}

// Approved-only, same public guard listNewsLinks's approvedOnly option
// documents — batched here (rather than N calls to that helper) since this
// page may render an unbounded number of candidates in one response.
const newsRows =
  candidateIds.length > 0
    ? await db
        .select({ candidateId: candidateNewsLinks.candidateId, url: candidateNewsLinks.url, title: candidateNewsLinks.title })
        .from(candidateNewsLinks)
        .where(and(inArray(candidateNewsLinks.candidateId, candidateIds), eq(candidateNewsLinks.status, 'approved')))
    : [];
const newsByCandidate = new Map<number, NewsLinkLite[]>();
for (const row of newsRows) {
  if (!newsByCandidate.has(row.candidateId)) newsByCandidate.set(row.candidateId, []);
  newsByCandidate.get(row.candidateId)!.push({ url: row.url, title: row.title });
}

const compareCandidates: CompareCandidate[] = orderedCandidates.map((c) => {
  const fieldsForCandidate = fieldsByCandidate.get(c.id);
  const fields = Object.fromEntries(
    REPORT_CARD_FIELD_KEYS.map((key) => {
      const f = fieldsForCandidate?.get(key);
      const resolved: ResolvedField = {
        value: pickValue(lang, f?.valueEn, f?.valueKn),
        notDeclared: f?.notDeclared ?? false,
        sourceType: f?.sourceType ?? ('curator' as const),
        sourceUrl: f?.sourceUrl ?? null,
        aiExtracted: f?.aiExtracted ?? false,
        authoredLang: f?.authoredLang ?? lang,
        translationStatus: f?.translationStatus ?? ('done' as const),
      };
      return [key, resolved];
    }),
  ) as Record<ReportCardFieldKey, ResolvedField>;

  return {
    id: c.id,
    slug: c.slug,
    nameEn: c.nameEn,
    nameKn: c.nameKn,
    partyEn: c.partyEn,
    partyKn: c.partyKn,
    photoUrl: c.photoMediaId != null && c.photoHash ? `/media/${c.photoMediaId}/${c.photoHash.slice(0, 16)}` : null,
    fields,
    newsLinks: newsByCandidate.get(c.id) ?? [],
  };
});

const candidateRowShapes: (CandidateRowCandidate & { id: number })[] = compareCandidates.map((c) => ({
  id: c.id,
  slug: c.slug,
  nameEn: c.nameEn,
  nameKn: c.nameKn,
  partyEn: c.partyEn,
  partyKn: c.partyKn,
  photoUrl: c.photoUrl,
}));

const withdrawalsClosedSetting = await getKnownSetting('withdrawals_closed');
const isProvisional = withdrawalsClosedSetting !== 'true';

const notificationDateSetting = await getKnownSetting('notification_date');
const emptyFact = notificationDateSetting
  ? t(lang, 'compare.empty.fact', { date: notificationDateSetting })
  : t(lang, 'compare.empty.awaited');

const wardName = ward ? (lang === 'kn' ? ward.nameKn : ward.nameEn) : '';
const pagePath = `/ward/${wardId}/compare`;
const title = ward ? t(lang, 'compare.meta.title', { wardName }) : t(lang, 'ward.notFound.fact');
const description = ward ? t(lang, 'compare.meta.description', { wardName }) : t(lang, 'ward.notFound.fact');

/** Same pending-translation-indicator rule FieldRow.astro's own docstring encodes — kept local since this cell markup deliberately doesn't route through that component (see module docstring). */
function showPendingIndicator(field: ResolvedField): boolean {
  const isNotDeclared = field.notDeclared || !field.value;
  return !isNotDeclared && field.translationStatus === 'pending' && field.authoredLang !== lang;
}
---

<Base lang={lang} title={title} description={description} path={pagePath}>
  {
    ward ? (
      <div class="compare">
        <header class="page-header">
          <h1>{wardName}</h1>
          <p class="subheading">{t(lang, 'compare.pageHeading')}</p>
        </header>

        {compareCandidates.length === 0 ? (
          <EmptyState fact={emptyFact}>
            <a class="back-to-ward" href={localePath(lang, `/ward/${wardId}`)}>
              {t(lang, 'compare.links.backToWard')}
            </a>
            <Button
              variant="primary"
              href={localePath(lang, '/login')}
              lang={lang}
              data-register-slot
              data-ward-id={wardId}
              data-msg-receiving-updates={t(lang, 'common.receivingUpdates')}
            >
              {t(lang, 'common.registerForUpdates')}
            </Button>
          </EmptyState>
        ) : (
          <>
            {isProvisional && <p class="provisional-marker">{t(lang, 'candidate.provisionalMarker')}</p>}

            <div class="compare-scroll">
              <table class="compare-table">
                <caption class="sr-only">{t(lang, 'compare.table.caption')}</caption>
                <thead>
                  <tr>
                    <th scope="col" class="label-col sticky-col" />
                    {candidateRowShapes.map((candidate) => (
                      <th scope="col" class="candidate-col">
                        <CandidateRow candidate={candidate} lang={lang} />
                      </th>
                    ))}
                  </tr>
                </thead>
                <tbody>
                  {REPORT_CARD_FIELD_KEYS.map((key) => (
                    <tr>
                      <th scope="row" class="label-col sticky-col">
                        {t(lang, FIELD_LABEL_KEYS[key])}
                      </th>
                      {compareCandidates.map((candidate) => {
                        const field = candidate.fields[key];
                        const isNotDeclared = field.notDeclared || !field.value;
                        return (
                          <td class="candidate-col">
                            <div class="cell-value">
                              {isNotDeclared ? (
                                <p class="field-value field-value--not-declared">{t(lang, 'common.notDeclared')}</p>
                              ) : (
                                <p class="field-value">
                                  {field.value}
                                  {showPendingIndicator(field) && (
                                    <span class="field-value__pending-note" aria-label={t(lang, 'common.translationPending')}>
                                      {' '}
                                      · {t(lang, 'common.translationPending')}
                                    </span>
                                  )}
                                </p>
                              )}
                              <SourceLine
                                sourceType={field.sourceType}
                                sourceUrl={field.sourceUrl}
                                aiExtracted={field.aiExtracted}
                                lang={lang}
                              />
                            </div>
                          </td>
                        );
                      })}
                    </tr>
                  ))}
                  <tr>
                    <th scope="row" class="label-col sticky-col">
                      {t(lang, 'candidate.news.heading')}
                    </th>
                    {compareCandidates.map((candidate) => (
                      <td class="candidate-col">
                        {candidate.newsLinks.length === 0 ? (
                          <p class="field-value field-value--not-declared">{t(lang, 'candidate.news.empty')}</p>
                        ) : (
                          <ul class="news-list">
                            {candidate.newsLinks.map((link) => (
                              <li>
                                <a href={link.url} target="_blank" rel="noopener noreferrer">
                                  {link.title}
                                </a>
                              </li>
                            ))}
                          </ul>
                        )}
                      </td>
                    ))}
                  </tr>
                </tbody>
              </table>
            </div>

            <section class="register-slot">
              <Button
                variant="secondary"
                href={localePath(lang, '/login')}
                lang={lang}
                data-register-slot
                data-ward-id={wardId}
                data-msg-receiving-updates={t(lang, 'common.receivingUpdates')}
              >
                {t(lang, 'common.registerForUpdates')}
              </Button>
            </section>
          </>
        )}
      </div>
    ) : (
      <EmptyState fact={t(lang, 'ward.notFound.fact')} />
    )
  }
</Base>

<style>
  .compare {
    max-width: var(--container-app);
    margin-inline: auto;
    padding: var(--space-8) var(--container-pad-x);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .page-header h1 {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    line-height: var(--leading-3xl);
    margin: 0 0 var(--space-2);
  }

  .subheading {
    margin: 0;
    color: var(--color-text-muted);
  }

  .provisional-marker {
    margin: 0;
    font-size: var(--text-sm);
    font-style: italic;
    color: var(--color-text-muted);
  }

  .back-to-ward {
    color: var(--color-primary);
    font-weight: 700;
    text-decoration: none;
  }

  .back-to-ward:hover,
  .back-to-ward:focus-visible {
    text-decoration: underline;
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /* Horizontal-scroll container (PRD §5.3): candidate columns scroll while
     the field-label column stays pinned via its own `position: sticky`. */
  .compare-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .compare-table {
    border-collapse: collapse;
    width: 100%;
    table-layout: fixed;
  }

  .compare-table th,
  .compare-table td {
    border-bottom: 1px solid var(--color-border);
    padding: var(--space-3) var(--space-4);
    vertical-align: top;
    text-align: left;
    font-weight: normal;
  }

  .compare-table tr:last-child th,
  .compare-table tr:last-child td {
    border-bottom: none;
  }

  .label-col {
    width: 108px;
    min-width: 108px;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  /* Field-label column pinned (PRD §5.3 "field-label column pinned so rows
     stay readable mid-scroll"). */
  .sticky-col {
    position: sticky;
    left: 0;
    z-index: 1;
    background: var(--color-bg);
    border-right: 1px solid var(--color-border);
  }

  /* ~2-up on mobile: each candidate column takes roughly half the viewport
     so two are visible with the rest reachable by horizontal scroll (no
     hard cap on candidate count, PRD §5.3). */
  .candidate-col {
    width: 46vw;
    min-width: 168px;
  }

  /* Wider screens: more columns fit without scrolling (design-system §2,
     "Desktop; compare grid widens" at --bp-lg / 1024px). */
  @media (min-width: 1024px) {
    .candidate-col {
      width: 260px;
      min-width: 260px;
    }
  }

  .cell-value {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .field-value {
    margin: 0;
    font-size: var(--text-base);
    color: var(--color-text);
  }

  .field-value--not-declared {
    font-style: italic;
    color: var(--color-text-muted);
  }

  .field-value__pending-note {
    font-size: var(--text-xs);
    font-style: italic;
    color: var(--color-text-muted);
  }

  .news-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .news-list a {
    color: var(--color-primary);
    font-weight: 700;
    text-decoration: none;
    font-size: var(--text-sm);
  }

  .news-list a:hover,
  .news-list a:focus-visible {
    text-decoration: underline;
  }

  .register-slot {
    display: flex;
  }
</style>
