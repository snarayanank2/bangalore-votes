---
/**
 * Data & key metrics (`/data`, `/kn/data`) — information-architecture.md
 * §3.14, PRD §5.14. "A platform that publishes other people's records
 * should publish its own." No editorial content file backs this page
 * (unlike About/Press) — every figure is computed live by
 * `publicMetrics()` (src/lib/metrics.ts) and rendered through plain i18n
 * labels.
 *
 * PHASE GATE (PRD §5.14/§13.1, load-bearing): this page ships in Phase 2,
 * not Phase 1. During the teaser it would honestly read "14 of 369
 * wards" — damaging, and it hands critics a number. `app_settings
 * .data_page_live` is the gate: anything other than the literal string
 * `'true'` renders a held NOTICE state (HTTP 200 — the URL is real and
 * indexable, there is just nothing to show yet) instead of ANY figure.
 * `publicMetrics()` is not even called in the held branch — there is
 * nothing to compute for a state that must not reveal a count.
 *
 * FIGURES, NOT DATASETS (PRD §5.14/§16): no download link, no API, no
 * per-ward breakdown — just the aggregate figures IA §3.14 lists.
 *
 * CACHE-SAFETY (architecture.md §5): no cookie/session read — this page
 * is identical for every visitor at a given instant. It computes LIVE on
 * every render; the ~5-minute staleness citizens actually see comes from
 * nginx's micro-cache TTL (Task 60's concern), not from any caching in
 * this component or in `publicMetrics()` itself.
 */
import Base from '../../layouts/Base.astro';
import Banner from '../../components/Banner.astro';
import Card from '../../components/Card.astro';
import StatFigure from '../../components/StatFigure.astro';
import IssueBars from '../../components/IssueBars.astro';
import { t, type Lang } from '../../i18n';
import { getKnownSetting } from '../../lib/settings';
import { publicMetrics } from '../../lib/metrics';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const dataPageLive = (await getKnownSetting('data_page_live')) === 'true';
const metrics = dataPageLive ? await publicMetrics() : null;

function formatAsOf(iso: string, forLang: Lang): string {
  return new Intl.DateTimeFormat(forLang === 'kn' ? 'kn-IN' : 'en-IN', {
    dateStyle: 'medium',
    timeStyle: 'short',
    timeZone: 'Asia/Kolkata',
  }).format(new Date(iso));
}
---

<Base lang={lang} title={t(lang, 'data.meta.title')} description={t(lang, 'data.meta.description')} path="/data">
  <div class="data-page">
    <header class="page-header">
      <h1>{t(lang, 'data.heading')}</h1>
      <p class="intro">{t(lang, 'data.intro')}</p>
    </header>

    {
      !metrics ? (
        <Banner kind="notice" lang={lang}>
          {t(lang, 'data.notLive.body')}
        </Banner>
      ) : (
        <>
          <p class="as-of">{t(lang, 'data.asOf', { date: formatAsOf(metrics.asOf, lang) })}</p>

          <Card>
            <section aria-labelledby="coverage-heading">
              <h2 id="coverage-heading">{t(lang, 'data.coverage.heading')}</h2>
              <dl class="stat-grid">
                <StatFigure
                  label={t(lang, 'data.coverage.wardsWithData.label')}
                  value={t(lang, 'data.coverage.wardsWithData.value', {
                    count: metrics.coverage.wardsWithData,
                    total: metrics.coverage.total,
                  })}
                />
                <StatFigure
                  label={t(lang, 'data.coverage.wardsSignedOff.label')}
                  value={t(lang, 'data.coverage.wardsSignedOff.value', {
                    count: metrics.coverage.wardsSignedOff,
                    total: metrics.coverage.total,
                  })}
                />
                <StatFigure
                  label={t(lang, 'data.coverage.reportCardsComplete.label')}
                  value={metrics.coverage.reportCardsComplete}
                />
                <StatFigure label={t(lang, 'data.coverage.activeCurators.label')} value={metrics.coverage.activeCurators} />
                <StatFigure label={t(lang, 'data.coverage.sourcesCited.label')} value={metrics.coverage.sourcesCited} />
              </dl>
            </section>
          </Card>

          <Card>
            <section aria-labelledby="integrity-heading">
              <h2 id="integrity-heading">{t(lang, 'data.integrity.heading')}</h2>
              <dl class="stat-grid">
                <StatFigure label={t(lang, 'data.integrity.flagsRaised.label')} value={metrics.integrity.flagsRaised} />
                <StatFigure label={t(lang, 'data.integrity.flagsResolved.label')} value={metrics.integrity.flagsResolved} />
                <StatFigure
                  label={t(lang, 'data.integrity.medianResolveHours.label')}
                  value={
                    metrics.integrity.medianResolveHours != null
                      ? t(lang, 'data.integrity.medianResolveHours.value', { hours: metrics.integrity.medianResolveHours })
                      : t(lang, 'data.integrity.medianResolveHours.notEnoughData')
                  }
                />
              </dl>
            </section>
          </Card>

          <Card>
            <section aria-labelledby="citizen-signal-heading">
              <h2 id="citizen-signal-heading">{t(lang, 'data.citizenSignal.heading')}</h2>
              <dl class="stat-grid">
                <StatFigure
                  label={t(lang, 'data.citizenSignal.totalVotesCast.label')}
                  value={metrics.citizenSignal.totalVotesCast}
                />
                <StatFigure
                  label={t(lang, 'data.citizenSignal.registeredCitizens.label')}
                  value={metrics.citizenSignal.registeredCitizens}
                />
              </dl>

              <div class="issue-rollup">
                <h3>{t(lang, 'data.citizenSignal.issueRollup.heading')}</h3>
                {metrics.citizenSignal.issueRollup.length === 0 ? (
                  <p class="empty-note">{t(lang, 'data.citizenSignal.issueRollup.empty')}</p>
                ) : (
                  <IssueBars results={metrics.citizenSignal.issueRollup} lang={lang} showCounts={false} />
                )}
              </div>
            </section>
          </Card>

          <p class="figures-note">{t(lang, 'data.figuresNotDatasets')}</p>
        </>
      )
    }
  </div>
</Base>

<style>
  .data-page {
    max-width: var(--container-app);
    margin-inline: auto;
    padding: var(--space-8) var(--container-pad-x);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .page-header h1 {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    line-height: var(--leading-3xl);
    margin: 0 0 var(--space-2);
  }

  .intro {
    margin: 0;
    color: var(--color-text-muted);
  }

  .as-of {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  h2 {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    margin: 0 0 var(--space-4);
  }

  h3 {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    margin: 0 0 var(--space-3);
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: var(--space-4);
    margin: 0;
  }

  .issue-rollup {
    margin-block-start: var(--space-6);
  }

  .empty-note {
    margin: 0;
    color: var(--color-text-muted);
    font-style: italic;
  }

  .figures-note {
    margin: 0;
    text-align: center;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }
</style>
