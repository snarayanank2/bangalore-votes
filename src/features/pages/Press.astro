---
/**
 * Press kit (`/press`, `/kn/press`) — information-architecture.md §3.16,
 * PRD §5.15. "Journalists arrive at the EC notification whether or not
 * anything is ready for them" — unlike `/data` (Phase 2, gated), this
 * page SHIPS IN PHASE 1 ALWAYS: it never reads `app_settings
 * .data_page_live` and never gates on it. A press kit assembled at the
 * notification is assembled too late.
 *
 * Renders the Task 8 `press` content entry (boilerplate at 50/100/200
 * words, the neutrality statement, the sourcing-methodology link to
 * `/about`) via the shared content pipeline (`renderContentHtml`,
 * `splitMarkdownSections` — same pattern as CheckRegistration.astro),
 * PLUS THREE interleaved elements that content authoring alone can't
 * provide, each spliced in at the exact point its content section's own
 * (now-stripped) `<!-- INPUT NEEDED -->` marker sits:
 *
 *   1. "## Key stats" — a small subset of `publicMetrics()`'s live
 *      figures (wards with published data, registered citizens, flags
 *      resolved), with its own "as of" timestamp. This is the one place
 *      `/press` reaches into the SAME metrics `/data` publishes — a
 *      journalist needs a real number today, in Phase 1, even though
 *      `/data` itself doesn't ship until Phase 2 (PRD §5.14/§5.15).
 *   2. "## Logos and screenshots" — a placeholder note (real asset files
 *      are INPUT NEEDED; never invented).
 *   3. "## Spokesperson" / "## Contact" — placeholder notes (spokesperson
 *      bio/quote and the press contact + stated response time are BOTH
 *      still INPUT NEEDED in content/pages/{lang}/press.md; this page
 *      renders an honest "coming soon" note rather than fabricating a
 *      name, email, or response-time commitment nobody has actually made).
 *
 * INPUT NEEDED markers themselves never reach the visitor —
 * `renderContentHtml` strips every HTML comment before parsing (see that
 * module's docstring); this page adds nothing that could leak one.
 *
 * CACHE-SAFETY (architecture.md §5): no cookie/session read. Computes
 * `publicMetrics()` live on every render, exactly like `/data` — the same
 * nginx micro-cache TTL applies to whichever page a visitor requests.
 */
import Prose from '../../layouts/Prose.astro';
import Card from '../../components/Card.astro';
import StatFigure from '../../components/StatFigure.astro';
import { t, type Lang } from '../../i18n';
import { getPageContent } from '../../i18n/content';
import { renderContentHtml, splitMarkdownSections } from '../../lib/render-content';
import { publicMetrics } from '../../lib/metrics';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const content = getPageContent(lang, 'press');
if (!content) {
  throw new Error('Press: missing content/pages/en/press.md');
}

const metrics = await publicMetrics();

function formatAsOf(iso: string, forLang: Lang): string {
  return new Intl.DateTimeFormat(forLang === 'kn' ? 'kn-IN' : 'en-IN', {
    dateStyle: 'medium',
    timeStyle: 'short',
    timeZone: 'Asia/Kolkata',
  }).format(new Date(iso));
}

// content/pages/{lang}/press.md's H2 order: Boilerplate, Key stats, Logos
// and screenshots, Spokesperson, Contact, Neutrality statement, Sourcing
// methodology. splitMarkdownSections gives [preamble, ...one chunk per H2].
const sections = splitMarkdownSections(content.body);
const intro = sections.slice(0, 2).join(''); // preamble + Boilerplate
const keyStatsHeading = sections[2] ?? ''; // "## Key stats" (body is INPUT NEEDED, stripped to nothing)
const logosHeading = sections[3] ?? ''; // "## Logos and screenshots"
const spokespersonHeading = sections[4] ?? ''; // "## Spokesperson"
const contactHeading = sections[5] ?? ''; // "## Contact"
const rest = sections.slice(6).join(''); // Neutrality statement + Sourcing methodology (real content)
---

<Prose lang={lang} title={content.title} description={content.description} path="/press">
  <div set:html={renderContentHtml(intro, lang)} />

  <div set:html={renderContentHtml(keyStatsHeading, lang)} />
  <Card>
    <p class="as-of">{t(lang, 'press.keyStats.asOf', { date: formatAsOf(metrics.asOf, lang) })}</p>
    <dl class="stat-grid">
      <StatFigure
        label={t(lang, 'press.keyStats.wardsWithData.label')}
        value={t(lang, 'press.keyStats.wardsWithData.value', {
          count: metrics.coverage.wardsWithData,
          total: metrics.coverage.total,
        })}
      />
      <StatFigure
        label={t(lang, 'press.keyStats.registeredCitizens.label')}
        value={metrics.citizenSignal.registeredCitizens}
      />
      <StatFigure label={t(lang, 'press.keyStats.flagsResolved.label')} value={metrics.integrity.flagsResolved} />
    </dl>
  </Card>

  <div set:html={renderContentHtml(logosHeading, lang)} />
  <p class="pending-note">{t(lang, 'press.logos.pendingNote')}</p>

  <div set:html={renderContentHtml(spokespersonHeading, lang)} />
  <p class="pending-note">{t(lang, 'press.spokesperson.pendingNote')}</p>

  <div set:html={renderContentHtml(contactHeading, lang)} />
  <p class="pending-note">{t(lang, 'press.contact.pendingNote')}</p>

  <div set:html={renderContentHtml(rest, lang)} />
</Prose>

<style>
  .as-of {
    margin: 0 0 var(--space-4);
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .stat-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
    gap: var(--space-4);
    margin: 0;
  }

  .pending-note {
    margin: 0 0 var(--space-6);
    color: var(--color-text-muted);
    font-style: italic;
  }
</style>
