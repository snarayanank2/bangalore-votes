---
/**
 * Ward issues & voting (`/ward/{id}/issues`, `/kn/ward/{id}/issues`) —
 * information-architecture.md §3.6, PRD §5.4 (issues & candidate stance),
 * §5.5 (citizen issue voting), §13.1 (Phase 1 page — ships before candidate
 * data). Renders: the curator-defined issue list, each issue's candidate
 * stances (where any exist), the public ranked/percentage results, the
 * "Vote your top 3" action, and the register-for-updates slot.
 *
 * Existence check lives in the route twins (src/pages/ward/[id]/issues.astro,
 * src/pages/kn/ward/[id]/issues.astro), not here — same pattern as
 * Ward.astro/[id].astro; see that file's header comment for the full
 * rationale. The `ward` lookup below is guarded defensively anyway.
 *
 * CACHE-SAFETY (architecture.md §5, binding): this component never reads
 * cookies/session. Both anonymous-only controls below — the register-for-
 * updates slot and the "Vote your top 3" action — always render their full
 * enabled anonymous markup (design-system.md §7.8: gated actions never
 * render disabled), identical for every visitor. The public issue-vote
 * results are themselves global per-ward state (same aggregate for
 * everyone), so nothing on this page varies by visitor. The "Vote your top
 * 3" button is a plain `type="button"` (no `href` — same convention as the
 * "Flag an error" button below it) carrying `data-vote-action`/
 * `data-ward-id`/`data-vote-issues` (this ward's CURRENT issues as a
 * JSON-encoded `{id,title}[]`, in the page's own language); Task 33's
 * `src/islands/VoteModal.ts` (mounted once from Base.astro) wires it up —
 * there is no server-rendered fallback href, matching FlagModal's own
 * JS-only convention. Task 28's MeSlot island (src/islands/MeSlot.ts) swaps
 * the register-for-updates control the same way it does on Ward.astro, and
 * lightly marks `data-vote-action` with `data-already-voted` when this ward
 * is the signed-in visitor's active issue-vote-set ward (a hint only —
 * VoteModal's own `/api/issue-votes` GET is what actually pre-checks the
 * modal's selections).
 *
 * No-raw-counts guarantee (PRD §5.5): `issueResults` (src/lib/votes.ts)
 * never returns a count field, and `<IssueBars>` is called with
 * `showCounts={false}` — belt and braces, since the data itself carries no
 * count to show.
 */
import Base from '../../layouts/Base.astro';
import EmptyState from '../../components/EmptyState.astro';
import Button from '../../components/Button.astro';
import SourceLine from '../../components/SourceLine.astro';
import IssueBars from '../../components/IssueBars.astro';
import { t, localePath, type Lang } from '../../i18n';
import { db } from '../../db/client';
import { wards, wardIssues, candidateStances, candidates } from '../../db/schema';
import { and, asc, eq, notInArray } from 'drizzle-orm';
import { issueResults } from '../../lib/votes';

interface Props {
  lang: Lang;
  wardId: number;
}

const { lang, wardId } = Astro.props;

const [ward] = await db.select().from(wards).where(eq(wards.id, wardId));

// Prefers the page's own language, falling back to the other one when a
// bilingual field hasn't been authored/translated in the preferred
// language yet (ward_issues.titleEn/titleKn and candidate_stances'
// valueEn/valueKn are both nullable for exactly this reason — see schema.ts).
function pick(preferred: Lang, en: string | null, kn: string | null): string {
  return preferred === 'kn' ? (kn ?? en ?? '') : (en ?? kn ?? '');
}

const issues = ward
  ? await db
      .select({
        id: wardIssues.id,
        titleEn: wardIssues.titleEn,
        titleKn: wardIssues.titleKn,
        position: wardIssues.position,
      })
      .from(wardIssues)
      .where(eq(wardIssues.wardId, wardId))
      .orderBy(asc(wardIssues.position), asc(wardIssues.id))
  : [];

// Candidate stances for this ward's current issues, excluding withdrawn/
// rejected candidates (PRD §5.2/§5.4). Grouped by issue below.
const stanceRows = ward
  ? await db
      .select({
        wardIssueId: candidateStances.wardIssueId,
        valueEn: candidateStances.valueEn,
        valueKn: candidateStances.valueKn,
        sourceUrl: candidateStances.sourceUrl,
        sourceType: candidateStances.sourceType,
        candidateSlug: candidates.slug,
        candidateNameEn: candidates.nameEn,
        candidateNameKn: candidates.nameKn,
      })
      .from(candidateStances)
      .innerJoin(candidates, eq(candidateStances.candidateId, candidates.id))
      .innerJoin(wardIssues, eq(candidateStances.wardIssueId, wardIssues.id))
      .where(and(eq(wardIssues.wardId, wardId), notInArray(candidates.status, ['withdrawn', 'rejected'])))
  : [];

const stancesByIssue = new Map<number, typeof stanceRows>();
for (const row of stanceRows) {
  const existing = stancesByIssue.get(row.wardIssueId);
  if (existing) {
    existing.push(row);
  } else {
    stancesByIssue.set(row.wardIssueId, [row]);
  }
}

const results = ward ? await issueResults(wardId) : [];
const barResults = results.map((r) => ({
  issueTitle: pick(lang, r.titleEn, r.titleKn),
  rank: r.rank,
  sharePct: r.sharePct,
}));

const wardName = ward ? (lang === 'kn' ? ward.nameKn : ward.nameEn) : '';
const pagePath = `/ward/${wardId}/issues`;
const title = ward ? t(lang, 'ward.issues.meta.title', { wardName }) : t(lang, 'ward.notFound.fact');
const description = ward ? t(lang, 'ward.issues.meta.description', { wardName }) : t(lang, 'ward.notFound.fact');

// Flag misinformation (Task 32, IA §7.2, PRD §6.1) — this page's flaggable
// targets are the ward's own curator-defined issues, one ward_issue target
// per issue (only rendered once at least one issue exists — see the Flag
// action markup below). Same anonymous-safe markup for every visitor
// (design-system.md §7.8); the auth gate happens client-side on tap.
const flagTargets = JSON.stringify(
  issues.map((issue) => ({
    targetType: 'ward_issue',
    targetRef: `ward_issue:${issue.id}`,
    label: pick(lang, issue.titleEn, issue.titleKn),
  })),
);

// Cast issue vote (Task 33, PRD §5.5) — the ward's current issues, in the
// page's own language, for src/islands/VoteModal.ts's client-built checkbox
// list. Same "current issue list only" scoping as issueResults: an issue
// deleted after this button was rendered simply won't be an option the next
// time the page (and this JSON) is served.
const voteIssues = JSON.stringify(
  issues.map((issue) => ({ id: issue.id, title: pick(lang, issue.titleEn, issue.titleKn) })),
);
---

<Base lang={lang} title={title} description={description} path={pagePath}>
  {
    ward ? (
      <div class="ward-issues">
        <header class="page-header">
          <h1>{wardName}</h1>
          <p class="subheading">{t(lang, 'ward.issues.subheading')}</p>
          {issues.length > 0 && (
            <Button
              variant="tertiary"
              type="button"
              lang={lang}
              data-flag-action
              data-ward-id={wardId}
              data-flag-targets={flagTargets}
            >
              {t(lang, 'common.flagError')}
            </Button>
          )}
        </header>

        {issues.length === 0 ? (
          <EmptyState fact={t(lang, 'ward.issues.empty.fact')} nextStep={t(lang, 'ward.issues.empty.nextStep')} />
        ) : (
          <>
            <ol class="issue-list" aria-label={t(lang, 'ward.issues.list.label')}>
              {issues.map((issue) => {
                const issueTitle = pick(lang, issue.titleEn, issue.titleKn);
                const stances = stancesByIssue.get(issue.id) ?? [];
                return (
                  <li class="issue-item">
                    <h2 class="issue-title">{issueTitle}</h2>
                    {stances.length > 0 && (
                      <ul class="stance-list" aria-label={t(lang, 'ward.issues.item.stancesLabel')}>
                        {stances.map((stance) => (
                          <li class="stance">
                            <a class="stance-candidate" href={localePath(lang, `/candidate/${stance.candidateSlug}`)}>
                              {lang === 'kn' && stance.candidateNameKn ? stance.candidateNameKn : stance.candidateNameEn}
                            </a>
                            <p class="stance-value">{pick(lang, stance.valueEn, stance.valueKn)}</p>
                            <SourceLine sourceType={stance.sourceType} sourceUrl={stance.sourceUrl} lang={lang} />
                          </li>
                        ))}
                      </ul>
                    )}
                  </li>
                );
              })}
            </ol>

            <section class="results" aria-label={t(lang, 'ward.issues.results.label')}>
              <h2>{t(lang, 'ward.issues.results.heading')}</h2>
              <IssueBars results={barResults} lang={lang} showCounts={false} />
            </section>

            <section class="vote-action">
              <Button
                variant="primary"
                type="button"
                lang={lang}
                data-vote-action
                data-ward-id={wardId}
                data-vote-issues={voteIssues}
              >
                {t(lang, 'common.voteTop3')}
              </Button>
            </section>
          </>
        )}

        <section class="register-slot">
          <Button
            variant="secondary"
            href={localePath(lang, '/login')}
            lang={lang}
            data-register-slot
            data-ward-id={wardId}
            data-msg-receiving-updates={t(lang, 'common.receivingUpdates')}
          >
            {t(lang, 'common.registerForUpdates')}
          </Button>
        </section>
      </div>
    ) : (
      <EmptyState fact={t(lang, 'ward.notFound.fact')} />
    )
  }
</Base>

<style>
  .ward-issues {
    max-width: var(--container-app);
    margin-inline: auto;
    padding: var(--space-8) var(--container-pad-x);
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
  }

  .page-header h1 {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    line-height: var(--leading-3xl);
    margin: 0 0 var(--space-2);
  }

  .subheading {
    margin: 0;
    color: var(--color-text-muted);
  }

  .issue-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .issue-item {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .issue-title {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    margin: 0;
  }

  .stance-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .stance {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
    padding-inline-start: var(--space-4);
    border-inline-start: 2px solid var(--color-border);
  }

  .stance-candidate {
    font-weight: 700;
    color: var(--color-primary);
    text-decoration: none;
  }

  .stance-candidate:hover,
  .stance-candidate:focus-visible {
    text-decoration: underline;
  }

  .stance-value {
    margin: 0;
    color: var(--color-text);
  }

  .results h2 {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    margin: 0 0 var(--space-4);
  }

  .vote-action,
  .register-slot {
    display: flex;
  }
</style>
