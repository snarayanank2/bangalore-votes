---
/**
 * `/account` (`/kn/account`) — information-architecture.md §4.1, PRD §8/§10.
 * Purely presentational: all state-loading/mutation logic lives in
 * src/lib/account-flow.ts, called by the route twins
 * (src/pages/account/index.astro, src/pages/kn/account/index.astro), which
 * own the HTTP concerns a plain component cannot (redirects on sign-out,
 * Set-Cookie, no-store) — same split as src/features/pages/Login.astro /
 * src/lib/login-flow.ts.
 *
 * Four independent forms, dispatched server-side by a hidden `action`
 * field (`language` | `ward` | `contact_step1` | `contact_step2` |
 * `signout`) rather than four separate routes — all four mutate the SAME
 * account resource and all need the exact same CSRF/session context, so one
 * POST endpoint keeps that context (and the synchronizer token embedding)
 * in one place. Every form embeds the session's CSRF token
 * (src/lib/csrf.ts) as a hidden field — src/middleware.ts 403s any of these
 * POSTs without it.
 *
 * Home ward change (PRD §5.5): changing it retires the previous ward's
 * active issue-vote-set — the helper text below the field says so; the
 * atomic update+retire itself happens in account-flow.ts's `handleWard`.
 *
 * Contact add/change (PRD §9/§10): a two-step OTP flow, structurally
 * identical to /login's no-JS steps 1→2 (src/features/pages/Login.astro) —
 * step 1 collects the new destination, step 2 collects the code, carrying
 * `destination`/`channel` forward as hidden fields between steps.
 */
import Base from '../../layouts/Base.astro';
import FormField from '../../components/FormField.astro';
import Button from '../../components/Button.astro';
import Banner from '../../components/Banner.astro';
import Card from '../../components/Card.astro';
import { t, localePath, type Lang } from '../../i18n';
import { CSRF_FIELD_NAME } from '../../lib/csrf';
import type { AccountRenderState } from '../../lib/account-flow';

interface Props {
  lang: Lang;
  state: AccountRenderState;
  csrfToken: string;
}

const { lang, state, csrfToken } = Astro.props;
const { user, ward, message, contactPending } = state;

const messageText = message ? t(lang, message.key) : undefined;
const wardName = ward ? (lang === 'kn' ? ward.nameKn : ward.nameEn) : undefined;
---

<Base
  lang={lang}
  title={t(lang, 'account.meta.title')}
  description={t(lang, 'account.meta.description')}
  path="/account"
  noindex={true}
>
  <div class="account-page">
    <h1>{t(lang, 'account.heading')}</h1>

    {
      messageText && (
        <Banner kind={message!.kind === 'error' ? 'error' : 'notice'} lang={lang}>
          {messageText}
        </Banner>
      )
    }

    <nav class="account-nav">
      <a href={localePath(lang, '/account/notifications')}>{t(lang, 'account.nav.notifications')}</a>
      <a href={localePath(lang, '/account/submissions')}>{t(lang, 'account.nav.submissions')}</a>
    </nav>

    <Card>
      <h2>{t(lang, 'account.language.heading')}</h2>
      <form method="post">
        <input type="hidden" name="action" value="language" />
        <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
        <div class="form-field">
          <label class="form-label" for="account-language">
            {t(lang, 'account.language.label')}
          </label>
          <select id="account-language" class="form-input" name="language">
            <option value="en" selected={user.language === 'en'}>
              {t(lang, 'account.language.option.en')}
            </option>
            <option value="kn" selected={user.language === 'kn'}>
              {t(lang, 'account.language.option.kn')}
            </option>
          </select>
        </div>
        <Button type="submit" variant="primary" lang={lang}>
          {t(lang, 'account.language.submit')}
        </Button>
      </form>
    </Card>

    <Card>
      <h2>{t(lang, 'account.ward.heading')}</h2>
      <p>{wardName ? t(lang, 'account.ward.current', { ward: wardName }) : t(lang, 'account.ward.none')}</p>
      <form method="post">
        <input type="hidden" name="action" value="ward" />
        <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
        <div class="form-field">
          <label class="form-label" for="account-ward">
            {t(lang, 'account.ward.changeLabel')}
          </label>
          <input id="account-ward" class="form-input" name="wardId" type="number" required />
        </div>
        <p class="helper">{t(lang, 'account.ward.changeHelper')}</p>
        <Button type="submit" variant="primary" lang={lang}>
          {t(lang, 'account.ward.submit')}
        </Button>
      </form>
    </Card>

    <Card>
      <h2>{t(lang, 'account.contact.heading')}</h2>
      <ul class="contact-list">
        <li>
          {t(lang, 'account.contact.emailLabel')}: {user.email ?? t(lang, 'account.contact.none')}
        </li>
        <li>
          {t(lang, 'account.contact.phoneLabel')}: {user.phone ?? t(lang, 'account.contact.none')}
        </li>
      </ul>

      {
        !contactPending && (
          <form method="post">
            <input type="hidden" name="action" value="contact_step1" />
            <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
            <FormField
              label={t(lang, 'account.contact.addLabel')}
              name="destination"
              type="text"
              helper={t(lang, 'account.contact.addHelper')}
              required
              lang={lang}
            />
            <Button type="submit" variant="primary" lang={lang}>
              {t(lang, 'account.contact.addSubmit')}
            </Button>
          </form>
        )
      }

      {
        contactPending && (
          <form method="post">
            <input type="hidden" name="action" value="contact_step2" />
            <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
            <input type="hidden" name="destination" value={contactPending.destination} />
            <input type="hidden" name="channel" value={contactPending.channel} />
            <div class="form-field">
              <label class="form-label" for="account-contact-code">
                {t(lang, 'account.contact.codeLabel')}
              </label>
              <input
                id="account-contact-code"
                class="form-input"
                name="code"
                type="text"
                inputmode="numeric"
                autocomplete="one-time-code"
                maxlength="6"
                required
              />
            </div>
            <Button type="submit" variant="primary" lang={lang}>
              {t(lang, 'account.contact.verifySubmit')}
            </Button>
          </form>
        )
      }
    </Card>

    <Card>
      <form method="post">
        <input type="hidden" name="action" value="signout" />
        <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
        <Button type="submit" variant="destructive" lang={lang}>
          {t(lang, 'account.signout.submit')}
        </Button>
      </form>
    </Card>
  </div>
</Base>

<style>
  .account-page {
    max-width: var(--container-prose);
    margin-inline: auto;
    padding-block: var(--space-8);
    padding-inline: var(--container-pad-x);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .account-page h1 {
    font-size: var(--text-2xl);
    line-height: var(--leading-2xl);
    margin: 0;
  }

  .account-page h2 {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-4);
  }

  .account-nav {
    display: flex;
    gap: var(--space-4);
  }

  form {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    max-width: 24rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .form-label {
    font-size: var(--text-sm);
    font-weight: 700;
  }

  .form-input {
    min-height: 44px;
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-base);
    font-family: var(--font-body);
    color: var(--color-text);
    background: var(--color-bg);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  .form-input:focus-visible {
    outline: 2px solid var(--color-primary);
    outline-offset: 2px;
    border-color: var(--color-primary);
  }

  .helper {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .contact-list {
    margin: 0 0 var(--space-4);
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }
</style>
