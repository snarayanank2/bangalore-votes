---
/**
 * `/admin/partners` (Task 46, information-architecture.md §6.4; PRD
 * §5.12/§5.13/§9.1/§11). The distribution/reach operating dashboard: the
 * partner roster (add/edit, with slug + ward coverage), the ward-coverage
 * matrix (covered vs the 369-ward city, with the UNCOVERED set surfaced as
 * a work queue), the held-wards list (PRD §9.1's comms send-gate, with a
 * per-ward admin override), and the EOI triage queue split by path.
 *
 * PARTNERS ARE NOT A ROLE (PRD §5.12) — this page never touches
 * `users.role`/`curator_scopes`; that's `/admin/roles`
 * (src/features/pages/admin/Roles.astro). The curation-path EOI accept
 * form below only marks the application accepted and points the admin at
 * `/admin/roles` to actually grant the role — see
 * src/lib/partners.ts's `acceptEoiCuration` docstring (PRD §5.13, no
 * self-activation).
 *
 * CONFIRMATION (design-system.md §7.13): every mutating form here uses the
 * same REQUIRED-checkbox convention as Roles.astro/Users.astro — a create/
 * update/override/accept/decline all take effect immediately (curator
 * publish-style, PRD §14), so each gets an explicit "I understand..."
 * checkbox re-validated server-side by the route twin.
 */
import AdminLayout from '../../../layouts/AdminLayout.astro';
import Card from '../../../components/Card.astro';
import Banner from '../../../components/Banner.astro';
import Button from '../../../components/Button.astro';
import Badge from '../../../components/Badge.astro';
import FormField from '../../../components/FormField.astro';
import { t, type Lang } from '../../../i18n';
import { CSRF_FIELD_NAME } from '../../../lib/csrf';
import type { PartnerRosterRow, PartnerCoverage, HeldWard, EoiRow } from '../../../lib/partners';

interface Props {
  lang: Lang;
  csrfToken: string;
  partners: PartnerRosterRow[];
  coverage: PartnerCoverage;
  held: HeldWard[];
  eoisAwareness: EoiRow[];
  eoisCuration: EoiRow[];
  message?: { kind: 'notice' | 'error'; key: string };
}

const { lang, csrfToken, partners, coverage, held, eoisAwareness, eoisCuration, message } = Astro.props;
const messageText = message ? t(lang, message.key) : undefined;

const reasonLabelKeys: Record<HeldWard['reason'], string> = {
  incomplete: 'admin.partners.held.reason.incomplete',
  unsigned: 'admin.partners.held.reason.unsigned',
  cleared: 'admin.partners.held.reason.cleared',
};
---

<AdminLayout lang={lang} title={t(lang, 'admin.partners.meta.title')} description={t(lang, 'admin.partners.meta.description')}>
  <div class="admin-page">
    <p><a href="/admin">{t(lang, 'admin.partners.backToConsole')}</a></p>
    <h1>{t(lang, 'admin.partners.heading')}</h1>

    {
      messageText && (
        <Banner kind={message!.kind === 'error' ? 'error' : 'notice'} lang={lang}>
          {messageText}
        </Banner>
      )
    }

    <Card>
      <h2>{t(lang, 'admin.partners.roster.heading')}</h2>
      {
        partners.length === 0 ? (
          <p class="placeholder-note">{t(lang, 'admin.partners.roster.empty')}</p>
        ) : (
          <div class="table-scroll">
            <table class="dense-table">
              <thead>
                <tr>
                  <th>{t(lang, 'admin.partners.roster.colId')}</th>
                  <th>{t(lang, 'admin.partners.roster.colSlug')}</th>
                  <th>{t(lang, 'admin.partners.roster.colName')}</th>
                  <th>{t(lang, 'admin.partners.roster.colContact')}</th>
                  <th>{t(lang, 'admin.partners.roster.colWards')}</th>
                  <th>{t(lang, 'admin.partners.roster.colRegistrations')}</th>
                </tr>
              </thead>
              <tbody>
                {partners.map((p) => (
                  <tr>
                    <td>{p.id}</td>
                    <td>{p.slug}</td>
                    <td>{p.name}</td>
                    <td>{p.contact ?? '—'}</td>
                    <td>{p.wardIds.length}</td>
                    <td>{p.registrations}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )
      }
    </Card>

    <Card>
      <h2>{t(lang, 'admin.partners.add.heading')}</h2>
      <form method="post" action="/admin/partners" class="stack-form">
        <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
        <input type="hidden" name="formAction" value="create_partner" />
        <FormField label={t(lang, 'admin.partners.add.slugLabel')} name="slug" helper={t(lang, 'admin.partners.add.slugHelper')} required lang={lang} />
        <FormField label={t(lang, 'admin.partners.add.nameLabel')} name="name" required lang={lang} />
        <FormField label={t(lang, 'admin.partners.add.contactLabel')} name="contact" lang={lang} />
        <FormField label={t(lang, 'admin.partners.add.wardIdsLabel')} name="wardIds" lang={lang} />
        <label class="checkbox">
          <input type="checkbox" name="confirm" required />
          {t(lang, 'admin.partners.add.confirmLabel')}
        </label>
        <Button type="submit" variant="primary" lang={lang}>
          {t(lang, 'admin.partners.add.submit')}
        </Button>
      </form>
    </Card>

    {
      partners.length > 0 && (
        <Card>
          <h2>{t(lang, 'admin.partners.edit.heading')}</h2>
          <ul class="manage-list">
            {partners.map((p) => (
              <li class="manage-row">
                <p class="manage-row-title">
                  {p.name} — <code>{p.slug}</code>
                </p>
                <form method="post" action="/admin/partners" class="stack-form">
                  <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
                  <input type="hidden" name="formAction" value="update_partner" />
                  <input type="hidden" name="partnerId" value={p.id} />
                  <FormField label={t(lang, 'admin.partners.edit.nameLabel')} name="name" value={p.name} required lang={lang} />
                  <FormField label={t(lang, 'admin.partners.edit.contactLabel')} name="contact" value={p.contact ?? ''} lang={lang} />
                  <FormField label={t(lang, 'admin.partners.edit.wardIdsLabel')} name="wardIds" value={p.wardIds.join(', ')} lang={lang} />
                  <label class="checkbox">
                    <input type="checkbox" name="confirm" required />
                    {t(lang, 'admin.partners.edit.confirmLabel', { slug: p.slug })}
                  </label>
                  <Button type="submit" variant="secondary" lang={lang}>
                    {t(lang, 'admin.partners.edit.submit')}
                  </Button>
                </form>
              </li>
            ))}
          </ul>
        </Card>
      )
    }

    <Card>
      <h2>{t(lang, 'admin.partners.coverage.heading')}</h2>
      <p>{t(lang, 'admin.partners.coverage.summary', { covered: coverage.covered.length, total: coverage.total })}</p>
      <h3>{t(lang, 'admin.partners.coverage.uncoveredHeading')}</h3>
      {
        coverage.uncovered.length === 0 ? (
          <p class="placeholder-note">{t(lang, 'admin.partners.coverage.uncoveredEmpty')}</p>
        ) : (
          <>
            <p>{t(lang, 'admin.partners.coverage.uncoveredCount', { count: coverage.uncovered.length })}</p>
            <p class="ward-id-list">{coverage.uncovered.join(', ')}</p>
          </>
        )
      }
    </Card>

    <Card>
      <h2>{t(lang, 'admin.partners.held.heading')}</h2>
      {
        held.length === 0 ? (
          <p class="placeholder-note">{t(lang, 'admin.partners.held.empty')}</p>
        ) : (
          <div class="table-scroll">
            <table class="dense-table">
              <thead>
                <tr>
                  <th>{t(lang, 'admin.partners.held.colWard')}</th>
                  <th>{t(lang, 'admin.partners.held.colReason')}</th>
                  <th>{t(lang, 'admin.partners.held.colStatus')}</th>
                  <th>{t(lang, 'admin.partners.held.colAction')}</th>
                </tr>
              </thead>
              <tbody>
                {held.map((w) => (
                  <tr>
                    <td>{w.wardName}</td>
                    <td>{t(lang, reasonLabelKeys[w.reason])}</td>
                    <td>
                      {w.overridden ? (
                        <Badge variant="ward-ready" lang={lang}>
                          {t(lang, 'admin.partners.held.overriddenLabel')}
                        </Badge>
                      ) : (
                        <Badge variant="ward-held" lang={lang} />
                      )}
                    </td>
                    <td>
                      {!w.overridden && (
                        <form method="post" action="/admin/partners" class="inline-form">
                          <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
                          <input type="hidden" name="formAction" value="override_hold" />
                          <input type="hidden" name="wardId" value={w.wardId} />
                          <label class="checkbox">
                            <input type="checkbox" name="confirm" required />
                            {t(lang, 'admin.partners.held.override.confirmLabel', { ward: w.wardName })}
                          </label>
                          <Button type="submit" variant="destructive" lang={lang}>
                            {t(lang, 'admin.partners.held.override.submit')}
                          </Button>
                        </form>
                      )}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )
      }
    </Card>

    <Card>
      <h2>{t(lang, 'admin.partners.eoi.heading')}</h2>

      <h3>{t(lang, 'admin.partners.eoi.awareness.heading')}</h3>
      {
        eoisAwareness.length === 0 ? (
          <p class="placeholder-note">{t(lang, 'admin.partners.eoi.empty')}</p>
        ) : (
          <ul class="manage-list">
            {eoisAwareness.map((eoi) => (
              <li class="manage-row">
                <p class="manage-row-title">{eoi.name}{eoi.organisation ? ` — ${eoi.organisation}` : ''}</p>
                <p>{eoi.contact}</p>
                {eoi.wardsText && <p>{eoi.wardsText}</p>}
                {eoi.message && <p>{eoi.message}</p>}

                <form method="post" action="/admin/partners" class="stack-form">
                  <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
                  <input type="hidden" name="formAction" value="accept_awareness" />
                  <input type="hidden" name="eoiId" value={eoi.id} />
                  <FormField label={t(lang, 'admin.partners.eoi.accept.awareness.slugLabel')} name="slug" required lang={lang} />
                  <FormField label={t(lang, 'admin.partners.eoi.accept.awareness.nameLabel')} name="name" value={eoi.organisation ?? eoi.name} required lang={lang} />
                  <label class="checkbox">
                    <input type="checkbox" name="confirm" required />
                    {t(lang, 'admin.partners.eoi.accept.awareness.confirmLabel')}
                  </label>
                  <Button type="submit" variant="primary" lang={lang}>
                    {t(lang, 'admin.partners.eoi.accept.awareness.submit')}
                  </Button>
                </form>

                <form method="post" action="/admin/partners" class="inline-form">
                  <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
                  <input type="hidden" name="formAction" value="decline_eoi" />
                  <input type="hidden" name="eoiId" value={eoi.id} />
                  <label class="checkbox">
                    <input type="checkbox" name="confirm" required />
                    {t(lang, 'admin.partners.eoi.decline.confirmLabel')}
                  </label>
                  <Button type="submit" variant="tertiary" lang={lang}>
                    {t(lang, 'admin.partners.eoi.decline.submit')}
                  </Button>
                </form>
              </li>
            ))}
          </ul>
        )
      }

      <h3>{t(lang, 'admin.partners.eoi.curation.heading')}</h3>
      {
        eoisCuration.length === 0 ? (
          <p class="placeholder-note">{t(lang, 'admin.partners.eoi.empty')}</p>
        ) : (
          <ul class="manage-list">
            {eoisCuration.map((eoi) => (
              <li class="manage-row">
                <p class="manage-row-title">{eoi.name}{eoi.organisation ? ` — ${eoi.organisation}` : ''}</p>
                <p>{eoi.contact}</p>
                {eoi.wardsText && <p>{eoi.wardsText}</p>}
                {eoi.message && <p>{eoi.message}</p>}

                <form method="post" action="/admin/partners" class="stack-form">
                  <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
                  <input type="hidden" name="formAction" value="accept_curation" />
                  <input type="hidden" name="eoiId" value={eoi.id} />
                  <p class="note">
                    {t(lang, 'admin.partners.eoi.accept.curation.note')} <a href="/admin/roles">{t(lang, 'admin.console.nav.roles')}</a>
                  </p>
                  <label class="checkbox">
                    <input type="checkbox" name="confirm" required />
                    {t(lang, 'admin.partners.eoi.accept.curation.confirmLabel')}
                  </label>
                  <Button type="submit" variant="primary" lang={lang}>
                    {t(lang, 'admin.partners.eoi.accept.curation.submit')}
                  </Button>
                </form>

                <form method="post" action="/admin/partners" class="inline-form">
                  <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
                  <input type="hidden" name="formAction" value="decline_eoi" />
                  <input type="hidden" name="eoiId" value={eoi.id} />
                  <label class="checkbox">
                    <input type="checkbox" name="confirm" required />
                    {t(lang, 'admin.partners.eoi.decline.confirmLabel')}
                  </label>
                  <Button type="submit" variant="tertiary" lang={lang}>
                    {t(lang, 'admin.partners.eoi.decline.submit')}
                  </Button>
                </form>
              </li>
            ))}
          </ul>
        )
      }
    </Card>
  </div>
</AdminLayout>

<style>
  .admin-page {
    max-width: var(--container-prose);
    margin-inline: auto;
    padding-block: var(--space-8);
    padding-inline: var(--container-pad-x);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .admin-page h1 {
    font-size: var(--text-2xl);
    line-height: var(--leading-2xl);
    margin: 0;
  }

  .admin-page h2 {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-3);
  }

  .admin-page h3 {
    font-size: var(--text-base);
    margin: var(--space-4) 0 var(--space-2);
  }

  .placeholder-note {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-style: italic;
  }

  .stack-form,
  .inline-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 32rem;
  }

  .checkbox {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-base);
  }

  .table-scroll {
    overflow-x: auto;
  }

  .dense-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .dense-table th,
  .dense-table td {
    text-align: left;
    padding: 8px;
    border-bottom: 1px solid var(--color-border);
  }

  .dense-table thead th {
    position: sticky;
    top: 0;
    background: var(--color-bg);
  }

  .dense-table tbody tr:nth-child(odd) {
    background: var(--color-surface);
  }

  .manage-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .manage-row {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .manage-row-title {
    margin: 0;
    font-weight: 700;
  }

  .note {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .ward-id-list {
    font-size: var(--text-sm);
    color: var(--color-text-muted);
    word-break: break-word;
  }
</style>
