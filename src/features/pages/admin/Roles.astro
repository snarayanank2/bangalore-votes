---
/**
 * `/admin/roles` (Task 44, information-architecture.md §6.2; PRD §7/§10;
 * design-system.md §7.13). The roles & scope console: grant a role to a
 * user (by id/email lookup), a dense overview table of every current
 * curator/admin with their scope, and a per-user "manage" panel with
 * REVOKE and SET SCOPE forms (curators only — an admin's scope is
 * city-wide, never a stored ward set, see src/lib/authz.ts's
 * `canEditWard`).
 *
 * THE ZONE SHORTCUT (PRD §10): the scope form's ward list is a plain
 * comma-separated ward-id text field (369 wards is too many for a
 * reasonable native `<select multiple>`) PLUS a zone `<select>` — picking
 * a zone does not replace the typed ids, it's UNIONED with them at save
 * time (the route twin calls `expandZoneToWards` and merges the two id
 * sets before calling `setCuratorScope`, which itself has no notion of
 * zones — see src/lib/admin.ts's module docstring). The prefilled
 * `wardIds` value always reflects the CURRENT stored scope, so re-submitting
 * unchanged is a no-op replace.
 *
 * CONFIRMATION (design-system.md §7.13: "destructive and publish actions
 * get confirmation dialogs stating scope"): this codebase's established
 * substitute for a JS `<dialog>` confirm on every other curator/admin form
 * is a REQUIRED checkbox with explicit label text, re-validated
 * server-side (see src/lib/curator.ts's `handleAccept`/`confirmPublish`,
 * src/features/pages/curator/WardIssuesEdit.astro's `confirmRemove`) —
 * grant/revoke/set-scope follow the exact same convention here.
 */
import AdminLayout from '../../../layouts/AdminLayout.astro';
import Card from '../../../components/Card.astro';
import Banner from '../../../components/Banner.astro';
import Button from '../../../components/Button.astro';
import FormField from '../../../components/FormField.astro';
import { t, type Lang } from '../../../i18n';
import { CSRF_FIELD_NAME } from '../../../lib/csrf';
import type { CuratorScopeRow } from '../../../lib/admin';

interface Props {
  lang: Lang;
  csrfToken: string;
  rows: CuratorScopeRow[];
  zones: string[];
  message?: { kind: 'notice' | 'error'; key: string };
}

const { lang, csrfToken, rows, zones, message } = Astro.props;
const messageText = message ? t(lang, message.key) : undefined;
---

<AdminLayout lang={lang} title={t(lang, 'admin.roles.meta.title')} description={t(lang, 'admin.roles.meta.description')}>
  <div class="admin-page">
    <p><a href="/admin">{t(lang, 'admin.roles.backToConsole')}</a></p>
    <h1>{t(lang, 'admin.roles.heading')}</h1>

    {
      messageText && (
        <Banner kind={message!.kind === 'error' ? 'error' : 'notice'} lang={lang}>
          {messageText}
        </Banner>
      )
    }

    <Card>
      <h2>{t(lang, 'admin.roles.grant.heading')}</h2>
      <form method="post" action="/admin/roles" class="grant-form">
        <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
        <input type="hidden" name="formAction" value="grant" />
        <FormField label={t(lang, 'admin.roles.grant.lookupLabel')} name="lookup" required lang={lang} />
        <div class="form-field">
          <label class="form-label" for="grant-role">
            {t(lang, 'admin.roles.grant.roleLabel')}
          </label>
          <select id="grant-role" class="form-input" name="role">
            <option value="curator">{t(lang, 'admin.roles.grant.roleCurator')}</option>
            <option value="admin">{t(lang, 'admin.roles.grant.roleAdmin')}</option>
          </select>
        </div>
        <label class="checkbox">
          <input type="checkbox" name="confirm" required />
          {t(lang, 'admin.roles.grant.confirmLabel')}
        </label>
        <Button type="submit" variant="primary" lang={lang}>
          {t(lang, 'admin.roles.grant.submit')}
        </Button>
      </form>
    </Card>

    <Card>
      <h2>{t(lang, 'admin.roles.list.heading')}</h2>
      {
        rows.length === 0 ? (
          <p class="placeholder-note">{t(lang, 'admin.roles.list.empty')}</p>
        ) : (
          <div class="table-scroll">
            <table class="dense-table">
              <thead>
                <tr>
                  <th>{t(lang, 'admin.roles.list.colId')}</th>
                  <th>{t(lang, 'admin.roles.list.colEmail')}</th>
                  <th>{t(lang, 'admin.roles.list.colRole')}</th>
                  <th>{t(lang, 'admin.roles.list.colWards')}</th>
                </tr>
              </thead>
              <tbody>
                {rows.map((row) => (
                  <tr>
                    <td>{row.id}</td>
                    <td>{row.email ?? '—'}</td>
                    <td>{row.role === 'admin' ? t(lang, 'admin.roles.list.roleAdmin') : t(lang, 'admin.roles.list.roleCurator')}</td>
                    <td>{row.role === 'admin' ? t(lang, 'admin.roles.list.cityWide') : `${row.wards.length} — ${row.wards.map((w) => w.nameEn).join(', ')}`}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )
      }
    </Card>

    <Card>
      <h2>{t(lang, 'admin.roles.manage.heading')}</h2>
      {
        rows.length === 0 ? (
          <p class="placeholder-note">{t(lang, 'admin.roles.manage.empty')}</p>
        ) : (
          <ul class="manage-list">
            {rows.map((row) => (
              <li class="manage-row">
                <p class="manage-row-title">
                  {row.email ?? `#${row.id}`} — {row.role === 'admin' ? t(lang, 'admin.roles.list.roleAdmin') : t(lang, 'admin.roles.list.roleCurator')}
                </p>

                <form method="post" action="/admin/roles" class="revoke-form">
                  <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
                  <input type="hidden" name="formAction" value="revoke" />
                  <input type="hidden" name="targetUserId" value={row.id} />
                  <label class="checkbox">
                    <input type="checkbox" name="confirm" required />
                    {t(lang, 'admin.roles.manage.revoke.confirmLabel', { email: row.email ?? String(row.id) })}
                  </label>
                  <Button type="submit" variant="destructive" lang={lang}>
                    {t(lang, 'admin.roles.manage.revoke.submit')}
                  </Button>
                </form>

                {
                  row.role === 'curator' && (
                    <form method="post" action="/admin/roles" class="scope-form">
                      <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
                      <input type="hidden" name="formAction" value="set_scope" />
                      <input type="hidden" name="targetUserId" value={row.id} />
                      <FormField
                        label={t(lang, 'admin.roles.manage.scope.wardIdsLabel')}
                        name="wardIds"
                        helper={t(lang, 'admin.roles.manage.scope.wardIdsHelper')}
                        value={row.wards.map((w) => w.id).join(', ')}
                        lang={lang}
                      />
                      <div class="form-field">
                        <label class="form-label" for={`scope-zone-${row.id}`}>
                          {t(lang, 'admin.roles.manage.scope.zoneLabel')}
                        </label>
                        <select id={`scope-zone-${row.id}`} class="form-input" name="zone">
                          <option value="">{t(lang, 'admin.roles.manage.scope.zoneNone')}</option>
                          {zones.map((zone) => (
                            <option value={zone}>{zone}</option>
                          ))}
                        </select>
                      </div>
                      <label class="checkbox">
                        <input type="checkbox" name="confirm" required />
                        {t(lang, 'admin.roles.manage.scope.confirmLabel', { email: row.email ?? String(row.id) })}
                      </label>
                      <Button type="submit" variant="secondary" lang={lang}>
                        {t(lang, 'admin.roles.manage.scope.submit')}
                      </Button>
                    </form>
                  )
                }
              </li>
            ))}
          </ul>
        )
      }
    </Card>
  </div>
</AdminLayout>

<style>
  .admin-page {
    max-width: var(--container-app);
    margin-inline: auto;
    padding-block: var(--space-8);
    padding-inline: var(--container-pad-x);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .admin-page h1 {
    font-size: var(--text-2xl);
    line-height: var(--leading-2xl);
    margin: 0;
  }

  .admin-page h2 {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-3);
  }

  .placeholder-note {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-style: italic;
  }

  .grant-form,
  .revoke-form,
  .scope-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    max-width: 32rem;
  }

  .form-field {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .form-label {
    font-size: var(--text-sm);
    font-weight: 700;
  }

  .form-input {
    min-height: 44px;
    padding: var(--space-2) var(--space-3);
    font-size: var(--text-base);
    font-family: var(--font-body);
    color: var(--color-text);
    background: var(--color-bg);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-sm);
  }

  .checkbox {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-base);
  }

  /* Dense table (design-system.md §7.13): --text-sm default, 8px cell
     padding, zebra rows, sticky header. */
  .table-scroll {
    overflow-x: auto;
  }

  .dense-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .dense-table th,
  .dense-table td {
    text-align: left;
    padding: 8px;
    border-bottom: 1px solid var(--color-border);
  }

  .dense-table thead th {
    position: sticky;
    top: 0;
    background: var(--color-bg);
  }

  .dense-table tbody tr:nth-child(odd) {
    background: var(--color-surface);
  }

  .manage-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .manage-row {
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
  }

  .manage-row-title {
    margin: 0;
    font-weight: 700;
  }
</style>
