---
/**
 * `/admin/audit` (Task 47, information-architecture.md §6.5; architecture.md
 * §7 "Audit ROLLBACK"; PRD §11). The audit-log viewer: every published
 * change, who made it, from which source, and when — filterable by entity
 * type, ward, and actor, paginated newest-first — plus a per-entry
 * "Restore this value" action for RESTORABLE entries only
 * (`src/lib/audit-restore.ts`'s `isRestorable` — currently just
 * `candidate_field` entries with a non-null `oldValue`).
 *
 * FORWARD-WRITE, NEVER A HISTORY EDIT: restore is presented (confirmation
 * checkbox label, and the post-restore notice) as "publish the old value
 * forward as a new change" — never as "undo" or "revert to" wording that
 * could imply history itself changes. See src/lib/audit-restore.ts's module
 * docstring for the actual mechanics.
 *
 * FILTERS ARE A GET (bookmarkable/shareable, same convention as
 * src/features/pages/admin/Users.astro's search box): entityType, wardId,
 * actorUserId, limit, offset all round-trip through the query string; the
 * route twin reads them and calls `listAuditEntries`. RESTORE is the only
 * POST this page issues.
 */
import AdminLayout from '../../../layouts/AdminLayout.astro';
import Card from '../../../components/Card.astro';
import Banner from '../../../components/Banner.astro';
import Button from '../../../components/Button.astro';
import FormField from '../../../components/FormField.astro';
import { t, type Lang } from '../../../i18n';
import { CSRF_FIELD_NAME } from '../../../lib/csrf';
import { isRestorable, type AuditEntryRow } from '../../../lib/audit-restore';

export interface AuditViewerFilters {
  entityType?: string;
  wardId?: number;
  actorUserId?: number;
  limit: number;
  offset: number;
}

interface Props {
  lang: Lang;
  csrfToken: string;
  entries: AuditEntryRow[];
  total: number;
  filters: AuditViewerFilters;
  message?: { kind: 'notice' | 'error'; key: string };
}

const { lang, csrfToken, entries, total, filters, message } = Astro.props;
const messageText = message ? t(lang, message.key) : undefined;

/** Renders a JSON audit value as a short human-readable summary — prefers valueEn/valueKn when present (the common candidate_field shape). */
function summarizeValue(value: unknown): string {
  if (value === null || value === undefined) return t(lang, 'admin.audit.list.noSource') || '—';
  if (typeof value === 'string') return value;
  if (typeof value === 'number' || typeof value === 'boolean') return String(value);
  if (Array.isArray(value)) return value.length === 0 ? '—' : value.map(String).join(', ');
  if (typeof value === 'object') {
    const obj = value as Record<string, unknown>;
    if (typeof obj.valueEn === 'string' || typeof obj.valueKn === 'string') {
      const en = typeof obj.valueEn === 'string' ? obj.valueEn : '';
      const kn = typeof obj.valueKn === 'string' ? obj.valueKn : '';
      const joined = [en, kn].filter((part) => part.length > 0).join(' / ');
      return joined.length > 0 ? joined : '—';
    }
    return JSON.stringify(obj);
  }
  return String(value);
}

function truncate(text: string, max = 60): string {
  return text.length > max ? `${text.slice(0, max)}…` : text;
}

function actorDisplay(entry: AuditEntryRow): string {
  if (entry.actorUserId === null) return t(lang, 'admin.audit.list.systemActor');
  return `#${entry.actorUserId} (${entry.actorRole})`;
}

/** Query string for a pagination/filter link, keeping the CURRENT filters and overriding just what's given. */
function buildQuery(overrides: Record<string, string | number | undefined>): string {
  const params = new URLSearchParams();
  if (filters.entityType) params.set('entityType', filters.entityType);
  if (filters.wardId !== undefined) params.set('wardId', String(filters.wardId));
  if (filters.actorUserId !== undefined) params.set('actorUserId', String(filters.actorUserId));
  params.set('limit', String(filters.limit));
  params.set('offset', String(filters.offset));
  for (const [key, value] of Object.entries(overrides)) {
    if (value === undefined) params.delete(key);
    else params.set(key, String(value));
  }
  return `?${params.toString()}`;
}

const from = total === 0 ? 0 : filters.offset + 1;
const to = Math.min(filters.offset + filters.limit, total);
const hasPrev = filters.offset > 0;
const hasNext = filters.offset + filters.limit < total;
const prevOffset = Math.max(0, filters.offset - filters.limit);
const nextOffset = filters.offset + filters.limit;
---

<AdminLayout lang={lang} title={t(lang, 'admin.audit.meta.title')} description={t(lang, 'admin.audit.meta.description')}>
  <div class="admin-page">
    <p><a href="/admin">{t(lang, 'admin.audit.backToConsole')}</a></p>
    <h1>{t(lang, 'admin.audit.heading')}</h1>

    {
      messageText && (
        <Banner kind={message!.kind === 'error' ? 'error' : 'notice'} lang={lang}>
          {messageText}
        </Banner>
      )
    }

    <Card>
      <h2>{t(lang, 'admin.audit.filters.heading')}</h2>
      <form method="get" action="/admin/audit" class="filters-form">
        <FormField label={t(lang, 'admin.audit.filters.entityTypeLabel')} name="entityType" value={filters.entityType ?? ''} lang={lang} />
        <FormField
          label={t(lang, 'admin.audit.filters.wardIdLabel')}
          name="wardId"
          type="number"
          value={filters.wardId !== undefined ? String(filters.wardId) : ''}
          lang={lang}
        />
        <FormField
          label={t(lang, 'admin.audit.filters.actorUserIdLabel')}
          name="actorUserId"
          type="number"
          value={filters.actorUserId !== undefined ? String(filters.actorUserId) : ''}
          lang={lang}
        />
        <div class="filters-actions">
          <Button type="submit" variant="primary" lang={lang}>
            {t(lang, 'admin.audit.filters.submit')}
          </Button>
          <a href="/admin/audit">{t(lang, 'admin.audit.filters.clear')}</a>
        </div>
      </form>
    </Card>

    <Card>
      <h2>{t(lang, 'admin.audit.list.heading')}</h2>
      {
        entries.length === 0 ? (
          <p class="placeholder-note">{t(lang, 'admin.audit.list.empty')}</p>
        ) : (
          <>
            <div class="table-scroll">
              <table class="dense-table">
                <thead>
                  <tr>
                    <th>{t(lang, 'admin.audit.list.colCreatedAt')}</th>
                    <th>{t(lang, 'admin.audit.list.colActor')}</th>
                    <th>{t(lang, 'admin.audit.list.colAction')}</th>
                    <th>{t(lang, 'admin.audit.list.colEntity')}</th>
                    <th>{t(lang, 'admin.audit.list.colWard')}</th>
                    <th>{t(lang, 'admin.audit.list.colField')}</th>
                    <th>{t(lang, 'admin.audit.list.colChange')}</th>
                    <th>{t(lang, 'admin.audit.list.colSource')}</th>
                    <th>{t(lang, 'admin.audit.list.colRestore')}</th>
                  </tr>
                </thead>
                <tbody>
                  {entries.map((entry) => (
                    <tr>
                      <td>{entry.createdAt.toISOString()}</td>
                      <td>{actorDisplay(entry)}</td>
                      <td>{entry.action}</td>
                      <td>
                        {entry.entityType}:{entry.entityId}
                      </td>
                      <td>{entry.wardId ?? t(lang, 'admin.audit.list.noWard')}</td>
                      <td>{entry.fieldKey ?? '—'}</td>
                      <td>
                        {truncate(summarizeValue(entry.oldValue))} → {truncate(summarizeValue(entry.newValue))}
                      </td>
                      <td>
                        {entry.sourceUrl ? (
                          <a href={entry.sourceUrl} target="_blank" rel="noopener noreferrer">
                            {t(lang, 'admin.audit.list.viewSource')}
                          </a>
                        ) : (
                          t(lang, 'admin.audit.list.noSource')
                        )}
                      </td>
                      <td>
                        {isRestorable(entry) && (
                          <form method="post" action="/admin/audit" class="restore-form">
                            <input type="hidden" name={CSRF_FIELD_NAME} value={csrfToken} />
                            <input type="hidden" name="formAction" value="restore" />
                            <input type="hidden" name="auditId" value={entry.id} />
                            <input type="hidden" name="entityType" value={filters.entityType ?? ''} />
                            <input type="hidden" name="wardId" value={filters.wardId ?? ''} />
                            <input type="hidden" name="actorUserId" value={filters.actorUserId ?? ''} />
                            <input type="hidden" name="limit" value={filters.limit} />
                            <input type="hidden" name="offset" value={filters.offset} />
                            <label class="checkbox">
                              <input type="checkbox" name="confirm" required />
                              {t(lang, 'admin.audit.restore.confirmLabel')}
                            </label>
                            <Button type="submit" variant="secondary" lang={lang}>
                              {t(lang, 'admin.audit.restore.submit')}
                            </Button>
                          </form>
                        )}
                      </td>
                    </tr>
                  ))}
                </tbody>
              </table>
            </div>

            <div class="pagination">
              <p>{t(lang, 'admin.audit.pagination.summary', { from: String(from), to: String(to), total: String(total) })}</p>
              <div class="pagination-links">
                {hasPrev ? (
                  <a href={buildQuery({ offset: prevOffset })}>{t(lang, 'admin.audit.pagination.prev')}</a>
                ) : (
                  <span class="pagination-disabled">{t(lang, 'admin.audit.pagination.prev')}</span>
                )}
                {hasNext ? (
                  <a href={buildQuery({ offset: nextOffset })}>{t(lang, 'admin.audit.pagination.next')}</a>
                ) : (
                  <span class="pagination-disabled">{t(lang, 'admin.audit.pagination.next')}</span>
                )}
              </div>
            </div>
          </>
        )
      }
    </Card>
  </div>
</AdminLayout>

<style>
  .admin-page {
    max-width: var(--container-wide, 72rem);
    margin-inline: auto;
    padding-block: var(--space-8);
    padding-inline: var(--container-pad-x);
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .admin-page h1 {
    font-size: var(--text-2xl);
    line-height: var(--leading-2xl);
    margin: 0;
  }

  .admin-page h2 {
    font-size: var(--text-lg);
    margin: 0 0 var(--space-3);
  }

  .placeholder-note {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-sm);
    font-style: italic;
  }

  .filters-form {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    gap: var(--space-3);
  }

  .filters-actions {
    display: flex;
    align-items: center;
    gap: var(--space-3);
  }

  .checkbox {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    font-size: var(--text-sm);
  }

  .table-scroll {
    overflow-x: auto;
  }

  .dense-table {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--text-sm);
  }

  .dense-table th,
  .dense-table td {
    text-align: left;
    padding: 8px;
    border-bottom: 1px solid var(--color-border);
    vertical-align: top;
  }

  .dense-table thead th {
    position: sticky;
    top: 0;
    background: var(--color-bg);
  }

  .dense-table tbody tr:nth-child(odd) {
    background: var(--color-surface);
  }

  .restore-form {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    min-width: 14rem;
  }

  .pagination {
    margin-top: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .pagination p {
    margin: 0;
    font-size: var(--text-sm);
    color: var(--color-text-muted);
  }

  .pagination-links {
    display: flex;
    gap: var(--space-4);
  }

  .pagination-disabled {
    color: var(--color-text-muted);
  }
</style>
