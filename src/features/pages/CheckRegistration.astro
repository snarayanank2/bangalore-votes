---
/**
 * Check registration (`/check-registration`, `/kn/check-registration`) —
 * information-architecture.md §3.7, PRD §5.6.
 *
 * Renders the Task 8 `check-registration` content entry inside Prose, with
 * the eligibility basics ("## Am I eligible...") appearing BEFORE the
 * guided link-out button, matching the content's own document order and
 * its embedded (now-stripped) `<!-- INPUT NEEDED -->` marker, which sits at
 * the end of the "## How do I check my registration status?" section —
 * see splitMarkdownSections's header for why this splits by HEADING COUNT
 * rather than matching marker/heading text.
 *
 * The button's href comes from app_settings' `roll_lookup_url` key
 * (INPUT NEEDED, dependency register §4.8) — never invented. Absent ->
 * ExternalLinkOut renders the pending-note placeholder instead.
 *
 * CACHE-SAFETY: only reads app_settings (global, same for every visitor,
 * same rule as Home's election-status/roll-deadline read) — no
 * cookie/session access, safe under the anonymous-page micro-cache.
 */
import Prose from '../../layouts/Prose.astro';
import DeadlineBanner from '../../components/DeadlineBanner.astro';
import ExternalLinkOut from '../../components/ExternalLinkOut.astro';
import { t, type Lang } from '../../i18n';
import { getPageContent } from '../../i18n/content';
import { renderContentHtml, splitMarkdownSections } from '../../lib/render-content';
import { getSettings } from '../../lib/settings';

interface Props {
  lang: Lang;
}

const { lang } = Astro.props;

const content = getPageContent(lang, 'check-registration');
if (!content) {
  throw new Error('CheckRegistration: missing content/pages/en/check-registration.md');
}

const sections = splitMarkdownSections(content.body);
// [preamble, "## Am I eligible...", "## How do I check...", "## What if I'm not on the roll..."]
const beforeLinkOut = sections.slice(0, 3).join('');
const afterLinkOut = sections.slice(3).join('');

const settings = await getSettings(['roll_deadline', 'roll_lookup_url']);
const rollDeadline = settings.roll_deadline;
const rollDeadlineActive = rollDeadline
  ? new Date(`${rollDeadline}T23:59:59Z`).getTime() >= Date.now()
  : false;
---

<Prose lang={lang} title={content.title} description={content.description} path="/check-registration">
  {rollDeadlineActive && rollDeadline && <DeadlineBanner deadlineISO={rollDeadline} lang={lang} />}

  <div set:html={renderContentHtml(beforeLinkOut, lang)} />

  <ExternalLinkOut lang={lang} href={settings.roll_lookup_url} label={t(lang, 'checkRegistration.linkOut.label')} />

  <div set:html={renderContentHtml(afterLinkOut, lang)} />
</Prose>
