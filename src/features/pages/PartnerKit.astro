---
/**
 * Partner kit (`/partner/{slug}`, `/kn/partner/{slug}`) — Task 48, IA
 * §3.19, PRD §5.12, gtm-plan.md §5. An unlisted, anonymous-access page
 * equipping an EXISTING distribution partner (an RWA, a civic org) to
 * forward the platform into their own network. Partners are NOT a role
 * (PRD §5.12, re-asserted in src/lib/partners.ts's own module docstring): a
 * `partners` row is purely a slug used for outbound-link attribution and
 * this kit page — it carries no permissions, and this page needs no
 * session at all.
 *
 * Existence check lives in the route twins (src/pages/partner/[slug].astro,
 * src/pages/kn/partner/[slug].astro), same convention as Candidate.astro —
 * only a page-level frontmatter script can end an Astro request early with
 * a real 404, so an UNKNOWN slug never actually reaches this component in
 * production. The lookup below is guarded anyway (renders EmptyState
 * rather than throwing) purely as a defensive belt-and-braces measure.
 *
 * THE COPY BLOCKS ARE THE CONTENT (IA §3.19's own note): "the unit of
 * distribution is a message pasted into an apartment WhatsApp group, so the
 * copy blocks matter more than the page design." Every WhatsApp forward
 * text below renders in BOTH languages on EVERY language variant of this
 * page — a partner reading the EN page can still grab the KN text to
 * forward into a Kannada-speaking group, and vice versa. `t()` is called
 * below with an explicit `'en'`/`'kn'` literal for each forward-text block
 * (never this page's own `lang` prop) precisely so both copies always
 * render regardless of which URL loaded.
 *
 * TAGGED LINK (PRD §5.12): `{SITE_ORIGIN}/?src={slug}` — ONE canonical link
 * for both languages (attribution survives to registration regardless of
 * which language the visitor eventually registers in, so there is no
 * separate "Kannada tagged link"). The first-time-voter forward text
 * instead points at the LOCALIZED `/voting-guide` checklist (IA §5.17)
 * carrying the same `?src` param, since THAT link's language does matter —
 * a Kannada forward should land a Kannada reader on the Kannada checklist,
 * not the English one.
 *
 * NO-JS-SAFE COPY (progressive enhancement only, IA §3.19): every copy
 * block below is a real readonly `<input>`/`<textarea>` that already works
 * with zero JS (select-all + Ctrl/Cmd+C). src/islands/CopyButton.ts's
 * `initCopyButtons()` only adds a one-tap `navigator.clipboard` shortcut on
 * top, wired from this page's own plain (non-inline, bundled-and-hashed)
 * `<script>` import — same pattern as FindBooth.astro's `initBoothLookup`.
 * This deliberately never uses an inline nonce'd script: that would embed
 * the request's per-response CSP nonce (`locals.cspNonce`,
 * src/middleware.ts) into the HTML itself, making the page vary per
 * request and breaking the cache-safety this page otherwise has.
 *
 * CACHE-SAFETY (architecture.md §5): this component never reads
 * cookies/session — the page is identical for every visitor, keyed only by
 * `slug` (same convention as Candidate.astro). Every absolute URL here is
 * derived from `Astro.site`, never the request Host.
 *
 * NOINDEX (IA §3.19: "unlisted" — not indexed, not linked from nav, but NOT
 * access-controlled): src/middleware.ts's `NOINDEX_PREFIXES` already sets
 * `X-Robots-Tag: noindex` on every `/partner/*` response (Task 26); Base's
 * `noindex` prop additionally renders `<meta name="robots" content="noindex">`
 * here so the same signal survives even against a downstream cache/CDN that
 * strips response headers.
 *
 * PRINT STYLES (design-system.md §11 — the ONE page in this system where
 * print matters): scoped to `.poster-block` only ("print styles matter for
 * one page: `/partner/{slug}`'s poster block. Everything else can rely on
 * defaults.") — an `@media print` rule below hides the surrounding chrome
 * (nav, headings, copy buttons) so printing the page yields a clean poster,
 * and gives the poster block itself full-bleed sizing for print.
 */
import Base from '../../layouts/Base.astro';
import Card from '../../components/Card.astro';
import EmptyState from '../../components/EmptyState.astro';
import { t, localePath, type Lang } from '../../i18n';
import { db } from '../../db/client';
import { partners } from '../../db/schema';
import { eq } from 'drizzle-orm';

interface Props {
  lang: Lang;
  slug: string;
}

const { lang, slug } = Astro.props;

const [row] = await db
  .select({ id: partners.id, slug: partners.slug, name: partners.name })
  .from(partners)
  .where(eq(partners.slug, slug));

// Astro.site is always configured (astro.config.mjs falls back to the
// production origin when SITE_ORIGIN is unset) — same convention as
// Base.astro/Candidate.astro; the local fallback here only satisfies
// strict typing and is never reached against the request's Host.
const siteOrigin = Astro.site ?? new URL('https://bangalore-votes.opencity.in');

const taggedLink = new URL(`/?src=${encodeURIComponent(slug)}`, siteOrigin).href;
const votingGuideLink = {
  en: new URL(`${localePath('en', '/voting-guide')}?src=${encodeURIComponent(slug)}`, siteOrigin).href,
  kn: new URL(`${localePath('kn', '/voting-guide')}?src=${encodeURIComponent(slug)}`, siteOrigin).href,
};

const pagePath = `/partner/${slug}`;
const title = row ? t(lang, 'partnerKit.meta.title', { name: row.name }) : t(lang, 'partnerKit.notFound.fact');
const description = row
  ? t(lang, 'partnerKit.meta.description', { name: row.name })
  : t(lang, 'partnerKit.notFound.fact');

interface ForwardText {
  langKey: 'en' | 'kn';
  langLabel: string;
  id: string;
  value: string;
}

interface ForwardBlock {
  key: string;
  heading: string;
  texts: ForwardText[];
}

const forwardBlocks: ForwardBlock[] = row
  ? [
      {
        key: 'general',
        heading: t(lang, 'partnerKit.forward.general.heading'),
        texts: (['en', 'kn'] as const).map((langKey) => ({
          langKey,
          langLabel: t(lang, `partnerKit.langLabel.${langKey}`),
          id: `forward-general-${langKey}`,
          value: t(langKey, 'partnerKit.forward.general.body', { link: taggedLink }),
        })),
      },
      {
        key: 'firstTimeVoter',
        heading: t(lang, 'partnerKit.forward.firstTimeVoter.heading'),
        texts: (['en', 'kn'] as const).map((langKey) => ({
          langKey,
          langLabel: t(lang, `partnerKit.langLabel.${langKey}`),
          id: `forward-firsttime-${langKey}`,
          value: t(langKey, 'partnerKit.forward.firstTimeVoter.body', { link: votingGuideLink[langKey] }),
        })),
      },
    ]
  : [];
---

<Base lang={lang} title={title} description={description} path={pagePath} noindex>
  {
    row ? (
      <div class="partner-kit">
        <header class="kit-header">
          <h1>{t(lang, 'partnerKit.heading', { name: row.name })}</h1>
          <p class="intro">{t(lang, 'partnerKit.intro')}</p>
        </header>

        <Card>
          <section class="tagged-link" aria-labelledby="tagged-link-heading">
            <h2 id="tagged-link-heading">{t(lang, 'partnerKit.taggedLink.heading')}</h2>
            <p class="helper">{t(lang, 'partnerKit.taggedLink.helper')}</p>
            <div class="copy-row">
              <input
                id="tagged-link-input"
                class="copy-field"
                type="text"
                readonly
                value={taggedLink}
                aria-label={t(lang, 'partnerKit.taggedLink.heading')}
              />
              <button
                type="button"
                class="btn btn--secondary copy-btn"
                data-copy-button
                data-copy-target="tagged-link-input"
                data-copy-label-copied={t(lang, 'partnerKit.copiedLabel')}
              >
                {t(lang, 'partnerKit.copyButton')}
              </button>
            </div>
          </section>
        </Card>

        <section class="forward-texts" aria-labelledby="forward-heading">
          <h2 id="forward-heading">{t(lang, 'partnerKit.forward.sectionHeading')}</h2>
          {forwardBlocks.map((block) => (
            <Card>
              <h3>{block.heading}</h3>
              <div class="forward-pair">
                {block.texts.map((text) => (
                  <div class="copy-block">
                    <label for={text.id}>{text.langLabel}</label>
                    <textarea id={text.id} class="copy-field" readonly rows={4} lang={text.langKey}>{text.value}</textarea>
                    <button
                      type="button"
                      class="btn btn--tertiary copy-btn"
                      data-copy-button
                      data-copy-target={text.id}
                      data-copy-label-copied={t(lang, 'partnerKit.copiedLabel')}
                    >
                      {t(lang, 'partnerKit.copyButton')}
                    </button>
                  </div>
                ))}
              </div>
            </Card>
          ))}
        </section>

        <section class="poster-section" aria-labelledby="poster-heading">
          <h2 id="poster-heading">{t(lang, 'partnerKit.poster.heading')}</h2>
          <div class="poster-block">
            <p class="poster-pending">{t(lang, 'partnerKit.poster.pendingNote')}</p>
          </div>
        </section>

        <Card>
          <section class="neutrality" aria-labelledby="neutrality-heading">
            <h2 id="neutrality-heading">{t(lang, 'partnerKit.neutrality.heading')}</h2>
            <p>{t(lang, 'partnerKit.neutrality.statement')}</p>
          </section>
        </Card>

        <p class="sr-only" id="copy-status" role="status" aria-live="polite" />
      </div>
    ) : (
      <EmptyState fact={t(lang, 'partnerKit.notFound.fact')} />
    )
  }
</Base>

<script>
  import { initCopyButtons } from '../../islands/CopyButton';
  initCopyButtons();
</script>

<style>
  .partner-kit {
    max-width: var(--container-app);
    margin-inline: auto;
    padding: var(--space-8) var(--container-pad-x);
    display: flex;
    flex-direction: column;
    gap: var(--space-6);
  }

  .kit-header h1 {
    font-family: var(--font-heading);
    font-size: var(--text-3xl);
    line-height: var(--leading-3xl);
    margin: 0 0 var(--space-2);
  }

  .intro {
    margin: 0;
    color: var(--color-text-muted);
    font-size: var(--text-base);
  }

  h2 {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    margin: 0 0 var(--space-2);
  }

  h3 {
    font-family: var(--font-heading);
    font-size: var(--text-lg);
    margin: 0 0 var(--space-2);
  }

  .helper {
    margin: 0 0 var(--space-3);
    color: var(--color-text-muted);
    font-size: var(--text-sm);
  }

  .copy-row {
    display: flex;
    gap: var(--space-2);
    flex-wrap: wrap;
  }

  .copy-field {
    flex: 1 1 260px;
    min-width: 0;
    font-family: var(--font-body, inherit);
    font-size: var(--text-base);
    padding: var(--space-2) var(--space-3);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    background: var(--color-surface);
    color: var(--color-text);
  }

  textarea.copy-field {
    width: 100%;
    resize: vertical;
  }

  .forward-texts {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .forward-pair {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
  }

  .copy-block {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .copy-block label {
    font-size: var(--text-sm);
    font-weight: 700;
    color: var(--color-text-muted);
  }

  .poster-block {
    border: 1px dashed var(--color-border);
    border-radius: var(--radius-md);
    padding: var(--space-8);
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-surface);
    aspect-ratio: 4 / 5;
    max-width: 320px;
  }

  .poster-pending {
    margin: 0;
    text-align: center;
    font-style: italic;
    color: var(--color-text-muted);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  /*
   * Print styles (design-system.md §11): scoped to .poster-block only —
   * this is the one page in this system where print matters. Hide every
   * other section (the header, tagged-link/forward-text copy blocks, the
   * neutrality card, and every button) so printing this page yields a
   * clean poster rather than a jumble of UI chrome.
   */
  @media print {
    .kit-header,
    .tagged-link,
    .forward-texts,
    .neutrality,
    .btn {
      display: none;
    }

    .poster-block {
      border: none;
      aspect-ratio: auto;
      max-width: none;
      width: 100%;
      height: 100vh;
      page-break-inside: avoid;
    }
  }
</style>
