---
/**
 * Partner kit (`/kn/partner/{slug}`) — Kannada twin, see
 * src/pages/partner/[slug].astro for the full explanation of the 404
 * handling.
 */
import PartnerKit from '../../../features/pages/PartnerKit.astro';
import { db } from '../../../db/client';
import { partners } from '../../../db/schema';
import { eq } from 'drizzle-orm';

const slug = Astro.params.slug;

if (!slug) {
  return new Response(null, { status: 404 });
}

const [exists] = await db.select({ id: partners.id }).from(partners).where(eq(partners.slug, slug));
if (!exists) {
  return new Response(null, { status: 404 });
}
---

<PartnerKit lang="kn" slug={slug} />
