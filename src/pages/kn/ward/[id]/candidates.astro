---
/**
 * Candidates-in-ward list (`/kn/ward/{id}/candidates`) — Kannada twin, see
 * src/pages/ward/[id]/candidates.astro for the full explanation of the 404
 * handling.
 */
import WardCandidates from '../../../../features/pages/WardCandidates.astro';
import { db } from '../../../../db/client';
import { wards } from '../../../../db/schema';
import { eq } from 'drizzle-orm';

const idParam = Astro.params.id;
const wardId = Number(idParam);

if (!idParam || !Number.isInteger(wardId)) {
  return new Response(null, { status: 404 });
}

const [exists] = await db.select({ id: wards.id }).from(wards).where(eq(wards.id, wardId));
if (!exists) {
  return new Response(null, { status: 404 });
}
---

<WardCandidates lang="kn" wardId={wardId} />
