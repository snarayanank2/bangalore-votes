---
/**
 * `/kn/account` — Kannada twin, see src/pages/account/index.astro for the
 * full explanation.
 */
import Account from '../../../features/pages/Account.astro';
import { handleAccountPost, loadAccountState, type AccountRenderState } from '../../../lib/account-flow';
import { destroySession, clearSessionCookie, SESSION_COOKIE } from '../../../lib/session';

const session = Astro.locals.session;
if (!session) {
  return Astro.redirect(`/login?next=${encodeURIComponent('/kn/account')}`);
}

let state: AccountRenderState | null = await loadAccountState(session.userId);
if (!state) {
  return Astro.redirect(`/login?next=${encodeURIComponent('/kn/account')}`);
}

if (Astro.request.method === 'POST') {
  Astro.response.headers.set('cache-control', 'no-store');

  const form = await Astro.request.formData();
  const outcome = await handleAccountPost(session.userId, form);

  if (outcome.kind === 'signout') {
    const cookieValue = Astro.cookies.get(SESSION_COOKIE)?.value;
    if (cookieValue) await destroySession(cookieValue);
    return new Response(null, {
      status: 302,
      headers: {
        Location: '/',
        'Set-Cookie': clearSessionCookie(),
        'cache-control': 'no-store',
      },
    });
  }

  state = outcome.state;
}

Astro.response.headers.set('cache-control', 'no-store');
---

<Account lang="kn" state={state} csrfToken={Astro.locals.csrfToken} />
