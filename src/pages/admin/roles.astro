---
/**
 * `/admin/roles` — see src/features/pages/admin/Roles.astro for the
 * presentational side. This route twin owns the HTTP concerns a plain
 * component cannot: dispatching the three POST form actions (`grant`,
 * `revoke`, `set_scope`) to src/lib/admin.ts, the ZONE-SHORTCUT UNION
 * (parsing the comma-separated `wardIds` text field, expanding the chosen
 * `zone` via `expandZoneToWards`, and merging the two id sets BEFORE
 * calling `setCuratorScope` — see that function's docstring: it has no
 * notion of zones itself), and no-store on every response.
 *
 * src/middleware.ts already 403s any non-admin session and redirects an
 * anonymous request to /login before this ever runs; the actor handed to
 * every src/lib/admin.ts mutator is therefore always `role: 'admin'` in
 * practice — the `assertAdmin` re-check inside those mutators is defense
 * in depth, not something this route expects to ever trip.
 */
import Roles from '../../features/pages/admin/Roles.astro';
import {
  expandZoneToWards,
  findUserIdByLookup,
  grantRole,
  listCuratorsAndScopes,
  listZones,
  revokeRole,
  setCuratorScope,
  type AdminActor,
} from '../../lib/admin';
import { loadCuratorLang } from '../../lib/curator';

const session = Astro.locals.session!;
const actor: AdminActor = { userId: session.userId, role: 'admin' };

/** Maps a thrown Error's message to a user-facing i18n key, falling back to `fallbackKey` for anything unrecognized (including a defensive `'admin_only'`, which this route never expects to actually see — see module docstring). */
function errorKey(err: unknown, fallbackKey: string): string {
  const msg = err instanceof Error ? err.message : '';
  if (msg === 'user_not_found') return 'admin.roles.error.userNotFound';
  if (msg === 'invalid_ward_id') return 'admin.roles.error.invalidWardId';
  return fallbackKey;
}

/** Parses the scope form's comma-separated `wardIds` text field. `null` for any token that isn't a bare integer (the route responds 400 rather than silently dropping a typo'd id). */
function parseWardIdsText(text: string): number[] | null {
  const tokens = text
    .split(',')
    .map((t) => t.trim())
    .filter((t) => t.length > 0);
  const ids = tokens.map(Number);
  if (ids.some((n) => !Number.isInteger(n))) return null;
  return ids;
}

let message: { kind: 'notice' | 'error'; key: string } | undefined;
let responseStatus = 200;

if (Astro.request.method === 'POST') {
  Astro.response.headers.set('cache-control', 'no-store');
  const form = await Astro.request.formData();
  const formAction = String(form.get('formAction') ?? '');
  const confirmed = form.get('confirm') != null;

  if (formAction === 'grant') {
    if (!confirmed) {
      message = { kind: 'error', key: 'admin.roles.error.confirmRequired' };
      responseStatus = 400;
    } else {
      const lookup = String(form.get('lookup') ?? '');
      const role = String(form.get('role') ?? '') === 'admin' ? 'admin' : 'curator';
      const targetUserId = await findUserIdByLookup(lookup);
      if (targetUserId === null) {
        message = { kind: 'error', key: 'admin.roles.error.userNotFound' };
        responseStatus = 400;
      } else {
        try {
          await grantRole(actor, targetUserId, role);
          return new Response(null, { status: 302, headers: { Location: '/admin/roles', 'cache-control': 'no-store' } });
        } catch (err) {
          message = { kind: 'error', key: errorKey(err, 'admin.roles.error.userNotFound') };
          responseStatus = 400;
        }
      }
    }
  } else if (formAction === 'revoke') {
    const targetUserId = Number(form.get('targetUserId'));
    if (!Number.isInteger(targetUserId)) {
      return new Response(null, { status: 400, headers: { 'cache-control': 'no-store' } });
    }
    if (!confirmed) {
      message = { kind: 'error', key: 'admin.roles.error.confirmRequired' };
      responseStatus = 400;
    } else {
      try {
        await revokeRole(actor, targetUserId);
        return new Response(null, { status: 302, headers: { Location: '/admin/roles', 'cache-control': 'no-store' } });
      } catch (err) {
        message = { kind: 'error', key: errorKey(err, 'admin.roles.error.userNotFound') };
        responseStatus = 400;
      }
    }
  } else if (formAction === 'set_scope') {
    const targetUserId = Number(form.get('targetUserId'));
    if (!Number.isInteger(targetUserId)) {
      return new Response(null, { status: 400, headers: { 'cache-control': 'no-store' } });
    }
    if (!confirmed) {
      message = { kind: 'error', key: 'admin.roles.error.confirmRequired' };
      responseStatus = 400;
    } else {
      const manualIds = parseWardIdsText(String(form.get('wardIds') ?? ''));
      if (manualIds === null) {
        message = { kind: 'error', key: 'admin.roles.error.invalidWardId' };
        responseStatus = 400;
      } else {
        const zone = String(form.get('zone') ?? '').trim();
        // THE ZONE SHORTCUT (PRD §10): union the zone's wards into the
        // manually-typed set at save time — expandZoneToWards has no
        // memory of this choice; only the resulting per-ward rows persist.
        const zoneIds = zone ? await expandZoneToWards(zone) : [];
        const wardIds = [...new Set([...manualIds, ...zoneIds])];
        try {
          await setCuratorScope(actor, targetUserId, wardIds);
          return new Response(null, { status: 302, headers: { Location: '/admin/roles', 'cache-control': 'no-store' } });
        } catch (err) {
          message = { kind: 'error', key: errorKey(err, 'admin.roles.error.invalidWardId') };
          responseStatus = 400;
        }
      }
    }
  } else {
    return new Response(null, { status: 400, headers: { 'cache-control': 'no-store' } });
  }
}

const [rows, zones, lang] = await Promise.all([listCuratorsAndScopes(), listZones(), loadCuratorLang(session.userId)]);
Astro.response.headers.set('cache-control', 'no-store');
Astro.response.status = responseStatus;
---

<Roles lang={lang} csrfToken={Astro.locals.csrfToken} rows={rows} zones={zones} message={message} />
