---
/**
 * `/admin/audit` — see src/features/pages/admin/Audit.astro for the
 * presentational side. This route twin owns the HTTP concerns: parsing the
 * `?entityType=&wardId=&actorUserId=&limit=&offset=` GET filters into
 * src/lib/audit-restore.ts's `listAuditEntries` call, dispatching the single
 * POST form action (`restore`) to `restoreAuditEntry`, and no-store on every
 * response.
 *
 * src/middleware.ts already 403s any non-admin session and redirects an
 * anonymous request to /login before this ever runs; the actor handed to
 * `restoreAuditEntry` is therefore always `role: 'admin'` in practice — the
 * `assertAdmin` re-check inside it is defense in depth, not something this
 * route expects to ever trip.
 *
 * RESTORE SUCCESS NOTICE: unlike the other admin consoles' plain
 * redirect-with-no-message convention, the brief for this page specifically
 * asks for "a note that the value was restored" after a successful restore
 * (the value itself isn't otherwise visually distinguished from a normal
 * publish in the table). Carried across the redirect as a `?restored=1`
 * query flag alongside the preserved filters — this route reads it back on
 * the following GET and renders it as a `notice` banner.
 */
import Audit from '../../features/pages/admin/Audit.astro';
import { listAuditEntries, restoreAuditEntry, type AuditActor } from '../../lib/audit-restore';
import { loadCuratorLang } from '../../lib/curator';

const session = Astro.locals.session!;
const actor: AuditActor = { userId: session.userId, role: 'admin' };

const DEFAULT_LIMIT = 50;
const MAX_LIMIT = 200;

/** `null` for a blank/missing value, `undefined` for one that doesn't parse as a bare integer (caller decides how to handle each). */
function parseIntParam(raw: string | null): number | undefined {
  if (raw === null) return undefined;
  const trimmed = raw.trim();
  if (trimmed === '') return undefined;
  const n = Number(trimmed);
  return Number.isInteger(n) ? n : undefined;
}

/** Maps a thrown Error's message to a user-facing i18n key, falling back to `fallbackKey` for anything unrecognized. */
function errorKey(err: unknown, fallbackKey: string): string {
  const msg = err instanceof Error ? err.message : '';
  if (msg === 'not_restorable') return 'admin.audit.error.notRestorable';
  if (msg === 'audit_entry_not_found') return 'admin.audit.error.entryNotFound';
  return fallbackKey;
}

function buildRedirectQuery(fields: {
  entityType: string;
  wardId: string;
  actorUserId: string;
  limit: string;
  offset: string;
}): string {
  const params = new URLSearchParams();
  if (fields.entityType) params.set('entityType', fields.entityType);
  if (fields.wardId) params.set('wardId', fields.wardId);
  if (fields.actorUserId) params.set('actorUserId', fields.actorUserId);
  if (fields.limit) params.set('limit', fields.limit);
  if (fields.offset) params.set('offset', fields.offset);
  return params.toString();
}

let message: { kind: 'notice' | 'error'; key: string } | undefined;
let responseStatus = 200;

// Filters as they'll be rendered — overwritten by the POST's hidden fields
// below when this request IS a POST, so a rejected restore re-renders with
// the admin's same view rather than resetting to the unfiltered default.
let entityType: string | undefined = Astro.url.searchParams.get('entityType')?.trim() || undefined;
let wardId: number | undefined = parseIntParam(Astro.url.searchParams.get('wardId'));
let actorUserId: number | undefined = parseIntParam(Astro.url.searchParams.get('actorUserId'));
let limit = parseIntParam(Astro.url.searchParams.get('limit')) ?? DEFAULT_LIMIT;
let offset = parseIntParam(Astro.url.searchParams.get('offset')) ?? 0;
if (limit <= 0 || limit > MAX_LIMIT) limit = DEFAULT_LIMIT;
if (offset < 0) offset = 0;

if (Astro.request.method === 'POST') {
  Astro.response.headers.set('cache-control', 'no-store');
  const form = await Astro.request.formData();
  const formAction = String(form.get('formAction') ?? '');
  const confirmed = form.get('confirm') != null;

  // Restore the filters/pagination the admin was looking at (posted as
  // hidden fields by the per-row restore form) so a rejected restore, or
  // the post-restore redirect, returns to the SAME view.
  const formEntityType = String(form.get('entityType') ?? '').trim();
  const formWardId = String(form.get('wardId') ?? '').trim();
  const formActorUserId = String(form.get('actorUserId') ?? '').trim();
  const formLimit = String(form.get('limit') ?? '').trim();
  const formOffset = String(form.get('offset') ?? '').trim();

  entityType = formEntityType || undefined;
  wardId = parseIntParam(formWardId || null);
  actorUserId = parseIntParam(formActorUserId || null);
  const parsedLimit = parseIntParam(formLimit || null);
  const parsedOffset = parseIntParam(formOffset || null);
  limit = parsedLimit && parsedLimit > 0 && parsedLimit <= MAX_LIMIT ? parsedLimit : DEFAULT_LIMIT;
  offset = parsedOffset && parsedOffset > 0 ? parsedOffset : 0;

  if (formAction !== 'restore') {
    return new Response(null, { status: 400, headers: { 'cache-control': 'no-store' } });
  }

  const auditId = Number(form.get('auditId'));
  if (!Number.isInteger(auditId)) {
    return new Response(null, { status: 400, headers: { 'cache-control': 'no-store' } });
  }

  if (!confirmed) {
    message = { kind: 'error', key: 'admin.audit.error.confirmRequired' };
    responseStatus = 400;
  } else {
    try {
      await restoreAuditEntry(actor, auditId);
      const query = buildRedirectQuery({
        entityType: formEntityType,
        wardId: formWardId,
        actorUserId: formActorUserId,
        limit: formLimit,
        offset: formOffset,
      });
      const restoredQuery = query ? `${query}&restored=1` : 'restored=1';
      return new Response(null, {
        status: 302,
        headers: { Location: `/admin/audit?${restoredQuery}`, 'cache-control': 'no-store' },
      });
    } catch (err) {
      message = { kind: 'error', key: errorKey(err, 'admin.audit.error.notRestorable') };
      responseStatus = 400;
    }
  }
} else if (Astro.url.searchParams.get('restored') === '1') {
  message = { kind: 'notice', key: 'admin.audit.notice.restored' };
}

const [{ entries, total }, lang] = await Promise.all([
  listAuditEntries({ entityType, wardId, actorUserId, limit, offset }),
  loadCuratorLang(session.userId),
]);

Astro.response.headers.set('cache-control', 'no-store');
Astro.response.status = responseStatus;
---

<Audit
  lang={lang}
  csrfToken={Astro.locals.csrfToken}
  entries={entries}
  total={total}
  filters={{ entityType, wardId, actorUserId, limit, offset }}
  message={message}
/>
