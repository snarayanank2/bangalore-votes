---
/**
 * `/admin/partners` — see src/features/pages/admin/Partners.astro for the
 * presentational side. This route twin owns the HTTP concerns a plain
 * component cannot: dispatching the six POST form actions
 * (`create_partner`, `update_partner`, `override_hold`, `accept_awareness`,
 * `accept_curation`, `decline_eoi`) to src/lib/partners.ts, parsing the
 * comma-separated `wardIds` text field (same convention as
 * src/pages/admin/roles.astro's `parseWardIdsText`), and no-store on every
 * response.
 *
 * src/middleware.ts already 403s any non-admin session and redirects an
 * anonymous request to /login before this ever runs; the actor handed to
 * every src/lib/partners.ts mutator is therefore always `role: 'admin'` in
 * practice — the `assertAdmin` re-check inside those mutators is defense
 * in depth, not something this route expects to ever trip.
 */
import Partners from '../../features/pages/admin/Partners.astro';
import {
  createPartner,
  updatePartner,
  partnerCoverage,
  listPartners,
  heldWards,
  overrideCommsHold,
  listEois,
  acceptEoiAwareness,
  acceptEoiCuration,
  declineEoi,
  type AdminActor,
} from '../../lib/partners';
import { loadCuratorLang } from '../../lib/curator';

const session = Astro.locals.session!;
const actor: AdminActor = { userId: session.userId, role: 'admin' };

/** Maps a thrown Error's message to a user-facing i18n key, falling back to `fallbackKey` for anything unrecognized (including a defensive `'admin_only'`, which this route never expects to actually see — see module docstring). */
function errorKey(err: unknown, fallbackKey: string): string {
  const msg = err instanceof Error ? err.message : '';
  if (msg === 'invalid_slug') return 'admin.partners.error.invalidSlug';
  if (msg === 'duplicate_slug') return 'admin.partners.error.duplicateSlug';
  if (msg === 'invalid_ward_id') return 'admin.partners.error.invalidWardId';
  if (msg === 'partner_not_found') return 'admin.partners.error.partnerNotFound';
  if (msg === 'eoi_not_found') return 'admin.partners.error.eoiNotFound';
  if (msg === 'eoi_already_processed') return 'admin.partners.error.eoiAlreadyProcessed';
  return fallbackKey;
}

/** Parses a comma-separated ward-id text field. `null` for any token that isn't a bare integer (the route responds 400 rather than silently dropping a typo'd id); `[]` for a blank field (a partner with no ward coverage is valid). Same convention as src/pages/admin/roles.astro's parseWardIdsText. */
function parseWardIdsText(text: string): number[] | null {
  const tokens = text
    .split(',')
    .map((t) => t.trim())
    .filter((t) => t.length > 0);
  const ids = tokens.map(Number);
  if (ids.some((n) => !Number.isInteger(n))) return null;
  return ids;
}

let message: { kind: 'notice' | 'error'; key: string } | undefined;
let responseStatus = 200;

if (Astro.request.method === 'POST') {
  Astro.response.headers.set('cache-control', 'no-store');
  const form = await Astro.request.formData();
  const formAction = String(form.get('formAction') ?? '');
  const confirmed = form.get('confirm') != null;

  const requireConfirm = (): boolean => {
    if (!confirmed) {
      message = { kind: 'error', key: 'admin.partners.error.confirmRequired' };
      responseStatus = 400;
    }
    return confirmed;
  };

  if (formAction === 'create_partner') {
    if (requireConfirm()) {
      const slug = String(form.get('slug') ?? '').trim();
      const name = String(form.get('name') ?? '').trim();
      const contact = String(form.get('contact') ?? '').trim();
      const wardIds = parseWardIdsText(String(form.get('wardIds') ?? ''));
      if (wardIds === null) {
        message = { kind: 'error', key: 'admin.partners.error.invalidWardId' };
        responseStatus = 400;
      } else {
        try {
          await createPartner(actor, { slug, name, contact: contact || undefined, wardIds });
          return new Response(null, { status: 302, headers: { Location: '/admin/partners', 'cache-control': 'no-store' } });
        } catch (err) {
          message = { kind: 'error', key: errorKey(err, 'admin.partners.error.invalidSlug') };
          responseStatus = 400;
        }
      }
    }
  } else if (formAction === 'update_partner') {
    const partnerId = Number(form.get('partnerId'));
    if (!Number.isInteger(partnerId)) {
      return new Response(null, { status: 400, headers: { 'cache-control': 'no-store' } });
    }
    if (requireConfirm()) {
      const name = String(form.get('name') ?? '').trim();
      const contact = String(form.get('contact') ?? '').trim();
      const wardIds = parseWardIdsText(String(form.get('wardIds') ?? ''));
      if (wardIds === null) {
        message = { kind: 'error', key: 'admin.partners.error.invalidWardId' };
        responseStatus = 400;
      } else {
        try {
          await updatePartner(actor, partnerId, { name, contact, wardIds });
          return new Response(null, { status: 302, headers: { Location: '/admin/partners', 'cache-control': 'no-store' } });
        } catch (err) {
          message = { kind: 'error', key: errorKey(err, 'admin.partners.error.partnerNotFound') };
          responseStatus = 400;
        }
      }
    }
  } else if (formAction === 'override_hold') {
    const wardId = Number(form.get('wardId'));
    if (!Number.isInteger(wardId)) {
      return new Response(null, { status: 400, headers: { 'cache-control': 'no-store' } });
    }
    if (requireConfirm()) {
      try {
        await overrideCommsHold(actor, wardId);
        return new Response(null, { status: 302, headers: { Location: '/admin/partners', 'cache-control': 'no-store' } });
      } catch (err) {
        message = { kind: 'error', key: errorKey(err, 'admin.partners.error.invalidWardId') };
        responseStatus = 400;
      }
    }
  } else if (formAction === 'accept_awareness') {
    const eoiId = Number(form.get('eoiId'));
    if (!Number.isInteger(eoiId)) {
      return new Response(null, { status: 400, headers: { 'cache-control': 'no-store' } });
    }
    if (requireConfirm()) {
      const slug = String(form.get('slug') ?? '').trim();
      const name = String(form.get('name') ?? '').trim();
      try {
        await acceptEoiAwareness(actor, eoiId, { slug, name });
        return new Response(null, { status: 302, headers: { Location: '/admin/partners', 'cache-control': 'no-store' } });
      } catch (err) {
        message = { kind: 'error', key: errorKey(err, 'admin.partners.error.invalidSlug') };
        responseStatus = 400;
      }
    }
  } else if (formAction === 'accept_curation') {
    const eoiId = Number(form.get('eoiId'));
    if (!Number.isInteger(eoiId)) {
      return new Response(null, { status: 400, headers: { 'cache-control': 'no-store' } });
    }
    if (requireConfirm()) {
      try {
        await acceptEoiCuration(actor, eoiId);
        return new Response(null, { status: 302, headers: { Location: '/admin/partners', 'cache-control': 'no-store' } });
      } catch (err) {
        message = { kind: 'error', key: errorKey(err, 'admin.partners.error.eoiNotFound') };
        responseStatus = 400;
      }
    }
  } else if (formAction === 'decline_eoi') {
    const eoiId = Number(form.get('eoiId'));
    if (!Number.isInteger(eoiId)) {
      return new Response(null, { status: 400, headers: { 'cache-control': 'no-store' } });
    }
    if (requireConfirm()) {
      try {
        await declineEoi(actor, eoiId);
        return new Response(null, { status: 302, headers: { Location: '/admin/partners', 'cache-control': 'no-store' } });
      } catch (err) {
        message = { kind: 'error', key: errorKey(err, 'admin.partners.error.eoiNotFound') };
        responseStatus = 400;
      }
    }
  } else {
    return new Response(null, { status: 400, headers: { 'cache-control': 'no-store' } });
  }
}

const [partners, coverage, held, eoisAwareness, eoisCuration, lang] = await Promise.all([
  listPartners(),
  partnerCoverage(),
  heldWards(),
  listEois('new').then((rows) => rows.filter((r) => r.path === 'awareness')),
  listEois('new').then((rows) => rows.filter((r) => r.path === 'curation')),
  loadCuratorLang(session.userId),
]);
Astro.response.headers.set('cache-control', 'no-store');
Astro.response.status = responseStatus;
---

<Partners
  lang={lang}
  csrfToken={Astro.locals.csrfToken}
  partners={partners}
  coverage={coverage}
  held={held}
  eoisAwareness={eoisAwareness}
  eoisCuration={eoisCuration}
  message={message}
/>
