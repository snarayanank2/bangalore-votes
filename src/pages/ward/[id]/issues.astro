---
/**
 * Ward issues & voting (`/ward/{id}/issues`) — thin route twin over
 * src/features/pages/WardIssues.astro (see src/features/pages/README.md).
 *
 * Existence check ONLY lives here, not in WardIssues.astro — see
 * src/pages/ward/[id].astro for the full explanation of why a real 404
 * requires a page-level frontmatter script.
 */
import WardIssues from '../../../features/pages/WardIssues.astro';
import { db } from '../../../db/client';
import { wards } from '../../../db/schema';
import { eq } from 'drizzle-orm';

const idParam = Astro.params.id;
const wardId = Number(idParam);

if (!idParam || !Number.isInteger(wardId)) {
  return new Response(null, { status: 404 });
}

const [exists] = await db.select({ id: wards.id }).from(wards).where(eq(wards.id, wardId));
if (!exists) {
  return new Response(null, { status: 404 });
}
---

<WardIssues lang="en" wardId={wardId} />
