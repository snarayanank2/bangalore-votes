---
/**
 * `/curator/candidate/new?ward={id}` — see
 * src/features/pages/curator/CandidateEdit.astro for the presentational
 * side. This route twin owns:
 *   - resolving `?ward=` (missing/non-numeric -> 400; unknown ward -> 404);
 *   - the SCOPE CHECK (`canEditWard`) against that ward id -> 403 for a
 *     curator not scoped to it (same convention as
 *     src/pages/curator/queue/[id].astro);
 *   - dispatching the create POST, and redirecting to the new candidate's
 *     `/curator/candidate/{id}` edit page on success (so report-card fields
 *     can be added right after creation);
 *   - no-store on every response.
 */
import CandidateEdit from '../../../features/pages/curator/CandidateEdit.astro';
import { canEditWard } from '../../../lib/authz';
import { handleCandidateCreate, loadCuratorLang, loadWardBasic } from '../../../lib/curator';

const session = Astro.locals.session!;
const actor = { userId: session.userId, role: session.role as 'curator' | 'admin' };

const wardIdParam = Astro.url.searchParams.get('ward');
const wardId = Number(wardIdParam);
if (!wardIdParam || !Number.isInteger(wardId)) {
  return new Response(null, { status: 400, headers: { 'cache-control': 'no-store' } });
}

const ward = await loadWardBasic(wardId);
if (!ward) {
  return new Response(null, { status: 404, headers: { 'cache-control': 'no-store' } });
}

const inScope = await canEditWard(session.userId, session.role, wardId);
if (!inScope) {
  return new Response('Forbidden', { status: 403, headers: { 'cache-control': 'no-store' } });
}

const lang = await loadCuratorLang(session.userId);

let message: { kind: 'notice' | 'error'; key: string } | undefined;
let status = 200;

if (Astro.request.method === 'POST') {
  Astro.response.headers.set('cache-control', 'no-store');
  const form = await Astro.request.formData();
  const outcome = await handleCandidateCreate(actor, wardId, form);

  if (outcome.kind === 'created') {
    return new Response(null, {
      status: 302,
      headers: { Location: `/curator/candidate/${outcome.id}`, 'cache-control': 'no-store' },
    });
  }

  message = { kind: 'error', key: outcome.key };
  status = 400;
}

Astro.response.headers.set('cache-control', 'no-store');
Astro.response.status = status;
---

<CandidateEdit
  lang={lang}
  csrfToken={Astro.locals.csrfToken}
  wardId={ward.id}
  wardNameEn={ward.nameEn}
  wardNameKn={ward.nameKn}
  message={message}
/>
