---
/**
 * `/curator/ward/{id}/issues` — see
 * src/features/pages/curator/WardIssuesEdit.astro for the presentational
 * side. This route twin owns the numeric-id existence check (404), the
 * SCOPE CHECK against the ward (`canEditWard`, 403), dispatching the
 * add/rename/remove POSTs via src/lib/ward-issues.ts, and no-store on
 * every response.
 *
 * The remove form's confirmation checkbox (`confirmRemove`) is validated
 * HERE, server-side, before `removeWardIssue` is ever called — mirrors
 * `handleAccept`'s identical `confirmPublish` belt-and-suspenders check in
 * src/lib/curator.ts (a direct POST must not be able to skip the HTML
 * `required` attribute).
 */
import WardIssuesEdit from '../../../../features/pages/curator/WardIssuesEdit.astro';
import { canEditWard } from '../../../../lib/authz';
import { loadCuratorLang, loadWardBasic } from '../../../../lib/curator';
import { addWardIssue, listWardIssues, removeWardIssue, renameWardIssue } from '../../../../lib/ward-issues';

const session = Astro.locals.session!;
const actor = { userId: session.userId, role: session.role as 'curator' | 'admin' };

const idParam = Astro.params.id;
const wardId = Number(idParam);
if (!idParam || !Number.isInteger(wardId)) {
  return new Response(null, { status: 404, headers: { 'cache-control': 'no-store' } });
}

const ward = await loadWardBasic(wardId);
if (!ward) {
  return new Response(null, { status: 404, headers: { 'cache-control': 'no-store' } });
}

const inScope = await canEditWard(session.userId, session.role, wardId);
if (!inScope) {
  return new Response('Forbidden', { status: 403, headers: { 'cache-control': 'no-store' } });
}

const lang = await loadCuratorLang(session.userId);

let message: { kind: 'notice' | 'error'; key: string } | undefined;
let responseStatus = 200;

if (Astro.request.method === 'POST') {
  Astro.response.headers.set('cache-control', 'no-store');
  const form = await Astro.request.formData();
  const formAction = String(form.get('formAction') ?? '');

  try {
    if (formAction === 'add') {
      const titleEn = String(form.get('titleEn') ?? '').trim();
      if (!titleEn) {
        message = { kind: 'error', key: 'curator.wardIssuesEdit.error.titleRequired' };
        responseStatus = 400;
      } else {
        await addWardIssue(actor, wardId, titleEn);
        return new Response(null, {
          status: 302,
          headers: { Location: `/curator/ward/${wardId}/issues`, 'cache-control': 'no-store' },
        });
      }
    } else if (formAction.startsWith('rename:')) {
      const issueId = Number(formAction.slice('rename:'.length));
      const titleEn = String(form.get('titleEn') ?? '').trim();
      if (!Number.isInteger(issueId) || !titleEn) {
        return new Response(null, { status: 400, headers: { 'cache-control': 'no-store' } });
      }
      await renameWardIssue(actor, issueId, titleEn);
      return new Response(null, {
        status: 302,
        headers: { Location: `/curator/ward/${wardId}/issues`, 'cache-control': 'no-store' },
      });
    } else if (formAction.startsWith('remove:')) {
      const issueId = Number(formAction.slice('remove:'.length));
      if (!Number.isInteger(issueId)) {
        return new Response(null, { status: 400, headers: { 'cache-control': 'no-store' } });
      }
      const confirmed = form.get('confirmRemove') != null;
      if (!confirmed) {
        message = { kind: 'error', key: 'curator.wardIssuesEdit.error.confirmRequired' };
        responseStatus = 400;
      } else {
        await removeWardIssue(actor, issueId);
        return new Response(null, {
          status: 302,
          headers: { Location: `/curator/ward/${wardId}/issues`, 'cache-control': 'no-store' },
        });
      }
    } else {
      return new Response(null, { status: 400, headers: { 'cache-control': 'no-store' } });
    }
  } catch (err) {
    if (err instanceof Error && (err.message === 'out_of_scope' || err.message === 'not_found')) {
      return new Response('Forbidden', { status: 403, headers: { 'cache-control': 'no-store' } });
    }
    throw err;
  }
}

const issues = await listWardIssues(wardId);

Astro.response.headers.set('cache-control', 'no-store');
Astro.response.status = responseStatus;
---

<WardIssuesEdit
  lang={lang}
  csrfToken={Astro.locals.csrfToken}
  wardId={wardId}
  wardNameEn={ward.nameEn}
  wardNameKn={ward.nameKn}
  issues={issues}
  message={message}
/>
