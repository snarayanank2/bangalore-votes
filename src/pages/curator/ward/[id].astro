---
/**
 * `/curator/ward/{id}` — see src/features/pages/curator/WardEdit.astro for
 * the presentational side. This route twin owns the numeric-id existence
 * check (404), the SCOPE CHECK (`canEditWard`, 403), dispatching the
 * `formAction=sign_off` POST via `handleWardSignOff`, and no-store on
 * every response — same conventions as
 * src/pages/curator/candidate/[id].astro.
 */
import WardEdit from '../../../features/pages/curator/WardEdit.astro';
import { canEditWard } from '../../../lib/authz';
import { handleWardSignOff, loadCuratorLang, loadWardForEdit } from '../../../lib/curator';

const session = Astro.locals.session!;
const actor = { userId: session.userId, role: session.role as 'curator' | 'admin' };

const idParam = Astro.params.id;
const wardId = Number(idParam);
if (!idParam || !Number.isInteger(wardId)) {
  return new Response(null, { status: 404, headers: { 'cache-control': 'no-store' } });
}

let ward = await loadWardForEdit(wardId);
if (!ward) {
  return new Response(null, { status: 404, headers: { 'cache-control': 'no-store' } });
}

const inScope = await canEditWard(session.userId, session.role, wardId);
if (!inScope) {
  return new Response('Forbidden', { status: 403, headers: { 'cache-control': 'no-store' } });
}

const lang = await loadCuratorLang(session.userId);

let message: { kind: 'notice' | 'error'; key: string } | undefined;
let responseStatus = 200;

if (Astro.request.method === 'POST') {
  Astro.response.headers.set('cache-control', 'no-store');
  const form = await Astro.request.formData();
  const formAction = String(form.get('formAction') ?? '');

  if (formAction === 'sign_off') {
    const outcome = await handleWardSignOff(actor, wardId);
    if (outcome.kind === 'saved') {
      return new Response(null, {
        status: 302,
        headers: { Location: `/curator/ward/${wardId}`, 'cache-control': 'no-store' },
      });
    }
    // out_of_scope here would mean the GET-time canEditWard check above
    // passed but the lib-level check disagreed — defensive only, never
    // expected to actually trigger.
    return new Response('Forbidden', { status: 403, headers: { 'cache-control': 'no-store' } });
  }

  return new Response(null, { status: 400, headers: { 'cache-control': 'no-store' } });
}

ward = (await loadWardForEdit(wardId))!;
Astro.response.headers.set('cache-control', 'no-store');
Astro.response.status = responseStatus;
---

<WardEdit lang={lang} csrfToken={Astro.locals.csrfToken} ward={ward} message={message} />
