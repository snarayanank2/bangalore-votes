---
/**
 * `/curator/queue/{id}` — see src/features/pages/curator/QueueItem.astro
 * for the presentational side. This route twin owns:
 *   - the numeric-id existence check (404 for a non-integer id or a row
 *     that doesn't exist — same pattern as src/pages/ward/[id].astro);
 *   - the SCOPE CHECK (`canEditWard`) — a curator whose scope does not
 *     cover this item's ward gets a 403, and never sees the item's content
 *     (the queue list is the OTHER half of this test: it never lists an
 *     out-of-scope item in the first place, src/lib/curator.ts's
 *     `loadQueueList`);
 *   - dispatching the accept/reject POST via the hidden `formAction`
 *     field, and the resulting redirect/re-render/403 status codes;
 *   - no-store on every response.
 */
import QueueItem from '../../../features/pages/curator/QueueItem.astro';
import { canEditWard } from '../../../lib/authz';
import { handleAccept, handleReject, loadCuratorLang, loadQueueItem } from '../../../lib/curator';

const session = Astro.locals.session!;
const actor = { userId: session.userId, role: session.role as 'curator' | 'admin' };

const idParam = Astro.params.id;
const itemId = Number(idParam);
if (!idParam || !Number.isInteger(itemId)) {
  return new Response(null, { status: 404 });
}

let item = await loadQueueItem(itemId);
if (!item) {
  return new Response(null, { status: 404 });
}

const inScope = await canEditWard(session.userId, session.role, item.wardId);
if (!inScope) {
  return new Response('Forbidden', { status: 403, headers: { 'cache-control': 'no-store' } });
}

const lang = await loadCuratorLang(session.userId);

let message: { kind: 'notice' | 'error'; key: string } | undefined;
let status = 200;

if (Astro.request.method === 'POST') {
  Astro.response.headers.set('cache-control', 'no-store');
  const form = await Astro.request.formData();
  const formAction = String(form.get('formAction') ?? '');

  const outcome =
    formAction === 'accept' ? await handleAccept(actor, item, form) : await handleReject(actor, item.id, form);

  if (outcome.kind === 'accepted' || outcome.kind === 'rejected') {
    return new Response(null, {
      status: 302,
      headers: { Location: '/curator/queue', 'cache-control': 'no-store' },
    });
  }

  if (outcome.kind === 'already_resolved') {
    message = { kind: 'notice', key: 'curator.queueItem.alreadyResolved' };
    item = (await loadQueueItem(itemId))!;
  } else {
    message = { kind: 'error', key: outcome.key };
    status = 400;
  }
}

Astro.response.headers.set('cache-control', 'no-store');
Astro.response.status = status;
---

<QueueItem lang={lang} csrfToken={Astro.locals.csrfToken} item={item} message={message} />
