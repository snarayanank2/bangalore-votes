---
/**
 * `/account/notifications` — see src/features/pages/AccountNotifications.astro
 * for the full explanation. Route-twin concerns only: session guard,
 * no-store.
 */
import AccountNotifications from '../../features/pages/AccountNotifications.astro';
import { handleNotificationsPost, loadNotificationsState, type AccountMessage } from '../../lib/account-flow';

const session = Astro.locals.session;
if (!session) {
  return Astro.redirect(`/login?next=${encodeURIComponent('/account/notifications')}`);
}

let message: AccountMessage | undefined;

if (Astro.request.method === 'POST') {
  Astro.response.headers.set('cache-control', 'no-store');
  const form = await Astro.request.formData();
  await handleNotificationsPost(session.userId, form);
  message = { kind: 'notice', key: 'account.notifications.success' };
}

const notifications = await loadNotificationsState(session.userId);
Astro.response.headers.set('cache-control', 'no-store');
---

<AccountNotifications
  lang="en"
  csrfToken={Astro.locals.csrfToken}
  emailEnabled={notifications.emailEnabled}
  whatsappEnabled={notifications.whatsappEnabled}
  message={message}
/>
