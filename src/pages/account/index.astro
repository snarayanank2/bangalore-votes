---
/**
 * `/account` — see src/features/pages/Account.astro for the full flow
 * explanation. This route twin (like src/pages/login.astro) owns the HTTP
 * concerns a child Astro component cannot: the redirect-to-`/login` guard
 * (belt-and-braces over src/middleware.ts's own session guard — if
 * `locals.session.userId` somehow no longer resolves to a user row, this
 * still redirects rather than crash), the sign-out redirect + Set-Cookie,
 * and `no-store` on every response (an authed, per-user page must never be
 * cached).
 */
import Account from '../../features/pages/Account.astro';
import { handleAccountPost, loadAccountState, type AccountRenderState } from '../../lib/account-flow';
import { destroySession, clearSessionCookie, SESSION_COOKIE } from '../../lib/session';

const session = Astro.locals.session;
if (!session) {
  return Astro.redirect(`/login?next=${encodeURIComponent('/account')}`);
}

let state: AccountRenderState | null = await loadAccountState(session.userId);
if (!state) {
  return Astro.redirect(`/login?next=${encodeURIComponent('/account')}`);
}

if (Astro.request.method === 'POST') {
  Astro.response.headers.set('cache-control', 'no-store');

  const form = await Astro.request.formData();
  const outcome = await handleAccountPost(session.userId, form);

  if (outcome.kind === 'signout') {
    const cookieValue = Astro.cookies.get(SESSION_COOKIE)?.value;
    if (cookieValue) await destroySession(cookieValue);
    return new Response(null, {
      status: 302,
      headers: {
        Location: '/',
        'Set-Cookie': clearSessionCookie(),
        'cache-control': 'no-store',
      },
    });
  }

  state = outcome.state;
}

Astro.response.headers.set('cache-control', 'no-store');
---

<Account lang="en" state={state} csrfToken={Astro.locals.csrfToken} />
