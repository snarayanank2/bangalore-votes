---
/**
 * `/account/submissions` — see src/features/pages/AccountSubmissions.astro
 * for the full explanation. GET only; route-twin concerns: session guard,
 * no-store (an authed, per-user page must never be cached).
 */
import AccountSubmissions from '../../features/pages/AccountSubmissions.astro';
import { loadSubmissions } from '../../lib/account-flow';

const session = Astro.locals.session;
if (!session) {
  return Astro.redirect(`/login?next=${encodeURIComponent('/account/submissions')}`);
}

const submissions = await loadSubmissions(session.userId);
Astro.response.headers.set('cache-control', 'no-store');
---

<AccountSubmissions lang="en" submissions={submissions} />
