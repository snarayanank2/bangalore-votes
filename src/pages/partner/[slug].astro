---
/**
 * Partner kit (`/partner/{slug}`) — thin route twin over
 * src/features/pages/PartnerKit.astro (see src/features/pages/README.md).
 *
 * Existence check ONLY lives here, not in PartnerKit.astro: only a
 * page-level frontmatter script can end an Astro request early with a
 * custom HTTP status (returning a Response from a component rendered as a
 * child of a page has no effect on the actual response) — so this twin
 * runs a minimal existence lookup and returns a real 404 before
 * PartnerKit.astro (which does its own full-row lookup for the fields it
 * renders) is ever reached. Same convention as
 * src/pages/candidate/[slug].astro. IA §3.19: an unknown partner slug
 * 404s; an existing one is always 200.
 */
import PartnerKit from '../../features/pages/PartnerKit.astro';
import { db } from '../../db/client';
import { partners } from '../../db/schema';
import { eq } from 'drizzle-orm';

const slug = Astro.params.slug;

if (!slug) {
  return new Response(null, { status: 404 });
}

const [exists] = await db.select({ id: partners.id }).from(partners).where(eq(partners.slug, slug));
if (!exists) {
  return new Response(null, { status: 404 });
}
---

<PartnerKit lang="en" slug={slug} />
